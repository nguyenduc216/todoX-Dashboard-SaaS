@code {
    private List<Customer> CustomerRows = new();
    private string NewCustomerName = string.Empty;
    private string? NewCustomerEmail;
    private string? NewCustomerPhone;

    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync() => CustomerRows = await Db.Customers.OrderByDescending(x => x.CreatedAt).ToListAsync();
    private async Task AddCustomerAsync()
    {
        if (string.IsNullOrWhiteSpace(NewCustomerName)) return;
        var customer = new Customer { Name = NewCustomerName.Trim(), Email = NewCustomerEmail, Phone = NewCustomerPhone };
        Db.Customers.Add(customer);
        Db.TokenWallets.Add(new TokenWallet { CustomerId = customer.Id, Balance = 0 });
        await Db.SaveChangesAsync();
        NewCustomerName = string.Empty; NewCustomerEmail = null; NewCustomerPhone = null;
        await LoadAsync();
    }
}