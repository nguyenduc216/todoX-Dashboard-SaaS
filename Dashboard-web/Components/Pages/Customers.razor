        <MudItem xs="12" md="4"><MudTextField T="string" Label="TÃªn khÃ¡ch hÃ ng" @bind-Value="NewCustomerName" /></MudItem>
        <MudItem xs="12" md="3"><MudTextField T="string" Label="Email" @bind-Value="NewCustomerEmail" /></MudItem>
