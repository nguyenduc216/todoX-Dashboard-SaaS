     private static void ValidateUpdate(UpdateCharacterRequest request)
     {
         ArgumentNullException.ThrowIfNull(request);
         if (string.IsNullOrWhiteSpace(request.CharacterName)) throw new InvalidOperationException("Tên character không được trống.");
         if (string.IsNullOrWhiteSpace(request.Description)) throw new InvalidOperationException("Mô tả character không được trống.");
         if (string.IsNullOrWhiteSpace(request.AspectRatio)) throw new InvalidOperationException("Aspect ratio không được trống.");
         if (!AspectRatios.Contains(request.AspectRatio.Trim())) throw new InvalidOperationException($"Tỷ lệ khung hình không hợp lệ: {request.AspectRatio}");
     }
