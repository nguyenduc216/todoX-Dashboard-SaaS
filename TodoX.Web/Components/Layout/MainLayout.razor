@inherits LayoutComponentBase
@implements IDisposable
@inject AuthStateService AuthState
@inject AccountService Accounts
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="todox-shell">
    <MudAppBar Class="todox-appbar" Elevation="0">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Warning" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <div class="todox-top-logo">
            <span class="todox-logo-text">Todo<span>X</span></span>
        </div>

        <MudSpacer />

        <MudMenu @bind-Open="_notifyOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="todox-notify-menu">
            <ActivatorContent>
                <div class="todox-activator" @onclick="@(() => _notifyOpen = !_notifyOpen)">
                    <MudBadge Content="@NotificationCount" Color="Color.Error" Overlap="true" Visible="@(NotificationCount > 0)" Class="todox-notify-badge">
                        <MudIcon Icon="@Icons.Material.Filled.Notifications" Color="Color.Warning" />
                    </MudBadge>
                </div>
            </ActivatorContent>
            <ChildContent>
                <div class="todox-notify-head">Thông báo</div>
                <MudMenuItem>Không có thông báo mới</MudMenuItem>
            </ChildContent>
        </MudMenu>

        <MudMenu @bind-Open="_userMenuOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="todox-user-menu">
            <ActivatorContent>
                <div class="todox-user-activator" @onclick="@(() => _userMenuOpen = !_userMenuOpen)">
                    <MudHidden Breakpoint="Breakpoint.SmAndDown">
                        <MudText Typo="Typo.body2" Class="todox-user-hello">Xin chào, <b>@UserDisplayName</b></MudText>
                    </MudHidden>
                    <MudAvatar Class="todox-avatar">
                        @if (!string.IsNullOrWhiteSpace(UserAvatarUrl))
                        {
                            <MudImage Src="@UserAvatarUrl" />
                        }
                        else
                        {
                            @AvatarText
                        }
                    </MudAvatar>
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Warning" Size="Size.Small" />
                </div>
            </ActivatorContent>
            <ChildContent>
                <div class="todox-user-menu-head">
                    <div class="todox-user-menu-name">@UserDisplayName</div>
                    <div class="todox-user-menu-email">@UserEmail</div>
                    <div class="todox-user-menu-role">@RoleLabel</div>
                </div>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.Person" Href="/profile">Hồ sơ cá nhân</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Password" Href="/profile">Đổi mật khẩu</MudMenuItem>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="Logout">Đăng xuất</MudMenuItem>
            </ChildContent>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Class="todox-drawer"
               Width="292px"
               Elevation="0"
               Variant="DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Md">

        <div class="todox-sidebar-logo">
            <span class="todox-logo-text">Todo<span>X</span></span>
        </div>

        <MudNavMenu Class="todox-nav">
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                Dashboard
            </MudNavLink>

            @if (CanModule("admin_users"))
            {
                <MudNavLink Href="/admin-users" Icon="@Icons.Material.Filled.AdminPanelSettings">
                    Quản trị viên
                </MudNavLink>
            }
            @if (CanModule("customers"))
            {
                <MudNavLink Href="/customers" Icon="@Icons.Material.Filled.Groups">
                    Quản lý khách hàng
                </MudNavLink>
            }
            @if (CanModule("customer_accounts"))
            {
                <MudNavLink Href="/customer-accounts" Icon="@Icons.Material.Filled.ManageAccounts">
                    Quản lý tài khoản
                </MudNavLink>
            }
            @if (CanModule("token_wallets"))
            {
                <MudNavLink Href="/wallets" Icon="@Icons.Material.Filled.AccountBalanceWallet">
                    Quản lý token
                </MudNavLink>
            }
            @if (CanModule("services"))
            {
                <MudNavLink Href="/services" Icon="@Icons.Material.Filled.Category">
                    Quản lý dịch vụ
                </MudNavLink>
            }
            @if (CanModule("render_jobs"))
            {
                <MudNavLink Href="/render-jobs" Icon="@Icons.Material.Filled.Movie">
                    Render Jobs
                </MudNavLink>
            }
            @if (CanModule("customer_pages"))
            {
                <MudNavLink Href="/my-pages" Icon="@Icons.Material.Filled.Public">
                    Trang mạng xã hội
                </MudNavLink>
            }
            @if (CanModule("roles") || CanModule("permissions"))
            {
                <MudNavLink Href="/permissions" Icon="@Icons.Material.Filled.Security">
                    Phân quyền
                </MudNavLink>
            }
            @if (CanModule("settings") || CanModule("app_settings"))
            {
                <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">
                    Cài đặt hệ thống
                </MudNavLink>
            }
            @if (CanModule("prompt_templates") || CanModule("settings") || CanModule("app_settings"))
            {
                <MudNavLink Href="/settings/prompt-templates" Icon="@Icons.Material.Filled.AutoFixHigh">
                    Quản lý prompt
                </MudNavLink>
            }
            @if (CanModule("api_providers"))
            {
                <MudNavLink Href="/api-settings" Icon="@Icons.Material.Filled.Api">
                    Cài đặt API (todox)
                </MudNavLink>
                <MudNavLink Href="/settings/api-providers" Icon="@Icons.Material.Filled.Dns">
                    Nhà cung cấp API
                </MudNavLink>
                <MudNavLink Href="/settings/api-endpoints" Icon="@Icons.Material.Filled.SettingsEthernet">
                    API Endpoints
                </MudNavLink>
            }
            @if (CanModule("audit_logs"))
            {
                <MudNavLink Href="/activity-logs" Icon="@Icons.Material.Filled.Article">
                    Nhật ký hoạt động
                </MudNavLink>
            }
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="todox-content">
        <div class="todox-breadcrumb">
            <MudIcon Icon="@Icons.Material.Filled.Home" Size="Size.Small" />
            <span>Dashboard</span>
            <span class="todox-breadcrumb-separator">›</span>
            <span class="todox-breadcrumb-muted">Overview</span>
        </div>

        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _userMenuOpen;
    private bool _notifyOpen;

    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#ffb700",
            Secondary = "#ffd45a",
            Background = "#05080d",
            Surface = "#111821",
            DrawerBackground = "#05080d",
            AppbarBackground = "#05080d",
            AppbarText = "#ffffff",
            TextPrimary = "#ffffff",
            TextSecondary = "#aeb7c4"
        }
    };

    private string UserDisplayName => AuthState.CurrentUser?.DisplayName ?? "Người dùng";
    private string UserEmail => AuthState.CurrentUser?.Email ?? "";
    private string? UserAvatarUrl => AuthState.CurrentUser?.AvatarUrl;
    private int NotificationCount => 3;

    private bool Can(string permission) => AuthState.CurrentUser?.Can(permission) == true;
    private bool CanModule(string module) => AuthState.CurrentUser?.CanViewModule(module) == true;

    protected override void OnInitialized()
    {
        AuthState.OnChange += HandleAuthChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Restore any persisted session (survives circuit reconnects & browser restarts
            // when Remember Me was chosen). Uses JS interop so it must run after render.
            if (!AuthState.IsInitialized)
            {
                await AuthState.InitializeAsync(id => Accounts.RehydrateSessionAsync(id));
            }

            // Only redirect once we know the real auth state.
            if (!AuthState.IsAuthenticated)
            {
                Navigation.NavigateTo("/login", forceLoad: false);
            }
        }
    }

    private void HandleAuthChange() => InvokeAsync(StateHasChanged);

    public void Dispose() => AuthState.OnChange -= HandleAuthChange;

    private string RoleLabel => AuthState.CurrentUser?.Role switch
    {
        TodoXUserRole.Admin => "Quản trị viên",
        TodoXUserRole.SystemOperator => "Vận hành hệ thống",
        TodoXUserRole.CustomerOwner => "Chủ tài khoản khách hàng",
        TodoXUserRole.CustomerUser => "Người dùng khách hàng",
        _ => "Người dùng"
    };

    private string AvatarText => string.IsNullOrWhiteSpace(UserDisplayName)
        ? "U"
        : UserDisplayName.Trim()[0].ToString().ToUpperInvariant();

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task Logout()
    {
        await AuthState.SignOutAsync();
        Navigation.NavigateTo("/login");
    }
}
