@inherits LayoutComponentBase
@implements IDisposable
@inject AuthStateService AuthState
@inject AccountService Accounts
@inject NavigationMenuRepository NavigationMenus
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="todox-shell">
    <MudAppBar Class="todox-appbar" Elevation="0">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Warning" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <div class="todox-top-logo">
            <span class="todox-logo-text">Todo<span>X</span></span>
        </div>

        <MudSpacer />

        @if (AuthState.CurrentUser?.IsImpersonating == true)
        {
            <MudButton Size="Size.Small"
                       Variant="Variant.Outlined"
                       Color="Color.Warning"
                       StartIcon="@Icons.Material.Filled.SupervisedUserCircle"
                       OnClick="StopImpersonation">
                Đang đăng nhập hộ · Thoát
            </MudButton>
        }

        <MudMenu @bind-Open="_notifyOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="todox-notify-menu">
            <ActivatorContent>
                <div class="todox-activator" @onclick="@(() => _notifyOpen = !_notifyOpen)">
                    <MudBadge Content="@NotificationCount" Color="Color.Error" Overlap="true" Visible="@(NotificationCount > 0)" Class="todox-notify-badge">
                        <MudIcon Icon="@Icons.Material.Filled.Notifications" Color="Color.Warning" />
                    </MudBadge>
                </div>
            </ActivatorContent>
            <ChildContent>
                <div class="todox-notify-head">Thông báo</div>
                <MudMenuItem>Không có thông báo mới</MudMenuItem>
            </ChildContent>
        </MudMenu>

        <MudMenu @bind-Open="_userMenuOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="todox-user-menu">
            <ActivatorContent>
                <div class="todox-user-activator" @onclick="@(() => _userMenuOpen = !_userMenuOpen)">
                    <MudHidden Breakpoint="Breakpoint.SmAndDown">
                        <MudText Typo="Typo.body2" Class="todox-user-hello">Xin chào, <b>@UserDisplayName</b></MudText>
                    </MudHidden>
                    <MudAvatar Class="todox-avatar">
                        @if (!string.IsNullOrWhiteSpace(UserAvatarUrl))
                        {
                            <img src="@UserAvatarUrl" alt="Ảnh đại diện" class="todox-avatar-img" />
                        }
                        else
                        {
                            @AvatarText
                        }
                    </MudAvatar>
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Warning" Size="Size.Small" />
                </div>
            </ActivatorContent>
            <ChildContent>
                <div class="todox-user-menu-head">
                    <div class="todox-user-menu-name">@UserDisplayName</div>
                    <div class="todox-user-menu-email">@UserEmail</div>
                    <div class="todox-user-menu-role">@RoleLabel</div>
                </div>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.Person" Href="/profile">Hồ sơ cá nhân</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Password" Href="/profile">Đổi mật khẩu</MudMenuItem>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="Logout">Đăng xuất</MudMenuItem>
            </ChildContent>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Class="todox-drawer"
               Width="292px"
               Elevation="0"
               Variant="DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Md">

        <MudNavMenu Class="todox-nav">
            @if (!_menuLoaded)
            {
                <div class="todox-nav-loading">
                    <MudProgressLinear Indeterminate="true" Color="Color.Warning" />
                </div>
            }
            else
            {
                @foreach (var group in _menuGroups)
                {
                    if (group.Items.Count == 1 && group.Code == "overview")
                    {
                        var item = group.Items[0];
                        <MudNavLink Href="@item.Href"
                                    Match="@(item.MatchAll ? NavLinkMatch.All : NavLinkMatch.Prefix)"
                                    Icon="@ResolveIcon(item.IconKey)">
                            @item.Title
                        </MudNavLink>
                    }
                    else
                    {
                        <MudNavGroup Title="@group.Title"
                                     Icon="@ResolveIcon(group.IconKey)"
                                     Expanded="@group.DefaultExpanded">
                            @foreach (var item in group.Items)
                            {
                                <MudNavLink Href="@item.Href"
                                            Match="@(item.MatchAll ? NavLinkMatch.All : NavLinkMatch.Prefix)"
                                            Icon="@ResolveIcon(item.IconKey)">
                                    @item.Title
                                </MudNavLink>
                            }
                        </MudNavGroup>
                    }
                }
            }
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="todox-content">
        <div class="todox-breadcrumb">
            <MudIcon Icon="@Icons.Material.Filled.Home" Size="Size.Small" />
            <span>Dashboard</span>
            <span class="todox-breadcrumb-separator">›</span>
            <span class="todox-breadcrumb-muted">Overview</span>
        </div>

        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _userMenuOpen;
    private bool _notifyOpen;
    private IReadOnlyList<NavigationMenuGroupDto> _menuGroups = Array.Empty<NavigationMenuGroupDto>();
    private bool _menuLoaded;

    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#ffb700",
            Secondary = "#ffd45a",
            Background = "#05080d",
            Surface = "#111821",
            DrawerBackground = "#05080d",
            AppbarBackground = "#05080d",
            AppbarText = "#ffffff",
            TextPrimary = "#ffffff",
            TextSecondary = "#aeb7c4"
        }
    };

    private string UserDisplayName => AuthState.CurrentUser?.DisplayName ?? "Người dùng";
    private string UserEmail => AuthState.CurrentUser?.Email ?? "";
    private string? UserAvatarUrl => AuthState.CurrentUser?.AvatarUrl;
    private int NotificationCount => 3;

    private bool Can(string permission) => AuthState.CurrentUser?.Can(permission) == true;
    private bool CanModule(string module) => AuthState.CurrentUser?.CanViewModule(module) == true;

    protected override void OnInitialized()
    {
        AuthState.OnChange += HandleAuthChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (!AuthState.IsInitialized)
            {
                await AuthState.InitializeAsync(id => Accounts.RehydrateSessionAsync(id));
            }

            if (!AuthState.IsAuthenticated && !IsPublicRoute())
            {
                Navigation.NavigateTo("/login", forceLoad: false);
            }

            await LoadNavigationMenuAsync();
        }
    }

    private bool IsPublicRoute()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/').ToLowerInvariant();
        if (string.IsNullOrWhiteSpace(path))
        {
            path = "/";
        }

        return path is "/privacy"
            or "/terms"
            or "/data-deletion"
            or "/avatar-builder"
            or "/auth/facebook/callback"
            or "/login"
            or "/register"
            or "/forgot-password";
    }

    private void HandleAuthChange() => InvokeAsync(async () =>
    {
        _menuLoaded = false;
        await LoadNavigationMenuAsync();
        StateHasChanged();
    });

    public void Dispose() => AuthState.OnChange -= HandleAuthChange;

    private string RoleLabel => AuthState.CurrentUser?.Role switch
    {
        TodoXUserRole.Admin => "Quản trị viên",
        TodoXUserRole.SystemOperator => "Vận hành hệ thống",
        TodoXUserRole.CustomerOwner => "Chủ tài khoản khách hàng",
        TodoXUserRole.CustomerUser => "Người dùng khách hàng",
        _ => "Người dùng"
    };

    private string AvatarText => string.IsNullOrWhiteSpace(UserDisplayName)
        ? "U"
        : UserDisplayName.Trim()[0].ToString().ToUpperInvariant();

    private bool CanAdminAvatarManager
        => AuthState.CurrentUser?.IsRoot == true
           || AuthState.CurrentUser?.Role is TodoXUserRole.Admin or TodoXUserRole.SystemOperator
           || CanModule("settings")
           || CanModule("services");

    private async Task LoadNavigationMenuAsync()
    {
        if (!AuthState.IsAuthenticated && !IsPublicRoute())
        {
            _menuGroups = Array.Empty<NavigationMenuGroupDto>();
            _menuLoaded = true;
            return;
        }

        try
        {
            var groups = await NavigationMenus.GetActiveMenuAsync();
            _menuGroups = ApplyMenuVisibility(groups).ToList();
            if (_menuGroups.Count == 0)
            {
                _menuGroups = ApplyMenuVisibility(BuildFallbackMenu()).ToList();
            }
        }
        catch
        {
            _menuGroups = ApplyMenuVisibility(BuildFallbackMenu()).ToList();
        }

        _menuLoaded = true;
    }

    private IEnumerable<NavigationMenuGroupDto> ApplyMenuVisibility(IEnumerable<NavigationMenuGroupDto> groups)
    {
        foreach (var group in groups.OrderBy(x => x.SortOrder))
        {
            var visibleItems = group.Items
                .OrderBy(x => x.SortOrder)
                .Where(IsMenuItemVisible)
                .ToList();

            if (visibleItems.Count == 0)
            {
                continue;
            }

            yield return new NavigationMenuGroupDto
            {
                Id = group.Id,
                Code = group.Code,
                Title = group.Title,
                IconKey = group.IconKey,
                SortOrder = group.SortOrder,
                DefaultExpanded = group.DefaultExpanded,
                Items = visibleItems
            };
        }
    }

    private bool IsMenuItemVisible(NavigationMenuItemDto item)
    {
        if (item.VisibilityPolicy.Equals("always", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        if (item.VisibilityPolicy.Equals("admin_avatar_manager", StringComparison.OrdinalIgnoreCase))
        {
            return CanAdminAvatarManager;
        }

        if (item.ModuleKeys.Length == 0)
        {
            return true;
        }

        return item.ModuleKeys.Any(CanModule);
    }

    private static string ResolveIcon(string? iconKey) => iconKey switch
    {
        "Dashboard" => Icons.Material.Filled.Dashboard,
        "AdminPanelSettings" => Icons.Material.Filled.AdminPanelSettings,
        "Groups" => Icons.Material.Filled.Groups,
        "ManageAccounts" => Icons.Material.Filled.ManageAccounts,
        "AccountBalanceWallet" => Icons.Material.Filled.AccountBalanceWallet,
        "Category" => Icons.Material.Filled.Category,
        "FaceRetouchingNatural" => Icons.Material.Filled.FaceRetouchingNatural,
        "Movie" => Icons.Material.Filled.Movie,
        "Public" => Icons.Material.Filled.Public,
        "VideoLibrary" => Icons.Material.Filled.VideoLibrary,
        "Campaign" => Icons.Material.Filled.Campaign,
        "Security" => Icons.Material.Filled.Security,
        "Settings" => Icons.Material.Filled.Settings,
        "AutoFixHigh" => Icons.Material.Filled.AutoFixHigh,
        "Api" => Icons.Material.Filled.Api,
        "Dns" => Icons.Material.Filled.Dns,
        "SettingsEthernet" => Icons.Material.Filled.SettingsEthernet,
        "Article" => Icons.Material.Filled.Article,
        _ => Icons.Material.Filled.Circle
    };

    private static IReadOnlyList<NavigationMenuGroupDto> BuildFallbackMenu()
    {
        NavigationMenuItemDto Item(string code, string title, string href, string icon, string[] modules, string policy = "any_module", bool matchAll = false, int sort = 10)
            => new()
            {
                Id = Guid.NewGuid(),
                Code = code,
                Title = title,
                Href = href,
                IconKey = icon,
                ModuleKeys = modules,
                VisibilityPolicy = policy,
                MatchAll = matchAll,
                SortOrder = sort
            };

        NavigationMenuGroupDto Group(string code, string title, string icon, int sort, bool expanded, params NavigationMenuItemDto[] items)
        {
            var id = Guid.NewGuid();
            foreach (var item in items)
            {
                item.GroupId = id;
            }

            return new NavigationMenuGroupDto
            {
                Id = id,
                Code = code,
                Title = title,
                IconKey = icon,
                SortOrder = sort,
                DefaultExpanded = expanded,
                Items = items.ToList()
            };
        }

        return new[]
        {
            Group("overview", "Tổng quan", "Dashboard", 10, true,
                Item("dashboard", "Dashboard", "/", "Dashboard", Array.Empty<string>(), "always", true, 10)),
            Group("administration", "Quản trị hệ thống", "AdminPanelSettings", 20, true,
                Item("admin_users", "Quản trị viên", "/admin-users", "AdminPanelSettings", new[] { "admin_users" }, sort: 10),
                Item("customers", "Quản lý khách hàng", "/customers", "Groups", new[] { "customers" }, sort: 20),
                Item("customer_accounts", "Quản lý tài khoản", "/customer-accounts", "ManageAccounts", new[] { "customer_accounts" }, sort: 30),
                Item("permissions", "Phân quyền", "/permissions", "Security", new[] { "roles", "permissions" }, sort: 40),
                Item("settings", "Cài đặt hệ thống", "/settings", "Settings", new[] { "settings", "app_settings" }, sort: 50),
                Item("activity_logs", "Nhật ký hoạt động", "/activity-logs", "Article", new[] { "audit_logs" }, sort: 60)),
            Group("billing_services", "Dịch vụ & điểm", "AccountBalanceWallet", 30, true,
                Item("wallets", "Quản lý điểm", "/wallets", "AccountBalanceWallet", new[] { "token_wallets" }, sort: 10),
                Item("services", "Quản lý dịch vụ", "/services", "Category", new[] { "services" }, sort: 20)),
            Group("ai_studio", "AI Studio", "AutoFixHigh", 40, true,
                Item("admin_avatar_manager", "Quản lý avatar mẫu", "/admin/avatar-manager", "FaceRetouchingNatural", new[] { "settings", "services" }, "admin_avatar_manager", sort: 10),
                Item("render_jobs", "Render Jobs", "/render-jobs", "Movie", new[] { "render_jobs" }, sort: 20),
                Item("prompt_templates", "Quản lý prompt", "/settings/prompt-templates", "AutoFixHigh", new[] { "prompt_templates", "settings", "app_settings" }, sort: 30)),
            Group("social_marketing", "Kênh mạng xã hội", "Public", 50, true,
                Item("customer_pages", "Trang mạng xã hội", "/my-pages", "Public", new[] { "customer_pages" }, sort: 10),
                Item("reference_videos", "Link video tham chiếu", "/reference-videos", "VideoLibrary", new[] { "reference_videos" }, sort: 20),
                Item("reup_campaigns", "Chiến dịch Reup", "/reup-campaigns", "Campaign", new[] { "reup_campaigns" }, sort: 30)),
            Group("api_integration", "API & tích hợp", "Api", 60, false,
                Item("api_settings", "Cài đặt API (todox)", "/api-settings", "Api", new[] { "api_providers" }, sort: 10),
                Item("api_providers", "Nhà cung cấp API", "/settings/api-providers", "Dns", new[] { "api_providers" }, sort: 20),
                Item("api_endpoints", "API Endpoints", "/settings/api-endpoints", "SettingsEthernet", new[] { "api_providers" }, sort: 30))
        };
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task Logout()
    {
        await AuthState.SignOutAsync();
        Navigation.NavigateTo("/login");
    }

    private async Task StopImpersonation()
    {
        var ok = await AuthState.StopImpersonationAsync(Accounts.RehydrateSessionAsync);
        Snackbar.Add(ok ? "Đã quay lại tài khoản quản trị." : "Không quay lại được tài khoản quản trị.", ok ? Severity.Success : Severity.Warning);
        Navigation.NavigateTo("/", forceLoad: true);
    }
}
