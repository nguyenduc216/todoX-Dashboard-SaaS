@page "/profile/avatar"
@using TodoX.Web.Services.Profile
@using TodoX.Web.Services.Media
@inject AuthStateService AuthState
@inject IAvatarService Avatars
@inject IChibiAvatarService Chibi
@inject IMediaFileService MediaFiles
@inject WalletService Wallet
@inject TokenSettingsService TokenSettings
@inject TenantContext Tenant
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Tạo ảnh chibi</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
        <div>
            <MudText Typo="Typo.h4" Class="todox-page-title">Ảnh đại diện chibi</MudText>
            <MudText Typo="Typo.body1" Class="todox-page-subtitle">Chỉnh prompt, chọn số lượng và để TodoX tạo ảnh chibi. Có thể sửa prompt và render lại từng ảnh.</MudText>
        </div>
        @if (IsCustomer)
        {
            <span class="todox-badge" style="font-size:.95rem">Số dư: @_balance.ToString("#,0") token</span>
        }
        else
        {
            <span class="todox-badge">Tài khoản quản trị · miễn phí token</span>
        }
    </MudStack>

    @if (AuthState.CurrentUser is null)
    {
        <MudAlert Severity="Severity.Warning">Vui lòng đăng nhập.</MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="5">
                <MudPaper Class="todox-card pa-5" Rounded="true">
                    <MudText Typo="Typo.h6">Ảnh tham chiếu</MudText>
                    <MudDivider Class="my-3" />
                    <MudStack Spacing="3">
                        @RefRow("avatar", "Ảnh khuôn mặt / avatar", _avatarMedia)
                        @RefRow("logo", "Logo thương hiệu (tùy chọn)", _logoMedia)
                        @RefRow("product", "Ảnh sản phẩm (tùy chọn)", _productMedia)
                        @RefRow("uniform", "Đồng phục / trang phục (tùy chọn)", _uniformMedia)
                        @RefRow("scene", "Ảnh bối cảnh (tùy chọn)", _sceneMedia)
                    </MudStack>

                    @if (_avatarMedia is null)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-3">
                            Ban chua chon anh khuon mat. He thong se tao chibi theo gioi tinh, do giong khuon mat se thap.
                        </MudAlert>
                    }

                    <MudGrid Class="mt-2">
                        <MudItem xs="12" sm="4">
                            <MudSelect T="string" Label="Giới tính nhân vật" Value="@_gender" ValueChanged="OnGenderChanged" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@("male")">Nam</MudSelectItem>
                                <MudSelectItem Value="@("female")">Nữ</MudSelectItem>
                                <MudSelectItem Value="@("other")">Khác</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudSelect T="string" Label="Góc máy" Value="@_cameraAngle" ValueChanged="OnCameraAngleChanged" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@("half_body")">Nửa người</MudSelectItem>
                                <MudSelectItem Value="@("full_body")">Toàn thân</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudNumericField T="int" Label="Số lượng ảnh" @bind-Value="_count" Min="1" Max="6" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    </MudGrid>

                    <MudExpansionPanels Class="mt-2" Elevation="0">
                        <MudExpansionPanel Text="Prompt chuẩn (có thể chỉnh sửa)">
                            <MudTextField T="string" @bind-Value="_basePrompt" Variant="Variant.Outlined" Lines="10" Class="todox-prompt-box" />
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Refresh" OnClick="ResetPrompt">
                                Đặt lại prompt mặc định
                            </MudButton>
                        </MudExpansionPanel>
                    </MudExpansionPanels>

                    <MudButton Class="todox-primary-btn mt-3" FullWidth="true" StartIcon="@Icons.Material.Filled.AutoAwesome"
                               OnClick="ConfirmAndGenerate" Disabled="_busy">
                        @(_busy ? "Đang tạo..." : $"Tạo {_count} ảnh chibi")
                    </MudButton>
                    @if (_busy)
                    {
                        <MudProgressLinear Indeterminate="true" Color="Color.Warning" Class="mt-2" />
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudPaper Class="todox-card pa-5" Rounded="true">
                    <MudText Typo="Typo.h6">Kết quả</MudText>
                    <MudDivider Class="my-3" />
                    @if (!string.IsNullOrWhiteSpace(_lastError))
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-3" ContentAlignment="HorizontalAlignment.Left"
                                  ShowCloseIcon="true" CloseIconClicked="@(() => _lastError = null)">
                            <MudText Typo="Typo.subtitle2">Chi tiết lỗi (copy gửi hỗ trợ):</MudText>
                            <pre class="todox-error-pre">@_lastError</pre>
                        </MudAlert>
                    }
                    @if (_result is null)
                    {
                        <MudText Class="todox-page-subtitle">Chưa có ảnh. Chỉnh số lượng/prompt rồi bấm "Tạo ảnh chibi".</MudText>
                    }
                    else if (_result.Status == "failed" && _result.Images.Count == 0)
                    {
                        <MudText Class="todox-page-subtitle">Không tạo được ảnh. Xem chi tiết lỗi phía trên.</MudText>
                    }
                    else
                    {
                        <MudGrid>
                            @foreach (var img in _result.Images)
                            {
                                <MudItem xs="12" sm="6">
                                    <MudPaper Class="todox-card pa-2" Rounded="true">
                                        @if (img.Status == "failed")
                                        {
                                            <MudAlert Severity="Severity.Error" Dense="true">Ảnh lỗi</MudAlert>
                                        }
                                        else
                                        {
                                            <MudImage Src="@img.Url" Fluid="true" Style="border-radius:8px;aspect-ratio:1/1;object-fit:cover;width:100%" />
                                        }
                                        <MudStack Row="true" Class="mt-2" Spacing="1">
                                            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Edit"
                                                       OnClick="@(() => EditAndRerender(img))" Disabled="_busy">Sửa prompt</MudButton>
                                            <MudButton Size="Size.Small" Class="todox-primary-btn" StartIcon="@Icons.Material.Filled.Check"
                                                       OnClick="@(() => SelectChibi(img.MediaId))" Disabled="@(_busy || img.Status == "failed")">Chọn</MudButton>
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>
                            }
                        </MudGrid>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudStack>

@code {
    private string? _gender = "male";
    private string? _cameraAngle = "half_body";
    private int _count = 3;
    private string _basePrompt = string.Empty;
    private string? _lastError;
    private bool _busy;
    private decimal _balance;
    private decimal _imageCost = 10;
    private ChibiGenerationDto? _result;
    private MediaFileDto? _avatarMedia;
    private MediaFileDto? _logoMedia;
    private MediaFileDto? _productMedia;
    private MediaFileDto? _uniformMedia;
    private MediaFileDto? _sceneMedia;

    private bool IsCustomer => AuthState.CurrentUser?.IsCustomer == true;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState.CurrentUser is null) return;
        _imageCost = await TokenSettings.GetChibiImageCostAsync();
        var current = await Avatars.GetCurrentAsync(AuthState.CurrentUser.UserId);
        if (current.MediaId is Guid mid)
        {
            _avatarMedia = await MediaFiles.GetAsync(mid);
        }
        await ResetPrompt();
        await RefreshBalance();
    }

    private async Task RefreshBalance()
    {
        if (IsCustomer && AuthState.CurrentUser?.CustomerId is Guid cid)
        {
            _balance = await Wallet.GetBalanceAsync(cid);
        }
    }

    private async Task ResetPrompt()
    {
        var template = await Chibi.GetDefaultPromptTemplateAsync();
        _basePrompt = Chibi.ResolvePromptTemplate(template, new ChibiGenerateInput
        {
            Gender = _gender,
            CameraAngle = _cameraAngle,
            AvatarMediaId = _avatarMedia?.Id,
            LogoMediaId = _logoMedia?.Id,
            ProductMediaId = _productMedia?.Id,
            UniformMediaId = _uniformMedia?.Id,
            SceneMediaId = _sceneMedia?.Id
        });
    }

    private async Task OnGenderChanged(string? value)
    {
        _gender = value;
        await ResetPrompt();
    }

    private async Task OnCameraAngleChanged(string? value)
    {
        _cameraAngle = value;
        await ResetPrompt();
    }

    private RenderFragment RefRow(string slot, string label, MediaFileDto? media) =>@<div class="d-flex align-center justify-space-between gap-2">
        <div class="d-flex align-center gap-2">
            @if (media is not null) { <MudAvatar><MudImage Src="@media.PublicUrl" /></MudAvatar> }
            <MudText Typo="Typo.body2">@label - @(media is null ? "missing" : "loaded")</MudText>
        </div>
        <MudFileUpload T="IBrowserFile" Accept="image/png,image/jpeg,image/webp" MaximumFileCount="1"
                       FilesChanged="@(f => OnRefSelected(slot, f))">
            <ActivatorContent><MudIconButton Icon="@Icons.Material.Filled.Upload" Color="Color.Warning" Size="Size.Small" /></ActivatorContent>
        </MudFileUpload>
    </div>;

    private async Task OnRefSelected(string slot, IBrowserFile file)
    {
        if (file is null || AuthState.CurrentUser is null) return;
        try
        {
            if (file.Size > 10 * 1024 * 1024) { Snackbar.Add("Ảnh vượt quá 10MB.", Severity.Error); return; }
            using var ms = new MemoryStream();
            await file.OpenReadStream(10 * 1024 * 1024).CopyToAsync(ms);
            await Tenant.EnsureLoadedAsync();
            var media = await MediaFiles.SaveAsync(ms.ToArray(), file.Name, file.ContentType,
                $"chibi_ref_{slot}", AuthState.CurrentUser.UserId, null, Tenant.TenantId);
            switch (slot)
            {
                case "avatar": _avatarMedia = media; break;
                case "logo": _logoMedia = media; break;
                case "product": _productMedia = media; break;
                case "uniform": _uniformMedia = media; break;
                case "scene": _sceneMedia = media; break;
            }
            await ResetPrompt();
            Snackbar.Add("Đã tải ảnh tham chiếu.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task ConfirmAndGenerate()
    {
        if (AuthState.CurrentUser is null) return;

        if (IsCustomer)
        {
            var total = _imageCost * _count;
            if (_balance < total)
            {
                Snackbar.Add($"Không đủ token: cần {total:#,0}, còn {_balance:#,0}.", Severity.Error);
                return;
            }
            var ok = await DialogService.ShowMessageBoxAsync("Xác nhận trừ token",
                (MarkupString)$"Tạo <b>{_count}</b> ảnh chibi sẽ trừ <b>{total:#,0} token</b> (số dư: {_balance:#,0}). Tiếp tục?",
                yesText: "Đồng ý", cancelText: "Hủy");
            if (ok != true) return;
        }

        await Generate();
    }

    private async Task Generate()
    {
        _busy = true;
        _result = null;
        _lastError = null;
        try
        {
            _result = await Chibi.GenerateAsync(new ChibiGenerateInput
            {
                UserId = AuthState.CurrentUser!.UserId,
                CustomerId = AuthState.CurrentUser.CustomerId,
                IsCustomer = IsCustomer,
                Gender = _gender,
                CameraAngle = _cameraAngle,
                Count = _count,
                PromptOverride = _basePrompt,
                AvatarMediaId = _avatarMedia?.Id,
                LogoMediaId = _logoMedia?.Id,
                ProductMediaId = _productMedia?.Id,
                UniformMediaId = _uniformMedia?.Id,
                SceneMediaId = _sceneMedia?.Id
            });
            await RefreshBalance();
            if (!string.IsNullOrWhiteSpace(_result.Error))
            {
                _lastError = _result.Error;
            }
            if (_result.Status == "failed" && _result.Images.Count == 0)
            {
                Snackbar.Add("Không tạo được ảnh. Xem chi tiết lỗi trên trang.", Severity.Error);
            }
            else
            {
                var msg = IsCustomer
                    ? $"Đã tạo {_result.Images.Count(x => x.Status != "failed")} ảnh. Đã trừ {_result.Charged:#,0} token, còn {_result.BalanceAfter:#,0}."
                    : $"Đã tạo {_result.Images.Count(x => x.Status != "failed")} ảnh chibi.";
                Snackbar.Add(msg, Severity.Success);
            }
        }
        catch (Exception ex)
        {
            _lastError = ex.ToString();
            Snackbar.Add($"Lỗi tạo chibi: {ex.Message}", Severity.Error);
        }
        finally { _busy = false; }
    }

    private async Task EditAndRerender(ChibiImage img)
    {
        if (AuthState.CurrentUser is null) return;

        var parameters = new DialogParameters { ["Prompt"] = img.PromptUsed ?? _basePrompt };
        var dialog = await DialogService.ShowAsync<Components.Dialogs.PromptEditDialog>("Sửa prompt & render lại", parameters);
        var res = await dialog.Result;
        if (res is null || res.Canceled || res.Data is not string newPrompt || string.IsNullOrWhiteSpace(newPrompt)) return;

        if (IsCustomer)
        {
            if (_balance < _imageCost)
            {
                Snackbar.Add($"Không đủ token: cần {_imageCost:#,0}, còn {_balance:#,0}.", Severity.Error);
                return;
            }
            var ok = await DialogService.ShowMessageBoxAsync("Xác nhận trừ token",
                (MarkupString)$"Render lại 1 ảnh sẽ trừ <b>{_imageCost:#,0} token</b>. Tiếp tục?",
                yesText: "Đồng ý", cancelText: "Hủy");
            if (ok != true) return;
        }

        _busy = true;
        try
        {
            var updated = await Chibi.RerenderAsync(AuthState.CurrentUser.UserId,
                AuthState.CurrentUser.CustomerId, IsCustomer, img.RenderId, newPrompt);
            // Update the image in the current result.
            var idx = _result!.Images.FindIndex(x => x.RenderId == img.RenderId);
            if (idx >= 0) _result.Images[idx] = updated;
            await RefreshBalance();
            Snackbar.Add(IsCustomer ? $"Đã render lại. Đã trừ {_imageCost:#,0} token, còn {_balance:#,0}." : "Đã render lại ảnh.", Severity.Success);
        }
        catch (Exception ex)
        {
            _lastError = ex.ToString();
            Snackbar.Add($"Lỗi render lại: {ex.Message}", Severity.Error);
        }
        finally { _busy = false; }
    }

    private async Task SelectChibi(Guid mediaId)
    {
        if (AuthState.CurrentUser is null || _result is null) return;
        _busy = true;
        try
        {
            await Chibi.SelectAsync(AuthState.CurrentUser.UserId, _result.Id, mediaId);
            var info = await Avatars.GetCurrentAsync(AuthState.CurrentUser.UserId);
            AuthState.UpdateAvatarUrl(info.AvatarUrl);
            Snackbar.Add("Đã đặt làm ảnh đại diện.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
        finally { _busy = false; }
    }
}
