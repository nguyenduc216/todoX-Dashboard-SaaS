@page "/profile/avatar"
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@using TodoX.Web.Services.Profile
@using TodoX.Web.Services.Media
@using TodoX.Web.Services.ImageRender
@inject AuthStateService AuthState
@inject IAvatarService Avatars
@inject IChibiAvatarService Chibi
@inject IMediaFileService MediaFiles
@inject WalletService Wallet
@inject TokenSettingsService TokenSettings
@inject TenantContext Tenant
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Tạo ảnh chibi</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
        <div>
            <MudText Typo="Typo.h4" Class="todox-page-title">Ảnh đại diện chibi</MudText>
            <MudText Typo="Typo.body1" Class="todox-page-subtitle">Chỉnh prompt, chọn số lượng và để TodoX tạo ảnh chibi. Có thể sửa prompt và render lại từng ảnh.</MudText>
        </div>
        @if (IsCustomer)
        {
            <span class="todox-badge" style="font-size:.95rem">Số dư: @_balance.ToString("#,0") token</span>
        }
        else
        {
            <span class="todox-badge">Tài khoản quản trị · miễn phí token</span>
        }
    </MudStack>

    @if (AuthState.CurrentUser is null)
    {
        <MudAlert Severity="Severity.Warning">Vui lòng đăng nhập.</MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="5">
                <MudPaper Class="todox-card pa-5" Rounded="true">
                    <MudText Typo="Typo.h6">Ảnh tham chiếu</MudText>
                    <MudDivider Class="my-3" />
                    <MudStack Spacing="3">
                        @RefRow("avatar", "Ảnh khuôn mặt / avatar", _avatarMedia)
                        @RefRow("logo", "Logo thương hiệu (tùy chọn)", _logoMedia)
                        @RefRow("product", "Ảnh sản phẩm (tùy chọn)", _productMedia)
                        @RefRow("uniform", "Đồng phục / trang phục (tùy chọn)", _uniformMedia)
                        @RefRow("scene", "Ảnh bối cảnh (tùy chọn)", _sceneMedia)
                    </MudStack>

                    @if (_avatarMedia is null)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-3">
                            Ban chua chon anh khuon mat. He thong se tao chibi theo gioi tinh, do giong khuon mat se thap.
                        </MudAlert>
                    }

                    <MudTextField T="string" Label="URL anh san pham (tuy chon)" Value="@_productImageUrl" ValueChanged="OnProductUrlChanged"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Link" />
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.CloudDownload"
                               Disabled="@(_busy || string.IsNullOrWhiteSpace(_productImageUrl))" OnClick="ImportProductUrl">
                        Tai anh san pham tu URL
                    </MudButton>

                    <MudGrid Class="mt-2">
                        <MudItem xs="12" sm="4">
                            <MudSelect T="string" Label="Kieu nhan vat" Value="@_characterType" ValueChanged="OnCharacterTypeChanged" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@("chibi")">Chibi</MudSelectItem>
                                <MudSelectItem Value="@("cartoon")">Hoat hinh</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudSelect T="string" Label="Gioi tinh" Value="@_gender" ValueChanged="OnGenderChanged" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@("male")">Nam</MudSelectItem>
                                <MudSelectItem Value="@("female")">Nu</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudSelect T="string" Label="Goc may" Value="@_cameraAngle" ValueChanged="OnCameraAngleChanged" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@("close_up")">Can mat</MudSelectItem>
                                <MudSelectItem Value="@("half_body")">Nua nguoi</MudSelectItem>
                                <MudSelectItem Value="@("full_body")">Toan than</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="8">
                            <MudSelect T="string" Label="Trang phuc" Value="@_outfit" ValueChanged="OnOutfitChanged" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@("vest")">Vest</MudSelectItem>
                                <MudSelectItem Value="@("dress")">Vay</MudSelectItem>
                                <MudSelectItem Value="@("formal")">Do tay</MudSelectItem>
                                <MudSelectItem Value="@("tshirt")">Do thun</MudSelectItem>
                                <MudSelectItem Value="@("swimwear")">Do tam</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudNumericField T="int" Label="So luong anh" Value="@_count" ValueChanged="OnCountChanged" Min="1" Max="4" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    </MudGrid>

                    <MudExpansionPanels Class="mt-2" Elevation="0">
                        <MudExpansionPanel Text="Prompt chuẩn (có thể chỉnh sửa)">
                            @if (_promptEdited)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">Prompt da duoc chinh tay.</MudAlert>
                            }
                            <MudTextField T="string" Value="@_basePrompt" ValueChanged="OnPromptChanged" Variant="Variant.Outlined" Lines="10" Class="todox-prompt-box" />
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Refresh" OnClick="ResetPrompt">
                                Đặt lại prompt mặc định
                            </MudButton>
                        </MudExpansionPanel>
                    </MudExpansionPanels>

                    <MudButton Class="todox-primary-btn mt-3" FullWidth="true" StartIcon="@Icons.Material.Filled.AutoAwesome"
                               OnClick="ConfirmAndGenerate" Disabled="_busy">
                        @(_busy ? "Đang tạo..." : $"Tạo {_count} ảnh chibi")
                    </MudButton>
                    @if (_busy)
                    {
                        <MudProgressLinear Indeterminate="true" Color="Color.Warning" Class="mt-2" />
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudPaper Class="todox-card pa-5" Rounded="true">
                    <MudText Typo="Typo.h6">Kết quả</MudText>
                    <MudDivider Class="my-3" />
                    @if (!string.IsNullOrWhiteSpace(_lastError))
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-3" ContentAlignment="HorizontalAlignment.Left"
                                  ShowCloseIcon="true" CloseIconClicked="@(() => _lastError = null)">
                            <MudText Typo="Typo.subtitle2">Chi tiết lỗi (copy gửi hỗ trợ):</MudText>
                            <pre class="todox-error-pre">@_lastError</pre>
                        </MudAlert>
                    }
                    <div Class='@($"avatar-result-zone {(_busy ? "is-rendering" : string.Empty)}")'>
                        @if (_busy && _rerenderingRenderId is null)
                        {
                            <div class="avatar-loading-overlay">
                                <MudProgressCircular Indeterminate="true" Color="Color.Warning" Size="Size.Medium" />
                                <MudText Typo="Typo.body2">Dang render...</MudText>
                            </div>
                        }
                        @if (_result is null)
                        {
                            <div class="avatar-render-placeholder">
                                <MudText Class="todox-page-subtitle">Chua co anh. Chinh so luong/prompt roi bam tao anh chibi.</MudText>
                            </div>
                        }
                        else if (_result.Status == "failed" && _result.Images.Count == 0)
                        {
                            <MudText Class="todox-page-subtitle">Khong tao duoc anh. Xem chi tiet loi phia tren.</MudText>
                        }
                        else
                        {
                            <MudGrid>
                                @foreach (var img in _result.Images)
                                {
                                    <MudItem xs="12" sm="6">
                                        <MudPaper Class='@($"todox-card pa-2 avatar-render-card {(IsCardRendering(img) ? "is-rendering" : string.Empty)}")' Rounded="true">
                                            @if (IsCardRendering(img))
                                            {
                                                <div class="avatar-card-overlay">
                                                    <MudProgressCircular Indeterminate="true" Color="Color.Warning" Size="Size.Small" />
                                                    <MudText Typo="Typo.body2">Đang render lại...</MudText>
                                                </div>
                                            }
                                            @if (img.Status == "failed")
                                            {
                                                <MudAlert Severity="Severity.Error" Dense="true">Anh loi</MudAlert>
                                            }
                                            else
                                            {
                                                <MudImage Src="@img.Url" Fluid="true" Style="border-radius:8px;aspect-ratio:1/1;object-fit:cover;width:100%" />
                                            }
                                            <MudStack Row="true" Class="mt-2" Spacing="1">
                                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Edit"
                                                           OnClick="@(() => EditAndRerender(img))" Disabled="@IsActionDisabled(img)">Sua prompt</MudButton>
                                                <MudButton Size="Size.Small" Class="todox-primary-btn" StartIcon="@Icons.Material.Filled.Check"
                                                           OnClick="@(() => SelectChibi(img.MediaId))" Disabled="@(IsActionDisabled(img) || img.Status == "failed")">Chon</MudButton>
                                                @if (!string.IsNullOrWhiteSpace(img.Url))
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small" Href="@img.Url" Target="_blank" Disabled="@IsActionDisabled(img)" />
                                                }
                                            </MudStack>
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mt-2">
                                                <MudText Typo="Typo.caption">Log: @(img.LogCode ?? _result?.LogCode ?? "-")</MudText>
                                                @if (!string.IsNullOrWhiteSpace(img.LogCode ?? _result?.LogCode))
                                                {
                                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Info" OnClick="@(() => OpenLog(img.LogCode ?? _result!.LogCode!))">Xem chi tiet log</MudButton>
                                                }
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                }
                            </MudGrid>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_result?.LogCode))
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
                            Ma log: <b>@_result.LogCode</b>
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Info" OnClick="@(() => OpenLog(_result.LogCode!))">Xem chi tiet log</MudButton>
                        </MudAlert>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudStack>

@code {
    private string? _gender = "male";
    private string? _characterType = "chibi";
    private string? _cameraAngle = "half_body";
    private string? _outfit = "vest";
    private int _count = 3;
    private string _basePrompt = string.Empty;
    private string? _productImageUrl;
    private bool _promptEdited;
    private string? _lastError;
    private bool _busy;
    private Guid? _rerenderingRenderId;
    private decimal _balance;
    private decimal _imageCost = 10;
    private ChibiGenerationDto? _result;
    private readonly List<RenderLogEntry> _uiLogs = new();
    private MediaFileDto? _avatarMedia;
    private MediaFileDto? _logoMedia;
    private MediaFileDto? _productMedia;
    private MediaFileDto? _uniformMedia;
    private MediaFileDto? _sceneMedia;

    private bool IsCustomer => AuthState.CurrentUser?.IsCustomer == true;
    private IReadOnlyList<RenderLogEntry> RenderLogs => _result?.Logs.Count > 0 ? _result.Logs : _uiLogs;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState.CurrentUser is null) return;
        _imageCost = await TokenSettings.GetChibiImageCostAsync();
        var current = await Avatars.GetCurrentAsync(AuthState.CurrentUser.UserId);
        if (current.MediaId is Guid mid)
        {
            _avatarMedia = await MediaFiles.GetAsync(mid);
        }
        await ResetPrompt();
        await RefreshBalance();
    }

    private async Task RefreshBalance()
    {
        if (IsCustomer && AuthState.CurrentUser?.CustomerId is Guid cid)
        {
            _balance = await Wallet.GetBalanceAsync(cid);
        }
    }

    private async Task ResetPrompt()
    {
        var template = await Chibi.GetDefaultPromptTemplateAsync();
        _basePrompt = Chibi.ResolvePromptTemplate(template, new ChibiGenerateInput
        {
            CharacterType = _characterType,
            Gender = _gender,
            CameraAngle = _cameraAngle,
            Outfit = _outfit,
            Count = Math.Clamp(_count, 1, 4),
            AvatarMediaId = _avatarMedia?.Id,
            LogoMediaId = _logoMedia?.Id,
            ProductMediaId = _productMedia?.Id,
            ProductImageUrl = _productImageUrl,
            UniformMediaId = _uniformMedia?.Id,
            SceneMediaId = _sceneMedia?.Id
        });
        _promptEdited = false;
    }

    private async Task RefreshPromptIfClean()
    {
        if (!_promptEdited)
        {
            await ResetPrompt();
        }
    }

    private async Task OnCharacterTypeChanged(string? value)
    {
        _characterType = value;
        await RefreshPromptIfClean();
    }

    private async Task OnGenderChanged(string? value)
    {
        _gender = value;
        await RefreshPromptIfClean();
    }

    private async Task OnCameraAngleChanged(string? value)
    {
        _cameraAngle = value;
        await RefreshPromptIfClean();
    }

    private async Task OnOutfitChanged(string? value)
    {
        _outfit = value;
        await RefreshPromptIfClean();
    }

    private async Task OnCountChanged(int value)
    {
        _count = Math.Clamp(value, 1, 4);
        await RefreshPromptIfClean();
    }

    private async Task OnProductUrlChanged(string? value)
    {
        _productImageUrl = value;
        await RefreshPromptIfClean();
    }

    private Task OnPromptChanged(string value)
    {
        _basePrompt = value;
        _promptEdited = true;
        return Task.CompletedTask;
    }

    private RenderFragment RefRow(string slot, string label, MediaFileDto? media) =>@<div class="avatar-reference-row">
        <div class="d-flex align-center gap-2">
            <div class="avatar-reference-thumb @(slot == "logo" ? "logo-preview-bg" : string.Empty)">
                @if (media is not null) { <img src="@media.PublicUrl" alt="@label" /> }
                else { <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Small" /> }
            </div>
            <div>
                <MudText Typo="Typo.body2">@label</MudText>
                <MudText Typo="Typo.caption" Class="todox-page-subtitle">@(media is null ? "missing" : $"loaded · {media.FileName}")</MudText>
            </div>
        </div>
        <div class="d-flex align-center gap-1">
            @if (media is not null)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(() => ViewReference(slot, label, media))" />
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small" OnClick="@(() => ClearReference(slot))" />
            }
            <label class="avatar-upload-btn" title="Upload">
                <MudIcon Icon="@Icons.Material.Filled.Upload" Size="Size.Small" />
                <InputFile OnChange="@(e => OnRefInputChanged(slot, e))" accept="image/png,image/jpeg,image/webp" />
            </label>
        </div>
    </div>;

    private async Task OnRefInputChanged(string slot, InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (slot == "logo")
        {
            _uiLogs.Add(new RenderLogEntry
            {
                Step = "LOGO_INPUT_CHANGED",
                Message = "Logo input changed on frontend.",
                Data = new { file.Name, file.Size, file.ContentType }
            });
        }
        await OnRefSelected(slot, file);
    }

    private async Task OnRefSelected(string slot, IBrowserFile file)
    {
        if (file is null || AuthState.CurrentUser is null) return;
        try
        {
            if (file.Size > 10 * 1024 * 1024) { Snackbar.Add("Ảnh vượt quá 10MB.", Severity.Error); return; }
            using var ms = new MemoryStream();
            await file.OpenReadStream(10 * 1024 * 1024).CopyToAsync(ms);
            await Tenant.EnsureLoadedAsync();
            var media = await MediaFiles.SaveAsync(ms.ToArray(), file.Name, file.ContentType,
                $"chibi_ref_{slot}", AuthState.CurrentUser.UserId, null, Tenant.TenantId);
            if (slot == "logo")
            {
                _uiLogs.Add(new RenderLogEntry
                {
                    Step = "LOGO_MEDIA_SAVED",
                    Message = "Logo media saved and registered as logo reference.",
                    Data = new { media.Id, media.FileName, media.MimeType, media.FileSizeBytes, media.PublicUrl, category = media.FileCategory }
                });
            }
            switch (slot)
            {
                case "avatar": _avatarMedia = media; break;
                case "logo": _logoMedia = media; break;
                case "product": _productMedia = media; break;
                case "uniform": _uniformMedia = media; break;
                case "scene": _sceneMedia = media; break;
            }
            await RefreshPromptIfClean();
            _uiLogs.Add(new RenderLogEntry
            {
                Step = "REFERENCE_IMAGE_UPLOADED",
                Message = $"Reference image uploaded: {slot}.",
                Data = new { slot, media.Id, media.MimeType, media.FileSizeBytes, media.PublicUrl, file.Name, file.ContentType }
            });
            Snackbar.Add("Đã tải ảnh tham chiếu.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task ViewReference(string slot, string label, MediaFileDto media)
    {
        var parameters = new DialogParameters
        {
            ["Title"] = label,
            ["ImageUrl"] = media.PublicUrl ?? media.FileUrl,
            ["FileName"] = media.FileName,
            ["MimeType"] = media.MimeType,
            ["SizeText"] = media.FileSizeBytes is null ? null : $"{media.FileSizeBytes:#,0} bytes"
        };
        await DialogService.ShowAsync<Components.Dialogs.ReferenceImageLightboxDialog>($"Xem {slot}", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
    }

    private async Task ClearReference(string slot)
    {
        switch (slot)
        {
            case "avatar": _avatarMedia = null; break;
            case "logo": _logoMedia = null; break;
            case "product": _productMedia = null; break;
            case "uniform": _uniformMedia = null; break;
            case "scene": _sceneMedia = null; break;
        }
        await RefreshPromptIfClean();
    }

    private async Task ImportProductUrl()
    {
        if (AuthState.CurrentUser is null || string.IsNullOrWhiteSpace(_productImageUrl)) return;
        _busy = true;
        try
        {
            await Tenant.EnsureLoadedAsync();
            _uiLogs.Add(new RenderLogEntry { Step = "PRODUCT_URL_DOWNLOAD_START", Message = "Downloading product image URL.", Data = new { url = _productImageUrl } });
            var media = await MediaFiles.DownloadAndSaveImageAsync(_productImageUrl, "chibi_ref_product_url",
                AuthState.CurrentUser.UserId, AuthState.CurrentUser.CustomerId, Tenant.TenantId);
            _productMedia = media;
            _uiLogs.Add(new RenderLogEntry
            {
                Step = "PRODUCT_URL_DOWNLOAD_SUCCESS",
                Message = "Product image URL stored as media.",
                Data = new { media.Id, media.MimeType, media.FileSizeBytes, media.PublicUrl, sourceUrl = _productImageUrl }
            });
            await RefreshPromptIfClean();
            Snackbar.Add("Da tai anh san pham tu URL.", Severity.Success);
        }
        catch (Exception ex)
        {
            _uiLogs.Add(new RenderLogEntry { Step = "PRODUCT_URL_DOWNLOAD_FAILED", Message = ex.Message, Data = new { url = _productImageUrl }, Level = "error" });
            Snackbar.Add($"Loi URL san pham: {ex.Message}", Severity.Error);
        }
        finally { _busy = false; }
    }

    private async Task ConfirmAndGenerate()
    {
        if (AuthState.CurrentUser is null) return;

        if (IsCustomer)
        {
            var total = _imageCost * Math.Clamp(_count, 1, 4);
            if (_balance < total)
            {
                Snackbar.Add($"Không đủ token: cần {total:#,0}, còn {_balance:#,0}.", Severity.Error);
                return;
            }
            var ok = await DialogService.ShowMessageBoxAsync("Xác nhận trừ token",
                (MarkupString)$"Tạo <b>{_count}</b> ảnh chibi sẽ trừ <b>{total:#,0} token</b> (số dư: {_balance:#,0}). Tiếp tục?",
                yesText: "Đồng ý", cancelText: "Hủy");
            if (ok != true) return;
        }

        await Generate();
    }

    private async Task Generate()
    {
        _busy = true;
        _lastError = null;
        _uiLogs.Clear();
        _uiLogs.Add(new RenderLogEntry
        {
            Step = "UI_RENDER_SUBMITTED",
            Message = "User submitted chibi render request.",
            Data = new { count = Math.Clamp(_count, 1, 4), hasAvatar = _avatarMedia is not null, hasLogo = _logoMedia is not null, hasProduct = _productMedia is not null }
        });
        try
        {
            _result = await Chibi.GenerateAsync(new ChibiGenerateInput
            {
                UserId = AuthState.CurrentUser!.UserId,
                CustomerId = AuthState.CurrentUser.CustomerId,
                IsCustomer = IsCustomer,
                CharacterType = _characterType,
                Gender = _gender,
                CameraAngle = _cameraAngle,
                Outfit = _outfit,
                Count = Math.Clamp(_count, 1, 4),
                PromptOverride = _basePrompt,
                AvatarMediaId = _avatarMedia?.Id,
                LogoMediaId = _logoMedia?.Id,
                ProductMediaId = _productMedia?.Id,
                ProductImageUrl = _productImageUrl,
                UniformMediaId = _uniformMedia?.Id,
                SceneMediaId = _sceneMedia?.Id
            });
            await RefreshBalance();
            if (!string.IsNullOrWhiteSpace(_result.Error))
            {
                _lastError = _result.Error;
            }
            if (_result.Status == "failed" && _result.Images.Count == 0)
            {
                Snackbar.Add("Không tạo được ảnh. Xem chi tiết lỗi trên trang.", Severity.Error);
            }
            else
            {
                var msg = IsCustomer
                    ? $"Đã tạo {_result.Images.Count(x => x.Status != "failed")} ảnh. Đã trừ {_result.Charged:#,0} token, còn {_result.BalanceAfter:#,0}."
                    : $"Đã tạo {_result.Images.Count(x => x.Status != "failed")} ảnh chibi.";
                Snackbar.Add(msg, Severity.Success);
            }
        }
        catch (Exception ex)
        {
            _lastError = ex.ToString();
            Snackbar.Add($"Lỗi tạo chibi: {ex.Message}", Severity.Error);
        }
        finally { _busy = false; }
    }

    private async Task EditAndRerender(ChibiImage img)
    {
        if (AuthState.CurrentUser is null) return;

        var parameters = new DialogParameters { ["Prompt"] = img.PromptUsed ?? _basePrompt };
        var dialog = await DialogService.ShowAsync<Components.Dialogs.PromptEditDialog>("Sửa prompt & render lại", parameters);
        var res = await dialog.Result;
        if (res is null || res.Canceled || res.Data is not string newPrompt || string.IsNullOrWhiteSpace(newPrompt)) return;

        if (IsCustomer)
        {
            if (_balance < _imageCost)
            {
                Snackbar.Add($"Không đủ token: cần {_imageCost:#,0}, còn {_balance:#,0}.", Severity.Error);
                return;
            }
            var ok = await DialogService.ShowMessageBoxAsync("Xác nhận trừ token",
                (MarkupString)$"Render lại 1 ảnh sẽ trừ <b>{_imageCost:#,0} token</b>. Tiếp tục?",
                yesText: "Đồng ý", cancelText: "Hủy");
            if (ok != true) return;
        }

        _busy = true;
        _rerenderingRenderId = img.RenderId;
        _uiLogs.Add(new RenderLogEntry
        {
            Step = "UI_RERENDER_STATE_SET",
            Message = "Per-card rerender state set on frontend.",
            Data = new { img.RenderId, img.Index }
        });
        StateHasChanged();
        try
        {
            var updated = await Chibi.RerenderAsync(AuthState.CurrentUser.UserId,
                AuthState.CurrentUser.CustomerId, IsCustomer, img.RenderId, newPrompt);
            // Update the image in the current result.
            updated.Index = img.Index;
            var idx = _result!.Images.FindIndex(x => x.RenderId == img.RenderId);
            if (idx >= 0) _result.Images[idx] = updated;
            _uiLogs.Add(new RenderLogEntry { Step = "UI_RERENDER_COMPLETED", Message = "Single image rerender completed.", Data = new { img.RenderId, updated.MediaId, updated.Url } });
            await RefreshBalance();
            Snackbar.Add(IsCustomer ? $"Đã render lại. Đã trừ {_imageCost:#,0} token, còn {_balance:#,0}." : "Đã render lại ảnh.", Severity.Success);
        }
        catch (Exception ex)
        {
            _lastError = ex.ToString();
            Snackbar.Add($"Lỗi render lại: {ex.Message}", Severity.Error);
        }
        finally { _rerenderingRenderId = null; _busy = false; }
    }

    private async Task SelectChibi(Guid mediaId)
    {
        if (AuthState.CurrentUser is null || _result is null) return;
        _busy = true;
        try
        {
            await Chibi.SelectAsync(AuthState.CurrentUser.UserId, _result.Id, mediaId);
            var info = await Avatars.GetCurrentAsync(AuthState.CurrentUser.UserId);
            AuthState.UpdateAvatarUrl(info.AvatarUrl);
            Snackbar.Add("Đã đặt làm ảnh đại diện.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
        finally { _busy = false; }
    }

    private bool IsCardRendering(ChibiImage image)
        => _rerenderingRenderId == image.RenderId;

    private bool IsActionDisabled(ChibiImage image)
        => (_busy && _rerenderingRenderId is null) || IsCardRendering(image);

    private void OpenLog(string logCode)
        => Nav.NavigateTo($"/activity-logs/{Uri.EscapeDataString(logCode)}");

    private static string FormatLog(RenderLogEntry entry)
    {
        var data = entry.Data is null ? string.Empty : " " + JsonSerializer.Serialize(entry.Data);
        return $"[{entry.Timestamp:HH:mm:ss}] {entry.Level.ToUpperInvariant()} {entry.Step}: {entry.Message}{data}";
    }
}
