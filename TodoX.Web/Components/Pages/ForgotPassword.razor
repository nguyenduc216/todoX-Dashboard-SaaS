@page "/forgot-password"
@layout AuthLayout
@inject AccountService Accounts
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Quên mật khẩu</PageTitle>

<div class="todox-auth-page">
    <div class="todox-auth-grid">
        <div class="todox-auth-hero">
            <img src="img/todox-logo.jpg" alt="TodoX" />
            <MudText Typo="Typo.h3" Class="mt-6 todox-page-title">Đặt lại mật khẩu</MudText>
            <MudText Typo="Typo.body1" Class="todox-page-subtitle mt-2">Nhập email và mật khẩu mới để khôi phục truy cập.</MudText>
        </div>

        <MudPaper Class="todox-auth-card pa-6" Rounded="true">
            <MudText Typo="Typo.h5" Class="todox-page-title">Quên mật khẩu</MudText>
            <MudText Typo="Typo.body2" Class="todox-page-subtitle mb-5">Nhập email tài khoản và mật khẩu mới.</MudText>

            <MudTextField T="string" Label="Email" Variant="Variant.Outlined" @bind-Value="_email" Immediate="true" Class="mb-3" OnKeyDown="OnKey" />
            <MudTextField T="string" Label="Mật khẩu mới" Variant="Variant.Outlined" @bind-Value="_newPassword" InputType="InputType.Password" Class="mb-3" Immediate="true" OnKeyDown="OnKey" />
            <MudTextField T="string" Label="Xác nhận mật khẩu mới" Variant="Variant.Outlined" @bind-Value="_confirmPassword" InputType="InputType.Password" Class="mb-4" Immediate="true" OnKeyDown="OnKey" />

            <MudButton FullWidth="true" Class="todox-primary-btn" OnClick="DoReset" Disabled="_busy">Đặt lại mật khẩu</MudButton>

            <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-5 todox-page-subtitle">
                <MudLink Href="/login" Class="todox-gold">Quay lại đăng nhập</MudLink>
            </MudText>
        </MudPaper>
    </div>
</div>

@code {
    private string _email = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _busy;

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or "NumpadEnter") await DoReset();
    }

    private async Task DoReset()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            var (ok, message) = await Accounts.ResetPasswordByEmailAsync(_email, _newPassword, _confirmPassword);
            Snackbar.Add(message, ok ? Severity.Success : Severity.Error);
            if (ok)
            {
                Navigation.NavigateTo("/login");
            }
        }
        finally { _busy = false; }
    }
}
