@page "/login"
@layout AuthLayout
@inject AccountService Accounts
@inject AuthStateService AuthState
@inject AuditRepository Audit
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Đăng nhập TodoX</PageTitle>

<div class="todox-auth-page">
    <div class="todox-auth-grid">
        <MudPaper Class="todox-auth-card pa-6" rounded="true">
            <MudText Typo="Typo.h5" Class="todox-page-title">Đăng nhập</MudText>
            <MudText Typo="Typo.body2" Class="todox-page-subtitle mb-5">Truy cập bảng điều khiển TodoX.</MudText>

            <MudTextField T="string" Label="Email hoặc username" Variant="Variant.Outlined" @bind-Value="_login.UsernameOrEmail" Immediate="true" Class="mb-3" OnKeyDown="OnKey" />
            <MudTextField T="string" Label="Mật khẩu" Variant="Variant.Outlined" @bind-Value="_login.Password" InputType="InputType.Password" Class="mb-2" Immediate="true" OnKeyDown="OnKey" />

            <div class="d-flex justify-space-between align-center mb-3">
                <MudCheckBox T="bool" @bind-Value="_rememberMe" Color="Color.Warning" Dense="true" Label="Ghi nhớ đăng nhập" />
                <MudLink Href="/forgot-password" Class="todox-gold" Typo="Typo.body2">Quên mật khẩu?</MudLink>
            </div>

            <MudButton FullWidth="true" Class="todox-primary-btn" OnClick="DoLogin" Disabled="_busy">Đăng nhập</MudButton>

            <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-5 todox-page-subtitle">
                Chưa có avatar? <MudLink Href="/avatar-builder" Class="todox-gold">Tạo avatar</MudLink>
            </MudText>
        </MudPaper>
    </div>
</div>

@code {
    private readonly LoginRequest _login = new();
    private bool _rememberMe = true;
    private bool _busy;

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or "NumpadEnter") await DoLogin();
    }

    private async Task DoLogin()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            var user = await Accounts.LoginAsync(_login);
            if (user is null)
            {
                Snackbar.Add("Sai thông tin đăng nhập hoặc tài khoản chưa active.", Severity.Error);
                return;
            }

            await AuthState.SignInAsync(user, _rememberMe);
            await Audit.LogAsync(user, "auth", "login", entityDisplay: user.Email, message: "Đăng nhập thành công");
            Snackbar.Add("Đăng nhập thành công.", Severity.Success);
            Navigation.NavigateTo("/");
        }
        finally { _busy = false; }
    }
}
