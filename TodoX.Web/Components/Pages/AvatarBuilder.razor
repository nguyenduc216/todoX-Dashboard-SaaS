        <MudExpansionPanels Class="avatar-advanced-panel" Elevation="0">
            <MudExpansionPanel Text="TÃ¹y chá»n nÃ¢ng cao">
                <p class="avatar-advanced-hint">ThÃªm logo, sáº£n pháº©m, Ä‘á»“ng phá»¥c hoáº·c bá»‘i cáº£nh náº¿u báº¡n muá»‘n avatar bÃ¡m theo thÆ°Æ¡ng hiá»‡u hÆ¡n.</p>
                <div class="avatar-advanced-grid">
                    @AdvancedUpload("logo", "Logo", _logoUrl)
                    @AdvancedUpload("product", "Sáº£n pháº©m", _productUrl)
                    @AdvancedUpload("uniform", "Äá»“ng phá»¥c", _uniformUrl)
                    @AdvancedUpload("scene", "Bá»‘i cáº£nh", _sceneUrl)
                </div>
            </MudExpansionPanel>
        </MudExpansionPanels>
    </section>

    <section class="avatar-gallery-section">
        <div class="avatar-section-head">
            <h2>Chá»n phong cÃ¡ch avatar</h2>
            <p>Má»—i máº«u dÃ¹ng áº£nh default tá»« thÆ° viá»‡n TodoX. Sau khi render, káº¿t quáº£ cá»§a báº¡n sáº½ hiá»‡n ngay trong card.</p>
        </div>

        @if (_providerOptions.Count > 0)
        {
            <div class="avatar-provider-picker">
                <MudSelect T="long?" @bind-Value="_providerCapabilityId" Label="AI Provider" Variant="Variant.Outlined" Dense="true">
