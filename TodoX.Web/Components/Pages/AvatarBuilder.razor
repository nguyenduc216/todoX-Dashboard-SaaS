@page "/avatar-builder"
@layout PublicAvatarBuilderLayout
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@using TodoX.Web.Components.Avatar
@using TodoX.Web.Services.AvatarTemplates
@inject IAvatarTemplateService AvatarTemplates
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Tạo avatar AI của bạn</PageTitle>

<main class="avatar-public-page">
    <section class="avatar-hero">
        <div class="avatar-hero-brand">Todo<span>X</span> AI</div>
        <div class="avatar-hero-copy">
            <h1>Tạo avatar AI của bạn</h1>
            <p>Tải ảnh chân dung, chọn mẫu avatar và tạo ảnh chỉ trong vài giây.</p>
        </div>
    </section>

    <section class="avatar-upload-panel">
        <div class="avatar-upload-main">
            <div class="avatar-portrait-preview">
                @if (!string.IsNullOrWhiteSpace(_portraitUrl))
                {
                    <img src="@_portraitUrl" alt="Ảnh chân dung đã tải" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.FaceRetouchingNatural" Size="Size.Large" />
                }
            </div>
            <div class="avatar-upload-copy">
                <h2>Tải ảnh chân dung</h2>
                <p>Ảnh rõ mặt sẽ cho kết quả tốt hơn. Đây là ảnh bắt buộc trước khi render.</p>
                <label class="avatar-public-upload-button">
                    <MudIcon Icon="@Icons.Material.Filled.Upload" Size="Size.Small" />
                    <span>Chọn ảnh chân dung</span>
                    <InputFile Class="avatar-public-hidden-input" OnChange="@(e => Upload("avatar", e))" accept="image/png,image/jpeg,image/webp" />
                </label>
            </div>
        </div>

        <MudExpansionPanels Class="avatar-advanced-panel" Elevation="0">
            <MudExpansionPanel Text="Tùy chọn nâng cao">
                <p class="avatar-advanced-hint">Thêm logo, sản phẩm, đồng phục hoặc bối cảnh nếu bạn muốn avatar bám theo thương hiệu hơn.</p>
                <div class="avatar-advanced-grid">
                    @AdvancedUpload("logo", "Logo", _logoUrl)
                    @AdvancedUpload("product", "Sản phẩm", _productUrl)
                    @AdvancedUpload("uniform", "Đồng phục", _uniformUrl)
                    @AdvancedUpload("scene", "Bối cảnh", _sceneUrl)
                </div>
            </MudExpansionPanel>
        </MudExpansionPanels>
    </section>

    <section class="avatar-gallery-section">
        <div class="avatar-section-head">
            <h2>Chọn phong cách avatar</h2>
            <p>Mỗi mẫu dùng ảnh default từ thư viện TodoX. Sau khi render, kết quả của bạn sẽ hiện ngay trong card.</p>
        </div>

        @if (_loading)
        {
            <div class="avatar-loading-row">
                <span class="avatar-flash-dot"></span>
                <span>Đang tải avatar mẫu...</span>
            </div>
        }
        else if (_cards.Count == 0)
        {
            <MudAlert Severity="Severity.Info">Chưa có avatar mẫu công khai. Vui lòng quay lại sau.</MudAlert>
        }
        else
        {
            <div class="avatar-card-grid">
                @foreach (var card in _cards)
                {
                    <article class='@($"avatar-public-card {(card.Rendering ? "is-rendering" : string.Empty)}")'>
                        <div class="avatar-card-image">
                            @if (!string.IsNullOrWhiteSpace(card.DisplayImageUrl))
                            {
                                <img src="@card.DisplayImageUrl" alt="@card.Template.Name" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.FaceRetouchingNatural" Size="Size.Large" />
                            }

                            @if (card.Rendering)
                            {
                                <div class="avatar-card-rendering">
                                    <span>Đang render...</span>
                                </div>
                            }
                        </div>

                        <div class="avatar-card-body">
                            <div class="avatar-card-title-row">
                                <h3>@card.Template.Name</h3>
                                <span>@(card.Template.CharacterTypeDisplayVi ?? "Avatar")</span>
                            </div>
                            <p>@card.Template.Description</p>
                            <div class="avatar-card-tags">
                                <span>@(card.Template.GenderDisplayVi ?? "Trung tính")</span>
                                <span>@(card.Template.CameraAngleDisplayVi ?? "Nửa người")</span>
                            </div>

                            @if (card.Result is not null)
                            {
                                <div class="avatar-card-result-meta">
                                    <span>Trạng thái: <b>@card.Result.Status</b></span>
                                    <span>Log: <b>@(card.Result.LogCode ?? "-")</b></span>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(card.Error))
                            {
                                <MudAlert Severity="Severity.Error" Dense="true">@card.Error</MudAlert>
                            }

                            <div class="avatar-card-actions">
                                <MudButton Class="avatar-card-primary" StartIcon="@Icons.Material.Filled.AutoAwesome"
                                           Disabled="@card.Rendering" OnClick="@(() => RenderCard(card))">
                                    @(card.Result is null ? "Render" : "Render lại")
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Edit"
                                           Disabled="@card.Rendering" OnClick="@(() => EditPrompt(card))">
                                    Sửa prompt
                                </MudButton>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(card.Result?.ImageUrl))
                            {
                                <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Warning"
                                           StartIcon="@Icons.Material.Filled.Download"
                                           Href="@card.Result.ImageUrl" Target="_blank"
                                           OnClick="@(() => TrackDownload(card))">
                                    Tải xuống
                                </MudButton>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</main>

@code {
    private bool _loading = true;
    private Guid? _portraitMediaId;
    private string? _portraitUrl;
    private Guid? _logoMediaId;
    private string? _logoUrl;
    private Guid? _productMediaId;
    private string? _productUrl;
    private Guid? _uniformMediaId;
    private string? _uniformUrl;
    private Guid? _sceneMediaId;
    private string? _sceneUrl;
    private readonly List<TemplateCardState> _cards = new();

    protected override async Task OnInitializedAsync()
    {
        var templates = await AvatarTemplates.ListAsync(publicOnly: true);
        _cards.Clear();
        _cards.AddRange(templates.Select(x => new TemplateCardState(x)));
        _loading = false;
    }

    private async Task Upload(string slot, InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        try
        {
            if (file.Size > 10 * 1024 * 1024)
            {
                Snackbar.Add("Ảnh vượt quá 10MB.", Severity.Error);
                return;
            }

            using var ms = new MemoryStream();
            await file.OpenReadStream(10 * 1024 * 1024).CopyToAsync(ms);
            var media = await AvatarTemplates.SavePublicUploadAsync(ms.ToArray(), file.Name, file.ContentType);
            SetMedia(slot, media.Id, media.PublicUrl ?? media.FileUrl);
            Snackbar.Add(slot == "avatar" ? "Đã tải ảnh chân dung." : "Đã tải ảnh tùy chọn.", Severity.Success);
            if (slot == "avatar")
            {
                await RenderAllCards();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải ảnh: {ex.Message}", Severity.Error);
        }
    }

    private RenderFragment AdvancedUpload(string slot, string label, string? url) => @<div class="avatar-advanced-upload">
        <div class="avatar-advanced-thumb">
            @if (!string.IsNullOrWhiteSpace(url))
            {
                <img src="@url" alt="@label" />
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.Image" />
            }
        </div>
        <div>
            <strong>@label</strong>
            <small>@(string.IsNullOrWhiteSpace(url) ? "Tùy chọn" : "Đã tải")</small>
        </div>
        <label class="avatar-advanced-button">
            <MudIcon Icon="@Icons.Material.Filled.Upload" Size="Size.Small" />
            <InputFile Class="avatar-public-hidden-input" OnChange="@(e => Upload(slot, e))" accept="image/png,image/jpeg,image/webp" />
        </label>
    </div>;

    private async Task RenderCard(TemplateCardState card)
    {
        if (_portraitMediaId is null)
        {
            Snackbar.Add("Vui lòng tải ảnh chân dung trước khi render.", Severity.Warning);
            return;
        }

        card.Rendering = true;
        card.Error = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var result = await RenderViaEndpointAsync(new PublicAvatarBuilderRenderRequest
            {
                TemplateId = card.Template.Id,
                PromptOverride = card.Prompt,
                CharacterTypeCode = card.CharacterTypeCode,
                GenderCode = card.GenderCode,
                CameraAngleCode = card.CameraAngleCode,
                OutfitCode = card.OutfitCode,
                AvatarMediaId = _portraitMediaId,
                LogoMediaId = _logoMediaId,
                ProductMediaId = _productMediaId,
                UniformMediaId = _uniformMediaId,
                SceneMediaId = _sceneMediaId
            });

            card.Result = result;
            if (!result.Ok)
            {
                card.Error = RenderFailureMessage(result);
            }
        }
        catch (Exception ex)
        {
            card.Error = $"Render chưa thành công: {ex.Message}";
            card.Result = new PublicAvatarBuilderRenderResult
            {
                Ok = false,
                Status = "failed",
                Error = ex.Message
            };
        }
        finally
        {
            card.Rendering = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RenderAllCards()
    {
        if (_portraitMediaId is null || _cards.Count == 0)
        {
            return;
        }

        foreach (var card in _cards)
        {
            card.Rendering = true;
            card.Error = null;
        }
        await InvokeAsync(StateHasChanged);

        using var gate = new SemaphoreSlim(3);
        await Task.WhenAll(_cards.Select(async card =>
        {
            await gate.WaitAsync();
            try
            {
                await RenderCardAfterBulkStart(card);
            }
            finally
            {
                gate.Release();
            }
        }));
    }

    private async Task RenderCardAfterBulkStart(TemplateCardState card)
    {
        try
        {
            var result = await RenderViaEndpointAsync(new PublicAvatarBuilderRenderRequest
            {
                TemplateId = card.Template.Id,
                PromptOverride = card.Prompt,
                CharacterTypeCode = card.CharacterTypeCode,
                GenderCode = card.GenderCode,
                CameraAngleCode = card.CameraAngleCode,
                OutfitCode = card.OutfitCode,
                AvatarMediaId = _portraitMediaId,
                LogoMediaId = _logoMediaId,
                ProductMediaId = _productMediaId,
                UniformMediaId = _uniformMediaId,
                SceneMediaId = _sceneMediaId
            });

            card.Result = result;
            if (!result.Ok)
            {
                card.Error = RenderFailureMessage(result);
            }
        }
        catch (Exception ex)
        {
            card.Error = $"Render chưa thành công: {ex.Message}";
            card.Result = new PublicAvatarBuilderRenderResult
            {
                Ok = false,
                Status = "failed",
                Error = ex.Message
            };
        }
        finally
        {
            card.Rendering = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<PublicAvatarBuilderRenderResult> RenderViaEndpointAsync(PublicAvatarBuilderRenderRequest request)
    {
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(Nav.BaseUri);
        using var response = await client.PostAsJsonAsync("api/public/avatar-builder/render", request);
        var body = await response.Content.ReadAsStringAsync();
        var result = string.IsNullOrWhiteSpace(body)
            ? null
            : JsonSerializer.Deserialize<PublicAvatarBuilderRenderResult>(body, new JsonSerializerOptions(JsonSerializerDefaults.Web));
        if (result is not null)
        {
            if (!response.IsSuccessStatusCode && string.IsNullOrWhiteSpace(result.Error))
            {
                result.Error = $"Render endpoint HTTP {(int)response.StatusCode}.";
            }
            return result;
        }

        return new PublicAvatarBuilderRenderResult
        {
            Ok = false,
            Status = "failed",
            Error = string.IsNullOrWhiteSpace(body) ? $"Render endpoint HTTP {(int)response.StatusCode}." : body
        };
    }

    private static string RenderFailureMessage(PublicAvatarBuilderRenderResult result)
    {
        if (!string.IsNullOrWhiteSpace(result.Error))
        {
            return $"Render chưa thành công: {result.Error}";
        }

        if (!string.IsNullOrWhiteSpace(result.LogCode))
        {
            return $"Render chưa thành công. Mã log: {result.LogCode}";
        }

        return "Render chưa thành công, vui lòng thử lại.";
    }

    private async Task EditPrompt(TemplateCardState card)
    {
        var parameters = new DialogParameters<PublicAvatarPromptEditDialog>
        {
            { x => x.TemplateName, card.Template.Name },
            { x => x.Prompt, card.Prompt },
            { x => x.CharacterTypeCode, card.CharacterTypeCode },
            { x => x.GenderCode, card.GenderCode },
            { x => x.CameraAngleCode, card.CameraAngleCode },
            { x => x.OutfitCode, card.OutfitCode }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<PublicAvatarPromptEditDialog>("Sửa prompt", parameters, options);
        var response = await dialog.Result;
        if (response is null || response.Canceled || response.Data is not PublicAvatarPromptEditResult edit)
        {
            return;
        }

        card.Prompt = edit.Prompt;
        card.CharacterTypeCode = edit.CharacterTypeCode;
        card.GenderCode = edit.GenderCode;
        card.CameraAngleCode = edit.CameraAngleCode;
        card.OutfitCode = edit.OutfitCode;

        if (edit.RenderNow)
        {
            await RenderCard(card);
        }
    }

    private void TrackDownload(TemplateCardState card)
    {
        card.DownloadClicked = true;
    }

    private void SetMedia(string slot, Guid mediaId, string? url)
    {
        switch (slot)
        {
            case "avatar":
                _portraitMediaId = mediaId;
                _portraitUrl = url;
                break;
            case "logo":
                _logoMediaId = mediaId;
                _logoUrl = url;
                break;
            case "product":
                _productMediaId = mediaId;
                _productUrl = url;
                break;
            case "uniform":
                _uniformMediaId = mediaId;
                _uniformUrl = url;
                break;
            case "scene":
                _sceneMediaId = mediaId;
                _sceneUrl = url;
                break;
        }
    }

    private sealed class TemplateCardState
    {
        public TemplateCardState(AvatarTemplateDto template)
        {
            Template = template;
            Prompt = template.PromptTemplate;
            CharacterTypeCode = template.CharacterTypeCode ?? "chibi";
            GenderCode = template.GenderCode ?? "neutral";
            CameraAngleCode = template.CameraAngleCode ?? "half_body";
            OutfitCode = template.OutfitCode ?? "suit";
        }

        public AvatarTemplateDto Template { get; }
        public string Prompt { get; set; }
        public string CharacterTypeCode { get; set; }
        public string GenderCode { get; set; }
        public string CameraAngleCode { get; set; }
        public string OutfitCode { get; set; }
        public bool Rendering { get; set; }
        public bool DownloadClicked { get; set; }
        public string? Error { get; set; }
        public PublicAvatarBuilderRenderResult? Result { get; set; }
        public string? DisplayImageUrl => Result?.ImageUrl ?? Template.PreviewMediaUrl;
    }
}
