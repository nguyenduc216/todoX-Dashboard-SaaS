        </div>
    </section>

    <section class="avatar-upload-panel">
        <div class="avatar-upload-main">
            <div class="avatar-portrait-preview">
                @if (!string.IsNullOrWhiteSpace(_portraitUrl))
                {
                    <img src="@_portraitUrl" alt="áº¢nh chÃ¢n dung Ä‘Ã£ táº£i" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.FaceRetouchingNatural" Size="Size.Large" />
                }
            </div>
            <div class="avatar-upload-copy">
                <h2>Táº£i áº£nh chÃ¢n dung</h2>
                <p>áº¢nh rÃµ máº·t sáº½ cho káº¿t quáº£ tá»‘t hÆ¡n. ÄÃ¢y lÃ  áº£nh báº¯t buá»™c trÆ°á»›c khi render.</p>
                <label class="avatar-public-upload-button">
                    <MudIcon Icon="@Icons.Material.Filled.Upload" Size="Size.Small" />
                    <span>Chá»n áº£nh chÃ¢n dung</span>
