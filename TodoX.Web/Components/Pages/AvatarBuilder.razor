</main>

@code {
    private bool _loading = true;
    private Guid? _portraitMediaId;
    private string? _portraitUrl;
    private Guid? _logoMediaId;
    private string? _logoUrl;
    private Guid? _productMediaId;
    private string? _productUrl;
    private Guid? _uniformMediaId;
    private string? _uniformUrl;
    private Guid? _sceneMediaId;
    private string? _sceneUrl;
    private long? _providerCapabilityId;
    private List<ProviderOptionDto> _providerOptions = new();
    private readonly List<TemplateCardState> _cards = new();

    protected override async Task OnInitializedAsync()
    {
        var templates = await AvatarTemplates.ListAsync(publicOnly: true);
        _cards.Clear();
        _cards.AddRange(templates.Select(x => new TemplateCardState(x)));
        await LoadProviderOptions();
        _loading = false;
    }

    private async Task LoadProviderOptions()
    {
        try
        {
            _providerOptions = (await AiProviders.GetSelectableProvidersAsync("avatar_generation")).ToList();
            if (_providerOptions.Count > 0)
            {
                _providerCapabilityId = (_providerOptions.FirstOrDefault(o => o.IsDefault) ?? _providerOptions[0]).ProviderCapabilityId;
            }
        }
        catch
        {
            // Public/anonymous visitors may not be authorized; server-side default provider is used on render.
            _providerOptions = new();
        }
    }
    private async Task Upload(string slot, InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        try
        {
            if (file.Size > 10 * 1024 * 1024)
            {
                Snackbar.Add("áº¢nh vÆ°á»£t quÃ¡ 10MB.", Severity.Error);
                return;
            }

            using var ms = new MemoryStream();
            await file.OpenReadStream(10 * 1024 * 1024).CopyToAsync(ms);
            var media = await AvatarTemplates.SavePublicUploadAsync(ms.ToArray(), file.Name, file.ContentType);
            SetMedia(slot, media.Id, NormalizePublicUrl(media.PublicUrl ?? media.FileUrl));
            Snackbar.Add(slot == "avatar" ? "ÄÃ£ táº£i áº£nh chÃ¢n dung." : "ÄÃ£ táº£i áº£nh tÃ¹y chá»n.", Severity.Success);
            if (slot == "avatar")
            {
                await RenderAllCards();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lá»—i táº£i áº£nh: {ex.Message}", Severity.Error);
        }
    }

    private RenderFragment AdvancedUpload(string slot, string label, string? url) => @<div class="avatar-advanced-upload">
        <div class="avatar-advanced-thumb">
            @if (!string.IsNullOrWhiteSpace(url))
            {
                <img src="@url" alt="@label" />
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.Image" />
            }
        </div>
        <div>
            <strong>@label</strong>
            <small>@(string.IsNullOrWhiteSpace(url) ? "TÃ¹y chá»n" : "ÄÃ£ táº£i")</small>
        </div>
        <label class="avatar-advanced-button">
            <MudIcon Icon="@Icons.Material.Filled.Upload" Size="Size.Small" />
            <InputFile Class="avatar-public-hidden-input" OnChange="@(e => Upload(slot, e))" accept="image/png,image/jpeg,image/webp" />
        </label>
    </div>;

    private async Task RenderCard(TemplateCardState card)
    {
        if (_portraitMediaId is null)
        {
            Snackbar.Add("Vui lÃ²ng táº£i áº£nh chÃ¢n dung trÆ°á»›c khi render.", Severity.Warning);
            return;
        }

        card.Rendering = true;
        card.Error = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var result = await RenderAvatarAsync(new PublicAvatarBuilderRenderRequest
            {
                TemplateId = card.Template.Id,
                PromptOverride = card.Prompt,
                CharacterTypeCode = card.CharacterTypeCode,
                GenderCode = card.GenderCode,
                CameraAngleCode = card.CameraAngleCode,
                OutfitCode = card.OutfitCode,
                AvatarMediaId = _portraitMediaId,
                LogoMediaId = _logoMediaId,
                ProductMediaId = _productMediaId,
                UniformMediaId = _uniformMediaId,
                SceneMediaId = _sceneMediaId,
                ProviderCapabilityId = _providerCapabilityId
            });

            card.Result = result;
            if (!result.Ok)
            {
                card.Error = RenderFailureMessage(result);
            }
        }
        catch (Exception ex)
        {
            card.Error = $"Render chÆ°a thÃ nh cÃ´ng: {ex.Message}";
            card.Result = new PublicAvatarBuilderRenderResult
            {
                Ok = false,
                Status = "failed",
                Error = ex.Message
            };
        }
        finally
        {
            card.Rendering = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RenderAllCards()
    {
        if (_portraitMediaId is null || _cards.Count == 0)
        {
            return;
        }

        foreach (var card in _cards)
        {
            card.Rendering = true;
            card.Error = null;
        }
        await InvokeAsync(StateHasChanged);

        using var gate = new SemaphoreSlim(3);
        await Task.WhenAll(_cards.Select(async card =>
        {
            await gate.WaitAsync();
            try
            {
                await RenderCardAfterBulkStart(card);
            }
            finally
            {
                gate.Release();
            }
        }));
    }

    private async Task RenderCardAfterBulkStart(TemplateCardState card)
    {
        try
        {
            var result = await RenderAvatarAsync(new PublicAvatarBuilderRenderRequest
            {
                TemplateId = card.Template.Id,
                PromptOverride = card.Prompt,
                CharacterTypeCode = card.CharacterTypeCode,
                GenderCode = card.GenderCode,
                CameraAngleCode = card.CameraAngleCode,
                OutfitCode = card.OutfitCode,
                AvatarMediaId = _portraitMediaId,
                LogoMediaId = _logoMediaId,
                ProductMediaId = _productMediaId,
                UniformMediaId = _uniformMediaId,
                SceneMediaId = _sceneMediaId,
                ProviderCapabilityId = _providerCapabilityId
            });

            card.Result = result;
            if (!result.Ok)
            {
                card.Error = RenderFailureMessage(result);
            }
        }
        catch (Exception ex)
        {
            card.Error = $"Render chÆ°a thÃ nh cÃ´ng: {ex.Message}";
            card.Result = new PublicAvatarBuilderRenderResult
            {
                Ok = false,
                Status = "failed",
                Error = ex.Message
            };
        }
        finally
        {
            card.Rendering = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private Task<PublicAvatarBuilderRenderResult> RenderAvatarAsync(PublicAvatarBuilderRenderRequest request)
        => AvatarTemplates.RenderPublicAsync(request);

    private static string RenderFailureMessage(PublicAvatarBuilderRenderResult result)
    {
        if (!string.IsNullOrWhiteSpace(result.Error))
        {
            return $"Render chÆ°a thÃ nh cÃ´ng: {result.Error}";
        }

        if (!string.IsNullOrWhiteSpace(result.LogCode))
        {
            return $"Render chÆ°a thÃ nh cÃ´ng. MÃ£ log: {result.LogCode}";
        }

        return "Render chÆ°a thÃ nh cÃ´ng, vui lÃ²ng thá»­ láº¡i.";
    }

    private async Task EditPrompt(TemplateCardState card)
    {
        var parameters = new DialogParameters<PublicAvatarPromptEditDialog>
        {
            { x => x.TemplateName, card.Template.Name },
            { x => x.Prompt, card.Prompt },
            { x => x.CharacterTypeCode, card.CharacterTypeCode },
            { x => x.GenderCode, card.GenderCode },
            { x => x.CameraAngleCode, card.CameraAngleCode },
            { x => x.OutfitCode, card.OutfitCode }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<PublicAvatarPromptEditDialog>("Sá»­a prompt", parameters, options);
        var response = await dialog.Result;
        if (response is null || response.Canceled || response.Data is not PublicAvatarPromptEditResult edit)
        {
            return;
        }

        card.Prompt = edit.Prompt;
        card.CharacterTypeCode = edit.CharacterTypeCode;
        card.GenderCode = edit.GenderCode;
        card.CameraAngleCode = edit.CameraAngleCode;
        card.OutfitCode = edit.OutfitCode;

        if (edit.RenderNow)
        {
            await RenderCard(card);
        }
    }

    private async Task OpenPreview(TemplateCardState card)
    {
        var imageUrl = card.Result?.ImageUrl ?? card.Template.PreviewMediaUrl;
        if (string.IsNullOrWhiteSpace(imageUrl))
        {
            return;
        }

        var parameters = new DialogParameters<Components.Dialogs.ReferenceImageLightboxDialog>
        {
            { x => x.Title, card.Template.Name },
            { x => x.ImageUrl, imageUrl },
            { x => x.FileName, card.Template.Name },
            { x => x.MimeType, "image/png" }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraLarge,
            FullWidth = true,
            CloseOnEscapeKey = true,
            FullScreen = true,
            BackdropClick = true
        };

        await DialogService.ShowAsync<Components.Dialogs.ReferenceImageLightboxDialog>(card.Template.Name, parameters, options);
    }
    private void TrackDownload(TemplateCardState card)
    {
        card.DownloadClicked = true;
    }

    private void SetMedia(string slot, Guid mediaId, string? url)
    {
        url = NormalizePublicUrl(url);
        switch (slot)
        {
            case "avatar":
                _portraitMediaId = mediaId;
                _portraitUrl = url;
                break;
            case "logo":
                _logoMediaId = mediaId;
                _logoUrl = url;
                break;
            case "product":
                _productMediaId = mediaId;
                _productUrl = url;
                break;
            case "uniform":
                _uniformMediaId = mediaId;
                _uniformUrl = url;
                break;
            case "scene":
                _sceneMediaId = mediaId;
                _sceneUrl = url;
                break;
        }
    }

    private static string? NormalizePublicUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return null;
        if (Uri.TryCreate(url, UriKind.Absolute, out var absolute) &&
            (absolute.Scheme == Uri.UriSchemeHttp || absolute.Scheme == Uri.UriSchemeHttps))
        {
            return url;
        }

        return url.StartsWith("/", StringComparison.Ordinal) ? url : null;
    }

    private sealed class TemplateCardState
    {
        public TemplateCardState(AvatarTemplateDto template)
        {
            Template = template;
            Prompt = template.PromptTemplate;
            CharacterTypeCode = template.CharacterTypeCode ?? "not_specified";
            GenderCode = template.GenderCode ?? "not_specified";
            CameraAngleCode = template.CameraAngleCode ?? "not_specified";
            OutfitCode = template.OutfitCode ?? "not_specified";
        }

        public AvatarTemplateDto Template { get; }
        public string Prompt { get; set; }
        public string CharacterTypeCode { get; set; } = "not_specified";
        public string GenderCode { get; set; } = "not_specified";
        public string CameraAngleCode { get; set; } = "not_specified";
        public string OutfitCode { get; set; } = "not_specified";
        public bool Rendering { get; set; }
        public bool DownloadClicked { get; set; }
        public string? Error { get; set; }
        public PublicAvatarBuilderRenderResult? Result { get; set; }
        public string? DisplayImageUrl => Result?.ImageUrl ?? Template.PreviewMediaUrl;
    }
}
