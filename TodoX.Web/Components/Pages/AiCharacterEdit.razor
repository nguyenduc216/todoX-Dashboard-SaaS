@page "/ai-assets/characters/new"
@page "/ai-assets/characters/{Id:long}"
@using TodoX.Web.Models
@using TodoX.Web.Services.AiProviders
@using System.Text.Json
@using Npgsql
@inject IAiCharacterService Characters
@inject IAiProviderService AiProviders
@inject AuthStateService AuthState
@inject NavigationManager Nav
@inject IJSRuntime Js
@inject ISnackbar Snackbar
@inject IConfiguration Config

<PageTitle>@(_isNew ? "T?o nhân v?t AI" : "Nhân v?t AI")</PageTitle>

<section class="todox-page-head">
    <div>
        <MudText Typo="Typo.h3" Class="todox-page-title">@(_isNew ? "T?o nhân v?t AI" : _model.CharacterName)</MudText>
        <MudText Typo="Typo.body1" Class="todox-page-subtitle">Thi?t k? nhân v?t AI nh?t quán d? důng l?i trong video TodoX.</MudText>
    </div>
    <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="@(() => Nav.NavigateTo("/ai-assets/characters"))">
        Quay l?i
    </MudButton>
</section>

@if (_loading)
{
    <div class="todox-flash-row"><span class="avatar-flash-dot"></span><span>Đang t?i nhân v?t...</span></div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <MudAlert Severity="Severity.Warning">@_error</MudAlert>
}
else
{
    <div class="ai-character-detail-grid">
        <MudPaper Class="todox-panel pa-5" rounded="true">
            <MudText Typo="Typo.h5" Class="mb-4">Thông tin nhân v?t</MudText>
            <MudTextField T="string" Label="Tęn nhân v?t" Variant="Variant.Outlined" @bind-Value="_model.CharacterName" Class="mb-3" />
            <MudTextField T="string" Label="Mô t? nhân v?t" Variant="Variant.Outlined" Lines="5" @bind-Value="_model.Description" Class="mb-3" />
            <MudTextField T="string" Label="Prompt render hěnh ?nh" HelperText="Có th? d? tr?ng d? TodoX t? t?o prompt t? mô t?. Prompt nŕy s? du?c g?i tr?c ti?p d?n provider render."
                          Variant="Variant.Outlined" Lines="5" @bind-Value="_renderPrompt" Class="mb-3" />
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="Phong cách" Variant="Variant.Outlined" @bind-Value="_model.StylePreset">
                        @foreach (var item in CharacterPresetOptions.StylePresets)
                        {
                            <MudSelectItem Value="@item.Value">@item.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="Gi?i tính" Variant="Variant.Outlined" @bind-Value="_model.Gender">
                        @foreach (var item in CharacterPresetOptions.GenderOptions)
                        {
                            <MudSelectItem Value="@item.Value">@item.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="T? l? khung hěnh" Variant="Variant.Outlined" @bind-Value="_model.AspectRatio">
                        @foreach (var item in CharacterPresetOptions.AspectRatios)
                        {
                            <MudSelectItem Value="@item.Value">@item.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="Tr?ng thái" Variant="Variant.Outlined" Disabled="_isNew" @bind-Value="_model.Status">
                        <MudSelectItem T="string" Value="@("active")">Đang důng</MudSelectItem>
                        <MudSelectItem T="string" Value="@("inactive")">T?m t?t</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="int?" Label="Mă seed" Variant="Variant.Outlined" @bind-Value="_seed" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    @if (_providerOptions.Count == 0)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">Chua c?u hěnh provider cho <b>character_generation</b>.</MudAlert>
                    }
                    else
                    {
                        <MudSelect T="long?" @bind-Value="_providerCapabilityId" Label="AI Provider" Variant="Variant.Outlined">
                            @foreach (var opt in _providerOptions)
                            {
                                <MudSelectItem T="long?" Value="@opt.ProviderCapabilityId">@opt.OptionLabel</MudSelectItem>
                            }
                        </MudSelect>
                    }
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudCheckBox T="bool" Label="Render ?nh sau khi luu" Color="Color.Warning" @bind-Value="_autoGenerate" Disabled="@(!_isNew)" />
                </MudItem>
            </MudGrid>
            <MudTextField T="string" Label="URL ?nh tham chi?u" HelperText="M?i dňng lŕ m?t URL http/https."
                          Variant="Variant.Outlined" Lines="3" @bind-Value="_referenceUrlsText" Class="mt-3" />
            <div class="ai-character-form-actions">
                <MudButton Class="todox-primary-btn" StartIcon="@Icons.Material.Filled.Save" Disabled="_busy" OnClick="Save">
                    Luu
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.AutoAwesome"
                           Disabled="@(_busy || _isNew)" OnClick="Generate">
                    Render ?nh nhân v?t
                </MudButton>
            </div>
        </MudPaper>

        <MudPaper Class="todox-panel ai-character-master pa-5" rounded="true">
            <div class="ai-character-section-title mb-3">
                <MudText Typo="Typo.h5">?nh master</MudText>
                <span class="ai-character-provider-chip">@ProviderDisplay</span>
            </div>
            <div class='@($"ai-character-master-image {(_busy ? "is-rendering" : string.Empty)}")'>
                @if (!string.IsNullOrWhiteSpace(_detail?.MasterImageUrl))
                {
                    <img src="@_detail.MasterImageUrl" alt="@_model.CharacterName" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" />
                }
                @if (_busy)
                {
                    <div class="ai-character-flash-overlay"><span>Đang x? lý...</span></div>
                }
            </div>
            <div class="ai-character-upload-box">
                <MudText Typo="Typo.subtitle2">Không render? Upload ?nh master t?i dây</MudText>
                <label class="ai-character-upload-button">
                    <MudIcon Icon="@Icons.Material.Filled.Upload" Size="Size.Small" />
                    <span>Ch?n ?nh upload</span>
                    <InputFile class="ai-character-upload-input" OnChange="UploadMasterImage" accept="image/*" disabled="@(_busy || _isNew)" />
                </label>
                @if (_isNew)
                {
                    <small>Luu nhân v?t tru?c khi upload ?nh master.</small>
                }
            </div>
            @if (_lastGenerate is not null)
            {
                <MudAlert Class="mt-3" Severity="@(_lastGenerate.Status == "success" ? Severity.Success : Severity.Error)" Dense="true">
                    @StatusLabel(_lastGenerate.Status)
                    @if (!string.IsNullOrWhiteSpace(_lastGenerate.ErrorMessage))
                    {
                        <span> - @_lastGenerate.ErrorMessage</span>
                    }
                </MudAlert>
            }
        </MudPaper>
    </div>

    @if (!_isNew && _detail is not null)
    {
        <MudPaper Class="todox-panel pa-5 mt-4" rounded="true">
            <div class="ai-character-section-title">
                <MudText Typo="Typo.h5">Prompt dang luu</MudText>
                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning" StartIcon="@Icons.Material.Filled.ContentCopy"
                           OnClick="@(() => Copy(_detail.NormalizedPrompt))">Sao chép</MudButton>
            </div>
            <pre class="ai-character-prompt">@_detail.NormalizedPrompt</pre>
        </MudPaper>

        <MudPaper Class="todox-panel pa-5 mt-4" rounded="true">
            <MudText Typo="Typo.h5" Class="mb-4">L?ch s? render</MudText>
            @if (_detail.Renders.Count == 0)
            {
                <MudAlert Severity="Severity.Info">Chua có l?ch s? render.</MudAlert>
            }
            else
            {
                <div class="ai-character-render-grid">
                    @foreach (var render in _detail.Renders)
                    {
                        <article class="ai-character-render-card">
                            <div class="ai-character-render-image">
                                @if (!string.IsNullOrWhiteSpace(render.OutputImageUrl))
                                {
                                    <img src="@render.OutputImageUrl" alt="@render.RenderCode" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.BrokenImage" />
                                }
                                <span class="ai-character-status @render.Status">@StatusLabel(render.Status)</span>
                            </div>
                            <div class="ai-character-render-body">
                                <b>@render.RenderCode</b>
                                <span>Nhŕ cung c?p: @ProviderLabel(render.ProviderCode) / @render.ModelName</span>
                                <span>@render.AspectRatio - @render.Quality - @render.Resolution</span>
                                <span>@(render.UsageCost?.ToString("0.####") ?? "0") di?m - @render.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                @if (!string.IsNullOrWhiteSpace(render.ErrorMessage))
                                {
                                    <small class="ai-character-error">@render.ErrorMessage</small>
                                }
                                <div>
                                    @if (render.Status == "success")
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                                                   StartIcon="@Icons.Material.Filled.Star"
                                                   OnClick="@(() => SetMaster(render.Id))">
                                            Ch?n lŕm master
                                        </MudButton>
                                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                                                   StartIcon="@Icons.Material.Filled.Link"
                                                    OnClick="@(() => Copy(render.OutputImageUrl ?? string.Empty))">
                                            Sao chép URL
                                        </MudButton>
                                    }
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                                               StartIcon="@Icons.Material.Filled.Article"
                                               OnClick="@(() => Copy(render.Prompt))">
                                        Sao chép prompt
                                    </MudButton>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        </MudPaper>
        <MudPaper Class="todox-panel pa-4 mt-4 ai-character-render-log-panel" rounded="true">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
                <div>
                    <MudText Typo="Typo.h6">Nh?t ký render</MudText>
                    <MudText Typo="Typo.caption" Class="todox-page-subtitle">Log ch?y tr?c ti?p tręn trang nŕy. T?i du?c file ngay c? khi backend l?i.</MudText>
                </div>
                <MudStack Row="true" Spacing="1" Class="flex-wrap gap-1">
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="CopyRenderLogs" Disabled="@(_renderLogs.Count == 0)">Sao chép log</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" OnClick="DownloadRenderLogTxt" Disabled="@(_renderLogs.Count == 0)">T?i .txt</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.DataObject" OnClick="DownloadRenderLogJson" Disabled="@(_renderLogs.Count == 0)">T?i .json</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning" OnClick="ClearRenderLogs" Disabled="@_busy">Xóa log</MudButton>
                </MudStack>
            </MudStack>

            @if (_busy)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Warning" Class="mt-3" />
            }

            @if (!string.IsNullOrWhiteSpace(_lastRenderError))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">
                    <MudText Typo="Typo.subtitle2">L?i g?n nh?t</MudText>
                    <pre class="ai-character-render-log-error">@_lastRenderError</pre>
                </MudAlert>
            }

            <div id="ai-character-render-log-panel" class="ai-character-render-log-list mt-3">
                @if (_renderLogs.Count == 0)
                {
                    <div class="ai-character-render-log-empty">Chua có log.</div>
                }
                else
                {
                    @foreach (var log in _renderLogs)
                    {
                        <div class="@($"ai-character-render-log-line log-{NormalizeLevel(log.Level)}")">
                            <div class="ai-character-render-log-head">
                                <span class="ai-character-render-log-time">[@log.Time:HH:mm:ss]</span>
                                <span class="ai-character-render-log-level">@NormalizeLevel(log.Level).ToUpperInvariant()</span>
                                <span class="ai-character-render-log-step">@log.Step</span>
                                <span class="ai-character-render-log-message">@log.Message</span>
                            </div>
                            @if (log.Data is not null)
                            {
                                <pre class="ai-character-render-log-data">@PrettyData(log.Data)</pre>
                            }
                            @if (!string.IsNullOrWhiteSpace(log.RawError))
                            {
                                <pre class="ai-character-render-log-error">@log.RawError</pre>
                            }
                        </div>
                    }
                }
            </div>
        </MudPaper>
    }
}

@code {
    [Parameter] public long? Id { get; set; }
    [SupplyParameterFromQuery(Name = "render")] public string? RenderQuery { get; set; }

    private readonly UpdateCharacterRequest _model = new()
    {
        StylePreset = CharacterPresetOptions.NotSpecified,
        Gender = "not_specified",
        AspectRatio = "1:1",
        Status = "active"
    };
    private CharacterDetailDto? _detail;
    private GenerateCharacterImageResponse? _lastGenerate;
    private bool _loading = true;
    private bool _busy;
    private bool _autoGenerate = true;
    private int? _seed;
    private string _referenceUrlsText = string.Empty;
    private string _renderPrompt = string.Empty;
    private string? _error;
    private bool _isNew => Id is null;
    private long? _providerCapabilityId;
    private List<ProviderOptionDto> _providerOptions = new();
    private readonly List<AiCharacterRenderLogItem> _renderLogs = new();
    private string? _lastRenderError;

    private string ProviderDisplay
    {
        get
        {
            var provider = _detail?.ProviderCode ?? Config["AiCharacters:DefaultImageProviderCode"] ?? Config["OpenRouter:DefaultImageProviderCode"] ?? "todox_image";
            var model = _detail?.ModelName ?? Config["AiCharacters:DefaultImageModel"] ?? Config["OpenRouter:DefaultImageModel"] ?? "ImageAICreativeRender";
            return $"Nhŕ cung c?p: {ProviderLabel(provider)} / {model}";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadProviderOptions();
        await Load();
        if (!_isNew && RenderQuery == "1")
        {
            await Generate();
        }
    }

    private async Task LoadProviderOptions()
    {
        try
        {
            _providerOptions = (await AiProviders.GetSelectableProvidersAsync("character_generation")).ToList();
            if (_providerOptions.Count > 0 && _providerCapabilityId is null)
            {
                _providerCapabilityId = (_providerOptions.FirstOrDefault(o => o.IsDefault) ?? _providerOptions[0]).ProviderCapabilityId;
            }
        }
        catch
        {
            _providerOptions = new();
        }
    }

    private async Task Load()
    {
        if (AuthState.CurrentUser is null) return;
        _loading = true;
        _error = null;
        try
        {
            if (!_isNew && Id is long id)
            {
                _detail = await Characters.GetCharacterAsync(AuthState.CurrentUser, id);
                if (_detail is null)
                {
                    _error = "Không těm th?y nhân v?t.";
                    return;
                }

                _model.CharacterName = _detail.CharacterName;
                _model.Description = _detail.Description;
                _model.RenderPrompt = _detail.NormalizedPrompt;
                _model.StylePreset = string.IsNullOrWhiteSpace(_detail.StylePreset) ? CharacterPresetOptions.NotSpecified : _detail.StylePreset;
                _model.Gender = string.IsNullOrWhiteSpace(_detail.Gender) ? CharacterPresetOptions.NotSpecified : _detail.Gender;
                _model.AspectRatio = _detail.AspectRatio;
                _model.Status = _detail.Status;
                _model.SortOrder = _detail.SortOrder;
                _renderPrompt = _detail.NormalizedPrompt;
                _seed = _detail.Seed;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Save()
    {
        if (AuthState.CurrentUser is null) return;
        _busy = true;
        try
        {
            if (_isNew)
            {
                var created = await Characters.CreateCharacterAsync(new CreateCharacterRequest
                {
                    CharacterName = _model.CharacterName,
                    Description = _model.Description,
                    RenderPrompt = _renderPrompt,
                    StylePreset = _model.StylePreset,
                    Gender = _model.Gender,
                    AspectRatio = _model.AspectRatio,
                    Seed = _seed,
                    AutoGenerateImage = _autoGenerate
                }, AuthState.CurrentUser);
                Snackbar.Add("Đă t?o nhân v?t AI.", Severity.Success);
                Nav.NavigateTo($"/ai-assets/characters/{created.Id}");
                return;
            }

            _model.RenderPrompt = _renderPrompt;
            await Characters.UpdateCharacterAsync(Id!.Value, _model, AuthState.CurrentUser);
            Snackbar.Add("Đă luu nhân v?t AI.", Severity.Success);
            await Load();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Generate()
    {
        _lastRenderError = null;
        _renderLogs.Clear();
        await AddRenderLogAsync("ui_started", "B?t d?u render character.", "info");
        await AddRenderLogAsync("ui_validate_input", "Đang ki?m tra input vŕ prompt.", "info", new
        {
            CharacterId = Id,
            _model.CharacterName,
            _model.AspectRatio,
            _model.StylePreset,
            _model.Gender,
            Seed = _seed,
            ProviderCapabilityId = _providerCapabilityId
        });

        if (AuthState.CurrentUser is null || Id is null)
        {
            await AddRenderLogAsync("ui_abort", "Thi?u user ho?c character id.", "warn");
            return;
        }

        _busy = true;
        _lastGenerate = null;
        try
        {
            var referenceUrls = ParseReferenceUrls();
            await AddRenderLogAsync("service_call", "G?i backend render character.", "info", new
            {
                CharacterId = Id,
                Seed = _seed,
                SaveAsMaster = true,
                ProviderCapabilityId = _providerCapabilityId,
                ReferenceCount = referenceUrls.Length
            });

            _lastGenerate = await Characters.GenerateImageAsync(new GenerateCharacterImageRequest
            {
                CharacterId = Id,
                Seed = _seed,
                RenderPrompt = _renderPrompt,
                ReferenceImageUrls = referenceUrls,
                SaveAsMaster = true,
                ProviderCapabilityId = _providerCapabilityId
            }, AuthState.CurrentUser);

            await AddRenderLogAsync(
                "service_result",
                _lastGenerate.Status == "success" ? "Render ?nh nhân v?t thŕnh công." : _lastGenerate.ErrorMessage ?? "Render chua thŕnh công.",
                _lastGenerate.Status == "success" ? "success" : "error",
                new { _lastGenerate.Status, _lastGenerate.RenderId, _lastGenerate.ImageUrl, _lastGenerate.ErrorMessage });

            Snackbar.Add(_lastGenerate.Status == "success" ? "Render ?nh nhân v?t thŕnh công." : _lastGenerate.ErrorMessage ?? "Render chua thŕnh công.",
                _lastGenerate.Status == "success" ? Severity.Success : Severity.Error);
            await Load();
        }
        catch (Npgsql.PostgresException ex)
        {
            _lastRenderError = ex.ToString();
            await AddRenderLogAsync("postgres_exception", ex.MessageText, "error", new { ex.SqlState, ex.Detail, ex.Hint }, ex.ToString());
            Snackbar.Add($"Render th?t b?i: {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            _lastRenderError = ex.ToString();
            await AddRenderLogAsync("unhandled_exception", ex.Message, "error", null, ex.ToString());
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
            await AddRenderLogAsync("ui_finished", "Hoŕn t?t render.", "info", new { _lastGenerate?.Status, _lastGenerate?.RenderId });
            await InvokeAsync(StateHasChanged);
            await ScrollRenderLogsAsync();
        }
    }

    private async Task UploadMasterImage(InputFileChangeEventArgs args)
    {
        if (AuthState.CurrentUser is null || Id is null) return;
        var file = args.File;
        _busy = true;
        try
        {
            await using var stream = file.OpenReadStream(12 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _lastGenerate = await Characters.UploadMasterImageAsync(Id.Value, ms.ToArray(), file.Name, file.ContentType, AuthState.CurrentUser);
            Snackbar.Add("Đă upload ?nh master.", Severity.Success);
            await Load();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SetMaster(long renderId)
    {
        if (AuthState.CurrentUser is null || Id is null) return;
        await Characters.SetMasterImageAsync(Id.Value, renderId, AuthState.CurrentUser);
        Snackbar.Add("Đă ch?n ?nh master.", Severity.Success);
        await Load();
    }

    private string[] ParseReferenceUrls()
        => _referenceUrlsText.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

    private Task AddRenderLogAsync(string step, string message, string level = "info", object? data = null, string? rawError = null)
    {
        _renderLogs.Add(new AiCharacterRenderLogItem
        {
            Time = DateTimeOffset.Now,
            Step = step,
            Level = level,
            Message = message,
            Data = data,
            RawError = rawError
        });

        return InvokeAsync(StateHasChanged);
    }

    private async Task ClearRenderLogs()
    {
        _renderLogs.Clear();
        _lastRenderError = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task CopyRenderLogs()
    {
        var text = string.Join(Environment.NewLine, _renderLogs.Select(log => $"[{log.Time:HH:mm:ss}] {log.Level.ToUpperInvariant()} {log.Step} - {log.Message}{FormatLogTail(log.Data, log.RawError)}"));
        await Js.InvokeVoidAsync("todoXRenderLog.copyText", text);
        Snackbar.Add("Đă sao chép log.", Severity.Success);
    }

    private async Task DownloadRenderLogTxt()
    {
        var text = string.Join(Environment.NewLine, _renderLogs.Select(log => $"[{log.Time:HH:mm:ss}] {log.Level.ToUpperInvariant()} {log.Step} - {log.Message}{FormatLogTail(log.Data, log.RawError)}"));
        await Js.InvokeVoidAsync("todoxDownload.saveTextFile", $"character-render-log-{DateTime.Now:yyyyMMdd-HHmmss}.txt", text);
    }

    private async Task DownloadRenderLogJson()
    {
        var json = JsonSerializer.Serialize(_renderLogs, new JsonSerializerOptions { WriteIndented = true });
        await Js.InvokeVoidAsync("todoxDownload.saveTextFile", $"character-render-log-{DateTime.Now:yyyyMMdd-HHmmss}.json", json);
    }

    private async Task ScrollRenderLogsAsync()
    {
        await Js.InvokeVoidAsync("todoXRenderLog.scrollToBottom", "ai-character-render-log-panel");
    }

    private static string FormatLogTail(object? data, string? rawError)
    {
        var parts = new List<string>();
        if (data is not null)
        {
            parts.Add(JsonSerializer.Serialize(data, new JsonSerializerOptions { WriteIndented = true }));
        }

        if (!string.IsNullOrWhiteSpace(rawError))
        {
            parts.Add(rawError);
        }

        return parts.Count == 0 ? string.Empty : $"{Environment.NewLine}{string.Join(Environment.NewLine, parts)}";
    }

    private static string NormalizeLevel(string? level)
        => string.IsNullOrWhiteSpace(level) ? "info" : level.Trim().ToLowerInvariant();

    private static string PrettyData(object? data)
        => data is null ? string.Empty : JsonSerializer.Serialize(data, new JsonSerializerOptions { WriteIndented = true });

    private sealed class AiCharacterRenderLogItem
    {
        public DateTimeOffset Time { get; set; } = DateTimeOffset.Now;
        public string Level { get; set; } = "info";
        public string Step { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
        public object? Data { get; set; }
        public string? RawError { get; set; }
    }

    private async Task Copy(string value)
    {
        await Js.InvokeVoidAsync("navigator.clipboard.writeText", value);
        Snackbar.Add("Đă copy.", Severity.Success);
    }

