@page "/admin-users"
@using TodoX.Web.Components.Dialogs
@inject AccountService Accounts
@inject AuthStateService AuthState
@inject AuditRepository Audit
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Quản trị viên</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-3">
        <div>
            <MudText Typo="Typo.h4" Class="todox-page-title">Quản lý tài khoản quản trị</MudText>
            <MudText Typo="Typo.body1" Class="todox-page-subtitle">Danh sách tài khoản quản trị và vận hành hệ thống TodoX.</MudText>
        </div>
        <IfCan Permission="admin_users.create">
            <MudButton Class="todox-primary-btn" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Thêm quản trị viên</MudButton>
        </IfCan>
    </MudStack>

    <MudPaper Class="todox-table-card pa-4" Rounded="true">
        <MudTable Items="@_users" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm" Class="todox-table">
            <HeaderContent>
                <MudTh>Họ tên</MudTh>
                <MudTh>Username</MudTh>
                <MudTh>Email</MudTh>
                <MudTh>Vai trò</MudTh>
                <MudTh>Trạng thái</MudTh>
                <MudTh>Ngày tạo</MudTh>
                <MudTh Style="text-align:right">Thao tác</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Họ tên">@context.FullName</MudTd>
                <MudTd DataLabel="Username">@context.Username</MudTd>
                <MudTd DataLabel="Email">@context.Email</MudTd>
                <MudTd DataLabel="Vai trò"><span class="todox-badge">@TodoXLabels.Role(context.Role)</span></MudTd>
                <MudTd DataLabel="Trạng thái">
                    <MudChip T="string" Size="Size.Small" Color="@TodoXLabels.StatusColor(context.Status)">@TodoXLabels.Status(context.Status)</MudChip>
                </MudTd>
                <MudTd DataLabel="Ngày tạo">@context.CreatedAt.ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Thao tác" Style="text-align:right">
                    @if (CanImpersonate(context.Id))
                    {
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Info"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.SupervisedUserCircle"
                                   OnClick="@(() => Impersonate(context))">
                            Đăng nhập hộ
                        </MudButton>
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEdit(context))" />
                    @if (context.Status == TodoXAccountStatus.Locked)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.LockOpen" Color="Color.Success" Size="Size.Small" OnClick="@(() => SetStatus(context, TodoXAccountStatus.Active))" />
                    }
                    else
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" OnClick="@(() => SetStatus(context, TodoXAccountStatus.Locked))" />
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => Delete(context))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-4 todox-page-subtitle">Chưa có quản trị viên nào.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private IReadOnlyList<SystemUser> _users = new List<SystemUser>();

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload() => _users = await Accounts.GetSystemUsersAsync();

    private async Task OpenCreate()
    {
        var dialog = await DialogService.ShowAsync<SystemUserDialog>("Thêm quản trị viên");
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is SystemUser model)
        {
            var (ok, message) = await Accounts.SaveSystemUserAsync(model);
            Snackbar.Add(message, ok ? Severity.Success : Severity.Error);
            if (ok) await Reload();
        }
    }

    private async Task OpenEdit(SystemUser user)
    {
        var parameters = new DialogParameters<SystemUserDialog> { { x => x.Source, user } };
        var dialog = await DialogService.ShowAsync<SystemUserDialog>("Chỉnh sửa quản trị viên", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is SystemUser model)
        {
            var (ok, message) = await Accounts.SaveSystemUserAsync(model);
            Snackbar.Add(message, ok ? Severity.Success : Severity.Error);
            if (ok) await Reload();
        }
    }

    private async Task SetStatus(SystemUser user, TodoXAccountStatus status)
    {
        await Accounts.SetSystemUserStatusAsync(user.Id, status);
        Snackbar.Add($"Đã cập nhật trạng thái: {TodoXLabels.Status(status)}.", Severity.Success);
        await Reload();
    }

    private async Task Delete(SystemUser user)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Xóa quản trị viên",
            $"Xóa tài khoản \"{user.Username}\"?",
            yesText: "Xóa", cancelText: "Hủy");

        if (confirm == true)
        {
            var (ok, message) = await Accounts.DeleteSystemUserAsync(user.Id);
            Snackbar.Add(message, ok ? Severity.Success : Severity.Error);
            if (ok) await Reload();
        }
    }

    private bool CanImpersonate(Guid targetUserId)
    {
        var current = AuthState.CurrentUser;
        return current is not null
            && current.UserId != targetUserId
            && !current.IsImpersonating
            && (current.IsRoot
                || current.Role is TodoXUserRole.Admin
                || current.CanViewModule("admin_users")
                || current.Can("admin_users.update"));
    }

    private async Task Impersonate(SystemUser user)
    {
        var current = AuthState.CurrentUser;
        if (current is null || !CanImpersonate(user.Id)) return;

        var reason = await RequestImpersonationReason(user.Email);
        if (string.IsNullOrWhiteSpace(reason)) return;

        var target = await Accounts.RehydrateSessionAsync(user.Id);
        if (target is null)
        {
            Snackbar.Add("Tài khoản không active hoặc không tồn tại.", Severity.Error);
            return;
        }

        await Audit.LogAsync(current, "admin_users", "impersonate",
            entityDisplay: user.Email, message: $"Impersonate admin user {user.Id}. Reason: {reason}");
        await AuthState.ImpersonateAsync(target, current);
        Snackbar.Add($"Đang đăng nhập dưới tài khoản {target.DisplayName}.", Severity.Warning);
        Nav.NavigateTo("/", forceLoad: true);
    }

    private async Task<string?> RequestImpersonationReason(string targetDisplay)
    {
        var parameters = new DialogParameters<ImpersonationReasonDialog>
        {
            { x => x.TargetDisplay, targetDisplay }
        };
        var dialog = await DialogService.ShowAsync<ImpersonationReasonDialog>("Lý do đăng nhập hộ", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        var result = await dialog.Result;
        return result is not null && !result.Canceled && result.Data is string reason
            ? reason.Trim()
            : null;
    }
}
