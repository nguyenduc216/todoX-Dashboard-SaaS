@page "/"
@inject AccountService Accounts

<PageTitle>TodoX SaaS Dashboard</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h4" Class="todox-page-title">Tổng quan hệ thống</MudText>
        <MudText Typo="Typo.body1" Class="todox-page-subtitle">Trung tâm quản trị khách hàng, tài khoản, điểm và render jobs của TodoX.</MudText>
    </div>

    <MudGrid>
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="todox-card pa-5" Rounded="true">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle2">Khách hàng</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Class="todox-gold" />
                </MudStack>
                <div class="todox-stat-value">@CustomerCount</div>
                <MudText Typo="Typo.caption" Class="todox-page-subtitle">Thông tin khách hàng TodoX</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="todox-card pa-5" Rounded="true">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle2">Tài khoản</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Class="todox-gold" />
                </MudStack>
                <div class="todox-stat-value">@AccountCount</div>
                <MudText Typo="Typo.caption" Class="todox-page-subtitle">Admin và tài khoản khách hàng</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="todox-card pa-5" Rounded="true">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle2">Điểm đã bán</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Token" Class="todox-gold" />
                </MudStack>
                <div class="todox-stat-value">0</div>
                <MudText Typo="Typo.caption" Class="todox-page-subtitle">Kết nối wallet ở Sprint tiếp theo</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="todox-card pa-5" Rounded="true">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle2">Render Jobs</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Movie" Class="todox-gold" />
                </MudStack>
                <div class="todox-stat-value">0</div>
                <MudText Typo="Typo.caption" Class="todox-page-subtitle">Prompt, image, voice, caption, video</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        <MudItem xs="12" lg="7">
            <MudPaper Class="todox-card pa-5" Rounded="true">
                <MudText Typo="Typo.h6">Lộ trình Sprint hiện tại</MudText>
                <MudDivider Class="my-3" />
                <MudList T="string">
                    <MudListItem Icon="@Icons.Material.Filled.CheckCircle">Đồng bộ màu sắc nhận diện TodoX theo logo</MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.CheckCircle">Bổ sung responsive layout cho desktop và mobile</MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.CheckCircle">Bổ sung đăng nhập, đăng ký và quản lý tài khoản cơ bản</MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Info">Dữ liệu hiện dùng in-memory; PostgreSQL schema/seed đã có script riêng</MudListItem>
                </MudList>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" lg="5">
            <MudPaper Class="todox-card pa-5" Rounded="true">
                <MudText Typo="Typo.h6">Tài khoản mặc định</MudText>
                <MudDivider Class="my-3" />
                <MudText Typo="Typo.body2">Admin: <b>admin</b></MudText>
                <MudText Typo="Typo.body2">Mật khẩu: <b>toDOx@123#2026</b></MudText>
                <MudText Typo="Typo.body2" Class="mt-2">Khách demo: <b>demo@todox.local</b> / <b>Customer@123</b></MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private int CustomerCount;
    private int AccountCount;

    protected override async Task OnInitializedAsync()
    {
        var customers = await Accounts.GetCustomersAsync();
        var systemUsers = await Accounts.GetSystemUsersAsync();
        var customerAccounts = await Accounts.GetCustomerAccountsAsync();
        CustomerCount = customers.Count;
        AccountCount = systemUsers.Count + customerAccounts.Count;
    }
}
