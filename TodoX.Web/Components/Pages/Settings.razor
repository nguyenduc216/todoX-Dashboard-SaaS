@page "/settings"
@inject CatalogRepository Catalog
@inject MrTodoXAvatarService MrTodoXAvatar
@inject SystemImageStorage SystemImageStorage
@inject ISnackbar Snackbar

<PageTitle>Cài đặt hệ thống</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h4" Class="todox-page-title">Cài đặt hệ thống</MudText>
        <MudText Typo="Typo.body1" Class="todox-page-subtitle">Cấu hình SaaS, LLM provider/router, nhận diện TodoX và thông tin triển khai.</MudText>
    </div>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="todox-card pa-5" rounded="true">
                <MudText Typo="Typo.h6">Thông tin hệ thống</MudText>
                <MudDivider Class="my-3" />
                <MudSimpleTable Dense="true" Bordered="false" Class="todox-kv-table">
                    <tbody>
                        <tr><td>Sản phẩm</td><td>TodoX SaaS Dashboard</td></tr>
                        <tr><td>Giao diện</td><td>Dark + Gold (nhận diện TodoX)</td></tr>
                        <tr><td>Database</td><td>PostgreSQL - Foundation V2</td></tr>
                        <tr><td>Automation API</td><td>V9 API-first (/api/v9, /api/llm)</td></tr>
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="todox-card pa-5" rounded="true">
                <MudText Typo="Typo.h6">LLM Router / Provider</MudText>
                <MudDivider Class="my-3" />
                <MudTable Items="@_routers" Dense="true" Hover="true" Class="todox-table" Breakpoint="Breakpoint.None">
                    <HeaderContent>
                        <MudTh>Router</MudTh>
                        <MudTh>Provider</MudTh>
                        <MudTh>Model</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Router"><span class="todox-badge">@context.Router</span></MudTd>
                        <MudTd DataLabel="Provider">@context.Provider</MudTd>
                        <MudTd DataLabel="Model">@context.Model</MudTd>
                    </RowTemplate>
                </MudTable>
                <MudText Typo="Typo.caption" Class="todox-page-subtitle mt-2">
                    Hiển thị theo DatabaseContract. Chỉnh sửa provider nằm trong nhóm cài đặt API.
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Class="todox-card pa-5" rounded="true">
                <MudStack Spacing="3">
                    <div>
                        <MudText Typo="Typo.h6">Hình ảnh đại diện TodoX / Mr. todoX</MudText>
                        <MudText Typo="Typo.body2" Class="todox-page-subtitle">
                            Ảnh này được dùng làm nhân vật đại diện trong các thumbnail dịch vụ render bằng AI.
                        </MudText>
                    </div>

                    <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="3" Class="flex-wrap">
                        <div class="todox-mr-avatar-preview">
                            @if (!string.IsNullOrWhiteSpace(_mrTodoXAvatarUrl))
                            {
                                <img src="@_mrTodoXAvatarUrl" alt="Mr. todoX" />
                            }
                            else
                            {
                                <div class="todox-mr-avatar-empty">
                                    <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Large" />
                                    <span>Chưa có ảnh Mr. todoX</span>
                                </div>
                            }
                        </div>

                        <MudStack Spacing="2" Class="todox-mr-avatar-form">
                            <MudTextField T="string"
                                          Label="URL ảnh Mr. todoX"
                                          @bind-Value="_mrTodoXAvatarUrl"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />

                            <MudTextField T="string"
                                          Label="Mô tả Mr. todoX dùng khi render"
                                          @bind-Value="_mrTodoXPrompt"
                                          Variant="Variant.Outlined"
                                          Lines="4" />

                            <MudStack Row="true" Spacing="2" Class="flex-wrap">
                                <label class="@($"profile-avatar-upload {(_mrTodoXBusy ? "is-disabled" : string.Empty)}")">
                                    <MudIcon Icon="@Icons.Material.Filled.Upload" Size="Size.Small" />
                                    <span>Upload ảnh Mr. todoX</span>
                                    <InputFile OnChange="UploadMrTodoXAvatar" accept="image/png,image/jpeg,image/webp" disabled="@_mrTodoXBusy" />
                                </label>

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Warning"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           OnClick="SaveMrTodoXSettings"
                                           Disabled="@_mrTodoXBusy">
                                    Lưu cài đặt
                                </MudButton>

                                <MudButton Variant="Variant.Text"
                                           Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.Delete"
                                           OnClick="ClearMrTodoXAvatar"
                                           Disabled="@_mrTodoXBusy">
                                    Xóa ảnh
                                </MudButton>
                            </MudStack>

                            @if (_mrTodoXBusy)
                            {
                                <MudProgressLinear Indeterminate="true" Color="Color.Warning" />
                            }
                        </MudStack>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Class="todox-card pa-5" rounded="true">
                <MudText Typo="Typo.h6">Gói dịch vụ &amp; bảng giá điểm</MudText>
                <MudDivider Class="my-3" />
                <MudTable Items="@_packages" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="todox-table">
                    <HeaderContent>
                        <MudTh>Mã gói</MudTh>
                        <MudTh>Tên</MudTh>
                        <MudTh>Loại</MudTh>
                        <MudTh Style="text-align:right">Điểm cơ bản</MudTh>
                        <MudTh Style="text-align:right">Điểm/giây</MudTh>
                        <MudTh Style="text-align:right">Voice</MudTh>
                        <MudTh Style="text-align:right">Caption</MudTh>
                        <MudTh>Trạng thái</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Mã gói"><span class="todox-badge">@context.Code</span></MudTd>
                        <MudTd DataLabel="Tên">@context.Name</MudTd>
                        <MudTd DataLabel="Loại">@context.ServiceType</MudTd>
                        <MudTd DataLabel="Điểm cơ bản" Style="text-align:right">@context.BaseTokens.ToString("#,0.##")</MudTd>
                        <MudTd DataLabel="Điểm/giây" Style="text-align:right">@context.TokenPerSecond.ToString("#,0.##")</MudTd>
                        <MudTd DataLabel="Voice" Style="text-align:right">@context.VoiceTokens.ToString("#,0.##")</MudTd>
                        <MudTd DataLabel="Caption" Style="text-align:right">@context.CaptionTokens.ToString("#,0.##")</MudTd>
                        <MudTd DataLabel="Trạng thái">
                            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">@(context.IsActive ? "Bật" : "Tắt")</MudChip>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4 todox-page-subtitle">Chưa có gói dịch vụ nào.</MudText>
                    </NoRecordsContent>
                </MudTable>
                <MudText Typo="Typo.caption" Class="todox-page-subtitle mt-2">
                    Dữ liệu đọc trực tiếp từ public.service_packages.
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private IReadOnlyList<ServicePackageView> _packages = new List<ServicePackageView>();
    private string? _mrTodoXAvatarUrl;
    private string _mrTodoXPrompt = string.Empty;
    private bool _mrTodoXBusy;

    protected override async Task OnInitializedAsync()
    {
        _packages = await Catalog.GetServicePackagesAsync();
        var mrTodoX = await MrTodoXAvatar.GetAsync();
        _mrTodoXAvatarUrl = mrTodoX.AvatarUrl;
        _mrTodoXPrompt = mrTodoX.PromptDescription;
    }

    private async Task UploadMrTodoXAvatar(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        _mrTodoXBusy = true;
        try
        {
            var url = await SystemImageStorage.SaveMrTodoXAvatarAsync(file);
            _mrTodoXAvatarUrl = url;
            await MrTodoXAvatar.SaveAvatarUrlAsync(url);
            Snackbar.Add("Đã upload ảnh Mr. todoX.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload ảnh Mr. todoX lỗi: {ex.Message}", Severity.Error);
        }
        finally
        {
            _mrTodoXBusy = false;
        }
    }

    private async Task SaveMrTodoXSettings()
    {
        _mrTodoXBusy = true;
        try
        {
            await MrTodoXAvatar.SaveAvatarUrlAsync(_mrTodoXAvatarUrl);
            await MrTodoXAvatar.SavePromptAsync(_mrTodoXPrompt);
            Snackbar.Add("Đã lưu cài đặt Mr. todoX.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lưu cài đặt Mr. todoX lỗi: {ex.Message}", Severity.Error);
        }
        finally
        {
            _mrTodoXBusy = false;
        }
    }

    private async Task ClearMrTodoXAvatar()
    {
        _mrTodoXBusy = true;
        try
        {
            _mrTodoXAvatarUrl = null;
            await MrTodoXAvatar.SaveAvatarUrlAsync(null);
            Snackbar.Add("Đã xóa URL ảnh Mr. todoX.", Severity.Success);
        }
        finally
        {
            _mrTodoXBusy = false;
        }
    }

    private readonly List<RouterRow> _routers = new()
    {
        new("CloudGemini", "Google Cloud", "gemini-2.5-pro"),
        new("GPT", "WokuGPT", "gpt-4o"),
        new("Claude", "WokuClaude", "claude-sonnet-4-6"),
        new("DeepSeek", "WokuDeepSeek", "deepseek-chat"),
        new("WokuGemini", "WokuGemini", "gemini-2.0-flash")
    };

    private sealed record RouterRow(string Router, string Provider, string Model);
}
