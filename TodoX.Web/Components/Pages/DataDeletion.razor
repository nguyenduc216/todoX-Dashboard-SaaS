@page "/data-deletion"

<PageTitle>User Data Deletion - TodoX</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">
    <MudPaper Class="todox-card pa-6" rounded="true">
        <MudText Typo="Typo.h4" Class="todox-page-title">User Data Deletion</MudText>
        <MudText Typo="Typo.caption" Class="todox-page-subtitle">Last updated: July 2026</MudText>

        <MudDivider Class="my-4" />

        <MudStack Spacing="3">
            <MudText>
                TodoX users may request deletion of their personal data, connected social page data, access tokens,
                publishing logs, and related account data.
            </MudText>

            <MudText Typo="Typo.h6">How to Request Deletion</MudText>
            <MudText>
                Please send an email to support@todox.vn with the subject:
                <b>TodoX Data Deletion Request</b>.
            </MudText>

            <MudText>
                Include your TodoX account email, customer/company name, connected page/account details,
                and whether you want to delete only connected social data or the entire TodoX account.
            </MudText>

            <MudText Typo="Typo.h6">Processing Time</MudText>
            <MudText>
                We will review and process valid deletion requests normally within 7 business days, unless retention
                is required for legal, security, billing, or audit obligations.
            </MudText>

            <MudText Typo="Typo.h6">Facebook Data Deletion Callback</MudText>
            <MudText>
                Facebook may also send automated data deletion requests to:
                <MudLink Href="/facebook/data-deletion">https://dashboard.todox.vn/facebook/data-deletion</MudLink>.
            </MudText>

            <MudText Typo="Typo.h6">Contact</MudText>
            <MudText>Email: support@todox.vn</MudText>
        </MudStack>
    </MudPaper>
</MudContainer>
