@page "/customer-accounts"
@using TodoX.Web.Components.Dialogs
@inject AccountService Accounts
@inject AuthStateService AuthState
@inject AuditRepository Audit
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Tài khoản khách hàng</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-3">
        <div>
            <MudText Typo="Typo.h4" Class="todox-page-title">Quản lý tài khoản</MudText>
            <MudText Typo="Typo.body1" Class="todox-page-subtitle">Quản lý tài khoản đăng nhập của khách hàng TodoX SaaS.</MudText>
        </div>
        <IfCan Permission="customer_accounts.create">
            <MudButton Class="todox-primary-btn" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate" Disabled="@(_customers.Count == 0)">Tạo tài khoản</MudButton>
        </IfCan>
    </MudStack>

    @if (_customers.Count == 0)
    {
        <MudAlert Severity="Severity.Warning">Chưa có khách hàng nào. Vui lòng thêm khách hàng trước khi tạo tài khoản đăng nhập.</MudAlert>
    }

    <MudPaper Class="todox-table-card pa-4" Rounded="true">
        <MudTextField T="string" @bind-Value="_search" Placeholder="Tìm theo tên, email, khách hàng..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" Class="mb-3" Variant="Variant.Outlined" Margin="Margin.Dense" />

        <MudTable Items="@Filtered" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="todox-table">
            <HeaderContent>
                <MudTh>Khách hàng</MudTh>
                <MudTh>Họ tên</MudTh>
                <MudTh>Email</MudTh>
                <MudTh>Vai trò</MudTh>
                <MudTh>Trạng thái</MudTh>
                <MudTh>Ngày tạo</MudTh>
                <MudTh Style="text-align:right">Thao tác</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Khách hàng">@context.CompanyName</MudTd>
                <MudTd DataLabel="Họ tên">@context.FullName</MudTd>
                <MudTd DataLabel="Email">@context.Email</MudTd>
                <MudTd DataLabel="Vai trò"><MudChip T="string" Color="Color.Warning" Size="Size.Small">@TodoXLabels.Role(context.Role)</MudChip></MudTd>
                <MudTd DataLabel="Trạng thái">
                    <MudChip T="string" Size="Size.Small" Color="@TodoXLabels.StatusColor(context.Status)">@TodoXLabels.Status(context.Status)</MudChip>
                </MudTd>
                <MudTd DataLabel="Ngày tạo">@context.CreatedAt.ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Thao tác" Style="text-align:right">
                    @if (CanImpersonate(context.Id))
                    {
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Info"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.SupervisedUserCircle"
                                   OnClick="@(() => Impersonate(context))">
                            Đăng nhập hộ
                        </MudButton>
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEdit(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.LockReset" Size="Size.Small" Title="Đặt lại mật khẩu" OnClick="@(() => ResetPassword(context))" />
                    @if (context.Status == TodoXAccountStatus.Locked)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.LockOpen" Color="Color.Success" Size="Size.Small" OnClick="@(() => SetStatus(context, TodoXAccountStatus.Active))" />
                    }
                    else
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" OnClick="@(() => SetStatus(context, TodoXAccountStatus.Locked))" />
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => Delete(context))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-4 todox-page-subtitle">Chưa có tài khoản khách hàng nào.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private IReadOnlyList<CustomerAccount> _accounts = new List<CustomerAccount>();
    private IReadOnlyList<CustomerProfile> _customers = new List<CustomerProfile>();
    private string _search = string.Empty;

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        _accounts = await Accounts.GetCustomerAccountsAsync();
        _customers = await Accounts.GetCustomersAsync();
    }

    private IEnumerable<CustomerAccount> Filtered
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_search))
            {
                return _accounts;
            }

            var q = _search.Trim();
            return _accounts.Where(x =>
                x.FullName.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                x.Email.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                x.CompanyName.Contains(q, StringComparison.OrdinalIgnoreCase));
        }
    }

    private async Task OpenCreate()
    {
        var parameters = new DialogParameters<CustomerAccountDialog> { { x => x.Customers, _customers } };
        var dialog = await DialogService.ShowAsync<CustomerAccountDialog>("Tạo tài khoản khách hàng", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is CustomerAccount model)
        {
            var (ok, message) = await Accounts.SaveCustomerAccountAsync(model);
            Snackbar.Add(message, ok ? Severity.Success : Severity.Error);
            if (ok) await Reload();
        }
    }

    private async Task OpenEdit(CustomerAccount account)
    {
        var parameters = new DialogParameters<CustomerAccountDialog>
        {
            { x => x.Source, account },
            { x => x.Customers, _customers }
        };
        var dialog = await DialogService.ShowAsync<CustomerAccountDialog>("Chỉnh sửa tài khoản", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is CustomerAccount model)
        {
            var (ok, message) = await Accounts.SaveCustomerAccountAsync(model);
            Snackbar.Add(message, ok ? Severity.Success : Severity.Error);
            if (ok) await Reload();
        }
    }

    private async Task ResetPassword(CustomerAccount account)
    {
        var newPassword = await DialogService.ShowMessageBoxAsync(
            "Đặt lại mật khẩu",
            (MarkupString)$"Đặt lại mật khẩu cho <b>{account.Email}</b> về mặc định <b>Customer@123</b>?",
            yesText: "Đặt lại", cancelText: "Hủy");

        if (newPassword == true)
        {
            var (ok, message) = await Accounts.ResetCustomerAccountPasswordAsync(account.Id, "Customer@123");
            Snackbar.Add(message, ok ? Severity.Success : Severity.Error);
        }
    }

    private async Task SetStatus(CustomerAccount account, TodoXAccountStatus status)
    {
        await Accounts.SetCustomerAccountStatusAsync(account.Id, status);
        Snackbar.Add($"Đã cập nhật trạng thái: {TodoXLabels.Status(status)}.", Severity.Success);
        await Reload();
    }

    private async Task Delete(CustomerAccount account)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Xóa tài khoản",
            $"Xóa tài khoản đăng nhập \"{account.Email}\"?",
            yesText: "Xóa", cancelText: "Hủy");

        if (confirm == true)
        {
            var (ok, message) = await Accounts.DeleteCustomerAccountAsync(account.Id);
            Snackbar.Add(message, ok ? Severity.Success : Severity.Error);
            if (ok) await Reload();
        }
    }

    private bool CanImpersonate(Guid targetUserId)
    {
        var current = AuthState.CurrentUser;
        return current is not null
            && current.UserId != targetUserId
            && !current.IsImpersonating
            && (current.IsRoot
                || current.Role is TodoXUserRole.Admin or TodoXUserRole.SystemOperator
                || current.CanViewModule("customer_accounts")
                || current.Can("customer_accounts.update"));
    }

    private async Task Impersonate(CustomerAccount account)
    {
        var current = AuthState.CurrentUser;
        if (current is null || !CanImpersonate(account.Id)) return;

        var reason = await RequestImpersonationReason(account.Email);
        if (string.IsNullOrWhiteSpace(reason)) return;

        var target = await Accounts.RehydrateSessionAsync(account.Id);
        if (target is null)
        {
            Snackbar.Add("Tài khoản không active hoặc không tồn tại.", Severity.Error);
            return;
        }

        await Audit.LogAsync(current, "customer_accounts", "impersonate",
            entityDisplay: account.Email, message: $"Impersonate customer account {account.Id}. Reason: {reason}");
        await AuthState.ImpersonateAsync(target, current);
        Snackbar.Add($"Đang đăng nhập dưới tài khoản {target.DisplayName}.", Severity.Warning);
        Nav.NavigateTo("/", forceLoad: true);
    }

    private async Task<string?> RequestImpersonationReason(string targetDisplay)
    {
        var parameters = new DialogParameters<ImpersonationReasonDialog>
        {
            { x => x.TargetDisplay, targetDisplay }
        };
        var dialog = await DialogService.ShowAsync<ImpersonationReasonDialog>("Lý do đăng nhập hộ", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        var result = await dialog.Result;
        return result is not null && !result.Canceled && result.Data is string reason
            ? reason.Trim()
            : null;
    }
}
