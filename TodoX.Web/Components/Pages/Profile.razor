@page "/profile"
@using Microsoft.AspNetCore.Components.Forms
@using TodoX.Web.Components.Dialogs
@using TodoX.Web.Services.Profile
@inject AuthStateService AuthState
@inject AccountService Accounts
@inject IAvatarService Avatars
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Hồ sơ cá nhân</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h4" Class="todox-page-title">Hồ sơ cá nhân</MudText>
        <MudText Typo="Typo.body1" Class="todox-page-subtitle">Cập nhật thông tin tài khoản, ảnh đại diện và đổi mật khẩu.</MudText>
    </div>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Class="todox-card profile-avatar-card pa-5" rounded="true">
                <MudText Typo="Typo.h6" Class="mb-3 align-self-start">Ảnh đại diện</MudText>

                <button type="button"
                        class="@($"profile-avatar-frame {(!string.IsNullOrWhiteSpace(_avatarUrl) ? "is-clickable" : string.Empty)}")"
                        disabled="@string.IsNullOrWhiteSpace(_avatarUrl)"
                        @onclick="ViewAvatar">
                    @if (!string.IsNullOrWhiteSpace(_avatarUrl))
                    {
                        <img src="@_avatarUrl" alt="Ảnh đại diện" />
                    }
                    else
                    {
                        <span>@AvatarText</span>
                    }
                </button>

                <label class="@($"profile-avatar-upload {(_busy ? "is-disabled" : string.Empty)}")">
                    <MudIcon Icon="@Icons.Material.Filled.Upload" Size="Size.Small" />
                    <span>Tải ảnh đại diện</span>
                    <InputFile OnChange="OnAvatarSelected" accept="image/png,image/jpeg,image/webp" disabled="@_busy" />
                </label>

                <MudButton Class="mt-2" Variant="Variant.Text" Color="Color.Warning" StartIcon="@Icons.Material.Filled.AutoAwesome"
                           OnClick="@(() => Nav.NavigateTo("/profile/avatar"))">
                    Tạo ảnh chibi
                </MudButton>

                @if (!string.IsNullOrWhiteSpace(_avatarUrl))
                {
                    <MudText Typo="Typo.caption" Class="todox-page-subtitle mt-2">Bấm vào ảnh để xem phóng to.</MudText>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudPaper Class="todox-card pa-5" rounded="true">
                <MudText Typo="Typo.h6">Thông tin tài khoản</MudText>
                <MudDivider Class="my-3" />
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Email" Value="@(AuthState.CurrentUser?.Email)" Variant="Variant.Outlined" ReadOnly="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Họ tên" @bind-Value="_fullName" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Số điện thoại" @bind-Value="_phone" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="string" Label="Giới tính" @bind-Value="_gender" Variant="Variant.Outlined">
                            <MudSelectItem Value="@("male")">Nam</MudSelectItem>
                            <MudSelectItem Value="@("female")">Nữ</MudSelectItem>
                            <MudSelectItem Value="@("other")">Khác</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Label="Ngày sinh" @bind-Date="_dob" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Vai trò" Value="@RoleLabel" Variant="Variant.Outlined" ReadOnly="true" />
                    </MudItem>
                </MudGrid>
                <MudButton Class="todox-primary-btn mt-4" OnClick="SaveProfile" Disabled="_busy">Lưu thông tin</MudButton>
            </MudPaper>

            <MudPaper Class="todox-card pa-5 mt-4" rounded="true">
                <MudText Typo="Typo.h6">Đổi mật khẩu</MudText>
                <MudDivider Class="my-3" />
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudTextField T="string" Label="Mật khẩu hiện tại" @bind-Value="_currentPassword" InputType="InputType.Password" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField T="string" Label="Mật khẩu mới" @bind-Value="_newPassword" InputType="InputType.Password" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField T="string" Label="Xác nhận mật khẩu mới" @bind-Value="_confirmPassword" InputType="InputType.Password" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
                <MudButton Class="todox-primary-btn mt-4" OnClick="ChangePassword" Disabled="_busy">Đổi mật khẩu</MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private string _avatarUrl = string.Empty;
    private Guid? _avatarMediaId;
    private string _fullName = string.Empty;
    private string _phone = string.Empty;
    private string? _gender;
    private DateTime? _dob;
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _busy;

    private string RoleLabel => AuthState.CurrentUser?.Role switch
    {
        TodoXUserRole.Admin => "Quản trị viên",
        TodoXUserRole.SystemOperator => "Vận hành hệ thống",
        TodoXUserRole.CustomerOwner => "Chủ tài khoản khách hàng",
        TodoXUserRole.CustomerUser => "Người dùng khách hàng",
        _ => ""
    };

    private string AvatarText => string.IsNullOrWhiteSpace(_fullName) ? "U" : _fullName.Trim()[0].ToString().ToUpperInvariant();

    protected override async Task OnInitializedAsync()
    {
        _fullName = AuthState.CurrentUser?.DisplayName ?? string.Empty;
        if (AuthState.CurrentUser is not null)
        {
            var uid = AuthState.CurrentUser.UserId;
            var extras = await Accounts.GetProfileExtrasAsync(uid);
            _gender = extras.Gender;
            _dob = extras.Dob;
            var avatar = await Avatars.GetCurrentAsync(uid);
            _avatarUrl = avatar.AvatarUrl ?? string.Empty;
            _avatarMediaId = avatar.MediaId;
        }
    }

    private async Task OnAvatarSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null || AuthState.CurrentUser is null) return;
        _busy = true;
        try
        {
            if (file.Size > 10 * 1024 * 1024)
            {
                Snackbar.Add("Ảnh vượt quá 10MB.", Severity.Error);
                return;
            }

            await using var stream = file.OpenReadStream(10 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var info = await Avatars.UploadAsync(AuthState.CurrentUser.UserId, ms.ToArray(), file.Name, file.ContentType);
            _avatarUrl = info.AvatarUrl ?? _avatarUrl;
            _avatarMediaId = info.MediaId;
            AuthState.UpdateAvatarUrl(info.AvatarUrl);
            Snackbar.Add("Đã cập nhật ảnh đại diện.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải ảnh: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ViewAvatar()
    {
        if (string.IsNullOrWhiteSpace(_avatarUrl)) return;

        var parameters = new DialogParameters<ReferenceImageLightboxDialog>
        {
            ["Title"] = "Ảnh đại diện",
            ["ImageUrl"] = _avatarUrl,
            ["FileName"] = "Ảnh đại diện",
            ["MediaId"] = _avatarMediaId
        };
        await DialogService.ShowAsync<ReferenceImageLightboxDialog>("Xem ảnh đại diện", parameters,
            new DialogOptions { FullScreen = true, CloseButton = true, MaxWidth = MaxWidth.False });
    }

    private async Task SaveProfile()
    {
        if (AuthState.CurrentUser is null) return;
        if (string.IsNullOrWhiteSpace(_fullName))
        {
            Snackbar.Add("Họ tên không được để trống.", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            await Accounts.UpdateOwnProfileAsync(AuthState.CurrentUser.UserId, _fullName.Trim(), _phone, _gender, _dob);
            AuthState.UpdateDisplayName(_fullName.Trim());
            Snackbar.Add("Đã cập nhật thông tin.", Severity.Success);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ChangePassword()
    {
        if (AuthState.CurrentUser is null) return;
        _busy = true;
        try
        {
            var (ok, message) = await Accounts.ChangePasswordAsync(
                AuthState.CurrentUser.UserId, _currentPassword, _newPassword, _confirmPassword);
            Snackbar.Add(message, ok ? Severity.Success : Severity.Error);
            if (ok) _currentPassword = _newPassword = _confirmPassword = string.Empty;
        }
        finally
        {
            _busy = false;
        }
    }
}
