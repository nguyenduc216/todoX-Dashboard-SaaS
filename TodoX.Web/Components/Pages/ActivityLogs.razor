@code {
    private bool _loading = true;
    private string _search = string.Empty;
    private IReadOnlyList<AuditLogView> _logs = new List<AuditLogView>();
    private AuditLogDetail? _detail;

    [Parameter] public string? LogCode { get; set; }

    private bool IsCustomer => AuthState.CurrentUser?.IsCustomer == true;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState.CurrentUser is not null)
        {
            _logs = await Audit.GetRecentAsync(AuthState.CurrentUser);
            if (!string.IsNullOrWhiteSpace(LogCode))
            {
                _detail = await Audit.GetByEntityDisplayAsync(AuthState.CurrentUser, LogCode);
                _search = LogCode;
            }
        }
        _loading = false;
    }

    private IEnumerable<AuditLogView> Filtered
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_search)) return _logs;
            var q = _search.Trim();
            return _logs.Where(x =>
                (x.ActorDisplayName?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (x.ActorEmail?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false) ||
                x.Module.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                x.Action.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                (x.EntityDisplay?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false));
        }
    }

    private static string ActionLabel(string a) => a switch
    {
        "view" => "Xem", "create" => "ThÃªm", "update" => "Sá»­a", "delete" => "XÃ³a",
        "login" => "ÄÄƒng nháº­p", "logout" => "ÄÄƒng xuáº¥t", "reset_password" => "Äáº·t láº¡i MK",
        "verify" => "XÃ¡c thá»±c", _ => a
    };

    private static string ModuleLabel(string m) => m switch
    {
        "admin_users" => "Quáº£n trá»‹ viÃªn", "customers" => "KhÃ¡ch hÃ ng", "customer_accounts" => "TÃ i khoáº£n KH",
        "customer_pages" => "Trang máº¡ng xÃ£ há»™i", "token_wallets" => "VÃ­ token", "services" => "Dá»‹ch vá»¥",
        "render_jobs" => "Render Jobs", "avatar_render" => "Avatar Render", "api_providers" => "CÃ i Ä‘áº·t API", "settings" => "CÃ i Ä‘áº·t",
        "permissions" => "PhÃ¢n quyá»n", "auth" => "XÃ¡c thá»±c", _ => m
    };

    private static string PrettyJson(string? message)
    {
        if (string.IsNullOrWhiteSpace(message)) return string.Empty;
        try
        {
            using var doc = JsonDocument.Parse(message);
            return JsonSerializer.Serialize(doc.RootElement, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return message;
        }
    }
}
