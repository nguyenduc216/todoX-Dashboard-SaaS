@page "/wallets"

<PageTitle>Ví token</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h4" Class="todox-page-title">Ví token</MudText>
        <MudText Typo="Typo.body1" Class="todox-page-subtitle">Khu vực quản lý số dư token và giao dịch sử dụng dịch vụ AI.</MudText>
    </div>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Class="todox-card pa-5" Rounded="true">
                <MudText Typo="Typo.subtitle2">Tổng token</MudText>
                <div class="todox-stat-value">0</div>
                <MudText Typo="Typo.caption" Class="todox-page-subtitle">Sẽ kết nối PostgreSQL ở Sprint tiếp theo</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="8">
            <MudPaper Class="todox-card pa-5" Rounded="true">
                <MudText Typo="Typo.h6">Giao dịch gần đây</MudText>
                <MudAlert Severity="Severity.Info" Class="mt-4">Module ví token đang ở trạng thái placeholder.</MudAlert>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>
