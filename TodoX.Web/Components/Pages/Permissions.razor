@page "/permissions"
@inject PermissionRepository PermRepo
@inject AuthStateService AuthState
@inject AuditRepository Audit
@inject ISnackbar Snackbar

<PageTitle>Phân quyền</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h4" Class="todox-page-title">Phân quyền theo nhóm</MudText>
        <MudText Typo="Typo.body1" Class="todox-page-subtitle">Chọn nhóm quyền và tick quyền theo chức năng, thao tác. Người dùng cần đăng nhập lại để nhận quyền mới.</MudText>
    </div>

    <MudPaper Class="todox-card pa-4" rounded="true">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="flex-wrap">
            <MudSelect T="Guid" Label="Nhóm quyền" @bind-Value="_roleId" @bind-Value:after="OnRoleChanged" Variant="Variant.Outlined" Style="max-width:340px">
                @foreach (var r in _roles)
                {
                    <MudSelectItem T="Guid" Value="@r.Id">@r.Name (@r.Code)</MudSelectItem>
                }
            </MudSelect>
            @if (_selectedRole is not null)
            {
                <span class="todox-badge">@(_selectedRole.RoleType == "customer" ? "Nhóm khách hàng" : "Nhóm quản trị")</span>
                <MudText Typo="Typo.body2" Class="todox-page-subtitle">@_checked.Count / @_allPermIds.Count quyền</MudText>
                @if (IsLockedRole)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true">Role root hệ thống không được phép chỉnh sửa.</MudAlert>
                }
            }
            <MudSpacer />
            <MudButton Class="todox-primary-btn" StartIcon="@Icons.Material.Filled.Save" OnClick="Save"
                       Disabled="@(_busy || _selectedRole is null || IsLockedRole)">
                Lưu quyền
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Warning" />
    }
    else if (_selectedRole is not null)
    {
        <MudPaper Class="todox-table-card pa-0" rounded="true">
            <div class="todox-perm-scroll">
                <table class="todox-perm-table">
                    <thead>
                        <tr>
                            <th class="todox-perm-sticky-col todox-perm-sticky-head todox-perm-module-head">
                                <div class="todox-perm-module-check">
                                    <MudCheckBox T="bool"
                                                 Value="@IsAllChecked()"
                                                 Indeterminate="@IsAllPartial()"
                                                 ValueChanged="SetAll"
                                                 Dense="true"
                                                 Color="Color.Warning"
                                                 Disabled="@IsLockedRole" />
                                    <span>Chức năng</span>
                                </div>
                            </th>
                            @foreach (var act in _actions)
                            {
                                <th class="todox-perm-sticky-head todox-perm-action-head">
                                    <div class="todox-perm-action-check">
                                        <MudCheckBox T="bool"
                                                     Value="@IsActionAll(act)"
                                                     Indeterminate="@IsActionPartial(act)"
                                                     ValueChanged="@(v => SetAction(act, v))"
                                                     Dense="true"
                                                     Color="Color.Warning"
                                                     Disabled="@IsLockedRole" />
                                        <span>@ActionLabel(act)</span>
                                    </div>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var module in _modules)
                        {
                            <tr>
                                <td class="todox-perm-sticky-col todox-perm-module-cell">
                                    <div class="todox-perm-module-check">
                                        <MudCheckBox T="bool"
                                                     Value="@IsModuleAll(module)"
                                                     Indeterminate="@IsModulePartial(module)"
                                                     ValueChanged="@(v => SetModule(module, v))"
                                                     Dense="true"
                                                     Color="Color.Warning"
                                                     Disabled="@IsLockedRole" />
                                        <b>@ModuleLabel(module)</b>
                                    </div>
                                </td>
                                @foreach (var act in _actions)
                                {
                                    var pid = FindPermId(module, act);
                                    <td class="todox-perm-cell">
                                        @if (pid is not null)
                                        {
                                            <MudCheckBox T="bool"
                                                         Value="@_checked.Contains(pid.Value)"
                                                         ValueChanged="@(v => Toggle(pid.Value, v))"
                                                         Dense="true"
                                                         Color="Color.Warning"
                                                         Disabled="@IsLockedRole" />
                                        }
                                        else
                                        {
                                            <span class="todox-perm-na">-</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </MudPaper>
    }
</MudStack>

@code {
    private bool _loading;
    private bool _busy;
    private IReadOnlyList<RoleDto> _roles = new List<RoleDto>();
    private IReadOnlyList<PermissionDto> _allPerms = new List<PermissionDto>();
    private HashSet<Guid> _allPermIds = new();
    private Guid _roleId;
    private RoleDto? _selectedRole;
    private HashSet<Guid> _checked = new();
    private List<string> _modules = new();
    private List<string> _actions = new();

    private bool IsLockedRole => _selectedRole?.IsSystem == true && _selectedRole?.Code == "administrator_root";

    protected override async Task OnInitializedAsync()
    {
        _roles = await PermRepo.GetRolesAsync();
        _allPerms = await PermRepo.GetAllPermissionsAsync();
        _allPermIds = _allPerms.Select(p => p.Id).ToHashSet();
        _modules = _allPerms.Select(p => p.Module).Distinct().OrderBy(x => x).ToList();

        var order = new[] { "view", "create", "update", "delete", "approve", "reject", "activate", "deactivate", "assign_role", "assign_permission", "reset_password", "run", "test", "export", "import", "adjust" };
        var present = _allPerms.Select(p => p.Action).Distinct().ToHashSet();
        _actions = order.Where(present.Contains).Concat(present.Except(order).OrderBy(x => x)).ToList();

        if (_roles.Count > 0)
        {
            _roleId = _roles.FirstOrDefault(r => r.Code == "customer")?.Id ?? _roles[0].Id;
            await OnRoleChanged();
        }
    }

    private async Task OnRoleChanged()
    {
        _loading = true;
        _selectedRole = _roles.FirstOrDefault(r => r.Id == _roleId);
        _checked = await PermRepo.GetRolePermissionIdsAsync(_roleId);
        _loading = false;
    }

    private Guid? FindPermId(string module, string action)
        => _allPerms.FirstOrDefault(p => p.Module == module && p.Action == action)?.Id;

    private IEnumerable<Guid> ModulePermissionIds(string module)
        => _allPerms.Where(p => p.Module == module).Select(p => p.Id);

    private IEnumerable<Guid> ActionPermissionIds(string action)
        => _allPerms.Where(p => p.Action == action).Select(p => p.Id);

    private bool IsAllChecked()
        => _allPermIds.Count > 0 && _allPermIds.All(_checked.Contains);

    private bool IsAllPartial()
        => _checked.Count > 0 && !IsAllChecked();

    private void SetAll(bool on)
    {
        if (IsLockedRole) return;
        if (on)
        {
            foreach (var id in _allPermIds) _checked.Add(id);
        }
        else
        {
            _checked.Clear();
        }
    }

    private bool IsModuleAll(string module)
    {
        var ids = ModulePermissionIds(module).ToArray();
        return ids.Length > 0 && ids.All(_checked.Contains);
    }

    private bool IsModulePartial(string module)
    {
        var ids = ModulePermissionIds(module).ToArray();
        return ids.Any(_checked.Contains) && !ids.All(_checked.Contains);
    }

    private void SetModule(string module, bool on)
    {
        if (IsLockedRole) return;
        foreach (var id in ModulePermissionIds(module))
        {
            if (on) _checked.Add(id);
            else _checked.Remove(id);
        }
    }

    private bool IsActionAll(string action)
    {
        var ids = ActionPermissionIds(action).ToArray();
        return ids.Length > 0 && ids.All(_checked.Contains);
    }

    private bool IsActionPartial(string action)
    {
        var ids = ActionPermissionIds(action).ToArray();
        return ids.Any(_checked.Contains) && !ids.All(_checked.Contains);
    }

    private void SetAction(string action, bool on)
    {
        if (IsLockedRole) return;
        foreach (var id in ActionPermissionIds(action))
        {
            if (on) _checked.Add(id);
            else _checked.Remove(id);
        }
    }

    private void Toggle(Guid pid, bool on)
    {
        if (IsLockedRole) return;
        if (on) _checked.Add(pid);
        else _checked.Remove(pid);
    }

    private async Task Save()
    {
        if (_selectedRole is null || IsLockedRole) return;
        _busy = true;
        try
        {
            await PermRepo.SetRolePermissionsAsync(_roleId, _checked);
            await Audit.LogAsync(AuthState.CurrentUser, "permissions", "update",
                entityDisplay: _selectedRole.Name, message: $"Cập nhật {_checked.Count} quyền cho nhóm {_selectedRole.Code}");
            Snackbar.Add("Đã lưu phân quyền. Người dùng cần đăng nhập lại để áp dụng.", Severity.Success);
        }
        finally
        {
            _busy = false;
        }
    }

    private static string ActionLabel(string a) => a switch
    {
        "view" => "Xem",
        "create" => "Thêm",
        "update" => "Sửa",
        "delete" => "Xóa",
        "approve" => "Duyệt",
        "reject" => "Từ chối",
        "activate" => "Kích hoạt",
        "deactivate" => "Vô hiệu",
        "assign_role" => "Gán vai trò",
        "assign_permission" => "Gán quyền",
        "reset_password" => "Reset MK",
        "run" => "Chạy",
        "test" => "Kiểm thử",
        "export" => "Xuất",
        "import" => "Nhập",
        "adjust" => "Điều chỉnh",
        _ => a
    };

    private static string ModuleLabel(string m) => m switch
    {
        "admin_users" => "Quản trị viên",
        "customers" => "Khách hàng",
        "customer_accounts" => "Tài khoản KH",
        "customer_pages" => "Trang mạng xã hội",
        "token_wallets" => "Ví điểm",
        "token_transactions" => "Giao dịch điểm",
        "services" => "Dịch vụ",
        "render_jobs" => "Render Jobs",
        "publish_jobs" => "Đăng bài",
        "api_providers" => "Nhà cung cấp API",
        "app_settings" => "Cấu hình",
        "settings" => "Cài đặt",
        "audit_logs" => "Nhật ký",
        "roles" => "Vai trò",
        "permissions" => "Quyền",
        "account_groups" => "Nhóm tài khoản",
        "dashboard" => "Dashboard",
        "llm_gateway" => "LLM Gateway",
        "prompt_templates" => "Quản lý prompt",
        _ => m
    };
}
