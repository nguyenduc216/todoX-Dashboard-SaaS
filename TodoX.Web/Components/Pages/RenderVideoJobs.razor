    private ActiveCharacterDto? ResolveCurrentCharacter()
        => _selectedCharacter ?? (_project?.CharacterId is long characterId ? _characters.FirstOrDefault(x => x.Id == characterId) : null);

    private async Task MoveSceneUpAsync(VideoProjectSceneDto scene)
    {
        if (_project is null || AuthState.CurrentUser is null || scene.SceneIndex <= 1) return;
        await VideoRepo.MoveSceneAsync(_project.Id, scene.Id, -1, AuthState.CurrentUser);
        await ReloadAsync();
    }

    private async Task MoveSceneDownAsync(VideoProjectSceneDto scene)
    {
        if (_project is null || AuthState.CurrentUser is null || scene.SceneIndex >= _project.Scenes.Count) return;
        await VideoRepo.MoveSceneAsync(_project.Id, scene.Id, 1, AuthState.CurrentUser);
        await ReloadAsync();
    }

    private async Task DeleteSceneAsync(VideoProjectSceneDto scene)
    {
        if (_project is null || AuthState.CurrentUser is null) return;
        await VideoRepo.DeleteSceneAsync(_project.Id, scene.Id, AuthState.CurrentUser);
        await ReloadAsync();
    }

    private async Task AddSceneAsync()
    {
        if (_project is null || AuthState.CurrentUser is null) return;
        if (!EnsureAspectRatioSelected())
        {
            return;
        }

        var index = _project.Scenes.Count + 1;
        await VideoRepo.AddSceneAsync(_project.Id, new VideoProjectAddSceneRequest
        {
            Title = $"Scene {index:00}",
            Purpose = "manual_scene",
            DurationSeconds = Math.Max(1, _sceneSeconds),
            ImagePrompt = $"Scene {index} image prompt",
            VideoPrompt = $"Scene {index} motion prompt",
            Voice = string.Empty,
            VoiceInstruction = string.Empty,
            AspectRatio = _aspectRatio
        }, AuthState.CurrentUser);
        Snackbar.Add("Đã thêm scene thủ công.", Severity.Success);
        await ReloadAsync();
    }

    private Task RenderSceneVideoAsync(VideoProjectSceneDto scene)
    {
        return EnqueueSceneVideoAsync(scene);
    }

    private async Task EnqueueRenderAllScenesAsync()
    {
        if (_project is null || AuthState.CurrentUser is null) return;
        if (!EnsureAspectRatioSelected() || !EnsureResolutionSelected())
        {
            return;
        }
        if (_defaultImageToVideoProvider is null)
        {
            Snackbar.Add("Chưa cấu hình provider image-to-video.", Severity.Warning);
            return;
        }

        var sceneIds = _project.Scenes
            .Where(scene => CanCreateSceneVideo(scene, GetSceneDraft(scene)))
            .Select(scene => scene.Id)
            .ToArray();
        if (sceneIds.Length == 0)
        {
            Snackbar.Add("Không có scene nào đủ điều kiện render video.", Severity.Info);
            return;
        }

        foreach (var scene in _project.Scenes.Where(scene => sceneIds.Contains(scene.Id)))
        {
            var draft = GetSceneDraft(scene);
            if (draft.IsDirty)
            {
                await SaveSceneAsync(scene);
            }
        }

        var input = new TodoX.Web.Services.VideoRender.SceneVideoRenderInput
        {
            ProjectId = _project.Id,
            SceneIds = sceneIds,
            AspectRatio = _aspectRatio,
            Resolution = _resolution,
            UserId = AuthState.CurrentUser.UserId,
            CustomerId = AuthState.CurrentUser.CustomerId,
            CreatedBy = AuthState.CurrentUser.Email ?? AuthState.CurrentUser.UserId.ToString(),
            TrustedPayerContext = TodoX.Web.Services.AiProviders.AiBillingPayerResolver.CreateTrustedBackgroundContext(AuthState.CurrentUser)
        };

        var (job, alreadyActive) = await RenderJobs.EnqueueForProjectIfNoneActiveAsync(new RenderJobCreateModel
        {
            JobType = TodoX.Web.Services.VideoRender.SceneVideoRenderHandler.JobTypeName,
            UserId = AuthState.CurrentUser.UserId,
            CustomerId = AuthState.CurrentUser.CustomerId,
            Input = input,
            Prompt = new { projectId = _project.Id, sceneIds },
            LogCode = BuildLogCode(),
            ProviderCode = TodoX.Web.Services.VideoRender.SceneVideoRenderHandler.RoutingProviderCode,
            ModelCode = TodoX.Web.Services.VideoRender.SceneVideoRenderHandler.RoutingModelCode,
            MaxAttempts = 1,
            PointCostEstimate = 0,
            PointStatus = RenderPointStatuses.Pending
        }, _project.Id);

        if (alreadyActive)
        {
            Snackbar.Add("Project này đang có job render video scene đang chạy.", Severity.Info);
        }
        else
        {
            await LogProjectEvent("SCENE_VIDEO_BATCH_ENQUEUED", "info", "Đã enqueue batch render scene video.",
                new { job.Id, sceneCount = sceneIds.Length, provider = _defaultImageToVideoProvider.ProviderCode, model = _defaultImageToVideoProvider.ModelName });
            Snackbar.Add($"Đã enqueue render video cho {sceneIds.Length} scene.", Severity.Success);
        }

        await StartPolling();
    }

    private async Task EnqueueMergeAsync()
    {
        if (_project is null || AuthState.CurrentUser is null) return;
        if (!CanMerge)
        {
            Snackbar.Add("Cần tất cả scene có video sẵn sàng trước khi ghép.", Severity.Warning);
            return;
        }

        var (job, alreadyActive) = await RenderJobs.EnqueueForProjectIfNoneActiveAsync(new RenderJobCreateModel
        {
            JobType = TodoX.Web.Services.VideoRender.VideoRenderMergeHandler.JobTypeName,
            UserId = AuthState.CurrentUser.UserId,
            CustomerId = AuthState.CurrentUser.CustomerId,
            Input = new { projectId = _project.Id },
            Prompt = new { projectId = _project.Id },
            LogCode = BuildLogCode(),
            ProviderCode = "internal_merge",
            ModelCode = "ffmpeg_concat",
            MaxAttempts = 1,
            PointCostEstimate = 0,
            PointStatus = RenderPointStatuses.NotRequired
        }, _project.Id);

        if (alreadyActive)
        {
            Snackbar.Add("Project này đang có job ghép video.", Severity.Info);
        }
        else
        {
            await LogProjectEvent("FINAL_VIDEO_MERGE_ENQUEUED", "info", "Đã enqueue ghép final video.", new { job.Id, projectId = _project.Id });
            Snackbar.Add("Đã enqueue ghép final video.", Severity.Success);
        }

        await StartPolling();
    }

    private async Task EnqueueSceneVideoAsync(VideoProjectSceneDto scene)
    {
        if (_project is null || AuthState.CurrentUser is null) return;
        if (!EnsureAspectRatioSelected() || !EnsureResolutionSelected())
        {
            return;
        }

        var draft = GetSceneDraft(scene);
        if (!CanCreateSceneVideo(scene, draft))
        {
            Snackbar.Add(SceneVideoDisabledReason(scene, draft), Severity.Info);
            return;
        }

        if (draft.IsDirty)
        {
            await SaveSceneAsync(scene);
            draft = GetSceneDraft(scene);
        }

        var input = new TodoX.Web.Services.VideoRender.SceneVideoRenderInput
        {
            ProjectId = _project.Id,
            SceneIds = new[] { scene.Id },
            AspectRatio = _aspectRatio,
            Resolution = _resolution,
            UserId = AuthState.CurrentUser.UserId,
            CustomerId = AuthState.CurrentUser.CustomerId,
            CreatedBy = AuthState.CurrentUser.Email ?? AuthState.CurrentUser.UserId.ToString(),
            TrustedPayerContext = TodoX.Web.Services.AiProviders.AiBillingPayerResolver.CreateTrustedBackgroundContext(AuthState.CurrentUser)
        };

        var job = await RenderJobs.EnqueueAsync(new RenderJobCreateModel
        {
            JobType = TodoX.Web.Services.VideoRender.SceneVideoRenderHandler.JobTypeName,
            UserId = AuthState.CurrentUser.UserId,
            CustomerId = AuthState.CurrentUser.CustomerId,
            Input = input,
            Prompt = new { projectId = _project.Id, sceneId = scene.Id },
            LogCode = BuildLogCode(),
            ProviderCode = TodoX.Web.Services.VideoRender.SceneVideoRenderHandler.RoutingProviderCode,
            ModelCode = TodoX.Web.Services.VideoRender.SceneVideoRenderHandler.RoutingModelCode,
            MaxAttempts = 1,
            PointCostEstimate = 0,
            PointStatus = RenderPointStatuses.Pending
        });

        await LogProjectEvent("SCENE_VIDEO_ENQUEUED", "info", $"Đã enqueue render video cho scene {scene.SceneIndex}.",
            new { job.Id, sceneId = scene.Id, scene.SceneIndex, provider = _defaultImageToVideoProvider?.ProviderCode, model = _defaultImageToVideoProvider?.ModelName });
        Snackbar.Add($"Đã enqueue render video cho scene {scene.SceneIndex}.", Severity.Success);
        await StartPolling();
    }

