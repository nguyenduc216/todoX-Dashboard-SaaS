            0x00,0x00,0x00,0x00,0x49,0x45,0x4E,0x44,0xAE,0x42,0x60,0x82
        };
        return Convert.ToBase64String(png);
    }

    private void OpenUrl(string url) => JS.InvokeVoidAsync("open", url);

    private Task LogProjectEvent(string eventType, string level, string message, object? data = null)
        => _project is null ? Task.CompletedTask : VideoRepo.AddProjectEventAsync(_project.Id, eventType, level, message, data);

    private static string SceneLabel(string status) => status switch
    {
        VideoSceneStatuses.Draft => "Draft",
        VideoSceneStatuses.ImageReady => "Image ready",
        VideoSceneStatuses.VideoQueued => "Video queued",
        VideoSceneStatuses.VideoRendering => "Rendering",
        VideoSceneStatuses.VideoReady => "Video ready",
        VideoSceneStatuses.Failed => "Failed",
        _ => status
    };

    private static Color SceneColor(string status) => status switch
    {
        VideoSceneStatuses.VideoReady => Color.Success,
        VideoSceneStatuses.ImageReady => Color.Info,
        VideoSceneStatuses.VideoQueued or VideoSceneStatuses.VideoRendering => Color.Warning,
        VideoSceneStatuses.Failed => Color.Error,
        _ => Color.Default
    };

    private static Color LogColor(string level) => level switch
    {
        "error" => Color.Error,
        "warning" => Color.Warning,
        "success" => Color.Success,
        _ => Color.Info
    };

    private static Color JobColor(string status) => status switch
    {
        RenderJobStatuses.Completed => Color.Success,
        RenderJobStatuses.Rendering or RenderJobStatuses.Preparing or RenderJobStatuses.Queued => Color.Warning,
        RenderJobStatuses.Failed => Color.Error,
        RenderJobStatuses.Cancelled => Color.Default,
        _ => Color.Info
    };
}


