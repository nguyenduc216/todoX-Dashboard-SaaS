    }

    private const string AspectRatioLandscape = "16:9";
    private const string AspectRatioPortrait = "9:16";
    private const string Resolution720p = "720p";
    private const string Resolution1080p = "1080p";
    private const string Resolution4K = "4K";

    private bool CanMerge => _project is not null && _project.Scenes.Count > 0 && _project.Scenes.All(x => x.Status == VideoSceneStatuses.VideoReady);

    private string BuildLogCode() => _projectId is null ? string.Empty : $"video-{_projectId.Value}";

    private string ProjectAspectRatio => HasProjectAspectRatio ? _aspectRatio : "Chưa chọn";

    private bool HasProjectAspectRatio => IsSupportedAspectRatio(_aspectRatio);

    private string ProjectResolution => HasProjectResolution ? _resolution : "Chưa chọn";

    private bool HasProjectResolution => IsSupportedResolution(_resolution);

    private IReadOnlyList<string> SupportedVideoResolutions
        => (VideoOptions.CurrentValue.SupportedResolutions is { Length: > 0 } values ? values : new[] { Resolution720p, Resolution1080p })
            .Select(NormalizeResolution)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Cast<string>()
            .ToList();

    private string ProjectHeaderMeta
        => _projectId is long id
            ? $"Project #{id} · Aspect ratio: {ProjectAspectRatio}"
            : $"Project mới · Aspect ratio: {ProjectAspectRatio}";

    private sealed record DebugEntry(DateTimeOffset Timestamp, int StepNumber, string StepCode, string StepName, string Status, long DurationMs, string Message, string? Details = null);

    protected override async Task OnInitializedAsync()
    {
        if (!Embedded)
        {
            var target = QueryProjectId is long projectId ? $"/render-jobs?projectId={projectId}" : "/render-jobs";
            Navigation.NavigateTo(target, replace: true);
            return;
        }

        _projectId = ProjectId ?? QueryProjectId;
        if (AuthState.CurrentUser is not null)
        {
            await LoadCharactersAsync();
        }
        if (AuthState.CurrentUser is not null)
        {
            _projectDialogOpen = true;
            if (_projectId is not null)
            {
                await ReloadAsync();
            }
        }
        if (_projectId is not null)
        {
            await StartPolling();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!Embedded)
        {
            var target = QueryProjectId is long projectId ? $"/render-jobs?projectId={projectId}" : "/render-jobs";
            Navigation.NavigateTo(target, replace: true);
            return;
        }

        var incomingProjectId = ProjectId ?? QueryProjectId;
        if (incomingProjectId != _projectId)
        {
            _projectId = incomingProjectId;
            _sceneDrafts.Clear();
            _imageVersions.Clear();
            _videoVersions.Clear();
            if (AuthState.CurrentUser is not null)
            {
                _projectDialogOpen = true;
                if (_projectId is null)
                {
                    _project = null;
                    _prompt = string.Empty;
                    _aspectRatio = string.Empty;
                    _resolution = string.Empty;
                    StopPolling();
                }
                else
                {
                    await ReloadAsync();
                    await StartPolling();
                }
                _tabIndex = 0;
            }
        }
    }

    public void Dispose()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollTimer?.Dispose();
        _reloadLock.Dispose();
    }

    private async Task CreateProjectAsync()
    {
        if (AuthState.CurrentUser is null) return;
        if (!EnsureAspectRatioSelected())
        {
            return;
        }
        _busy = true;
        try
        {
            if (!_promptParseResult.IsJsonValid)
            {
                _promptParseResult = PromptParser.Parse(_prompt);
            }
            await AddDebugAsync("ui_started", "Bắt đầu xử lý", "STARTED", "Người dùng bấm nút Tạo / phân tách scene.");
            await AddDebugAsync("ui_auth", "Kiểm tra đăng nhập", "INFO", $"User={MaskGuid(AuthState.CurrentUser.UserId)}, Customer={MaskGuid(AuthState.CurrentUser.CustomerId)}");
            var inputDebug = BuildInputDebugMessage();
            await AddDebugAsync("ui_input", "Kiểm tra prompt", "INFO", inputDebug);
            _prompt = PersistPromptVideoSettings(_prompt, _aspectRatio, _resolution);

            var storageRoot = VideoOptions.CurrentValue.StorageRoot;
            var publicBase = VideoOptions.CurrentValue.PublicBase;
            var jobFolder = DateTime.UtcNow.ToString("yyyyMMdd-HHmmss");
            await AddDebugAsync("repo_call", "Gọi repository", "INFO", $"storageRoot={storageRoot}, publicBase={publicBase}, jobFolder={jobFolder}");
            var result = await VideoRepo.CreateProjectAsync(new VideoProjectCreateRequest
            {
                Prompt = _prompt,
                AspectRatio = _aspectRatio,
                CharacterId = _selectedCharacter?.Id,
                TotalSeconds = _totalSeconds,
                SceneSeconds = Math.Max(1, _sceneSeconds),
                ThinkScenes = _thinkScenes,
                Title = _promptParseResult.Model.VideoTitle ?? "Render video job",
                CreateEmptyProject = false,
                Scenes = BuildSceneRequests()
            }, AuthState.CurrentUser.UserId, AuthState.CurrentUser.CustomerId, storageRoot, publicBase, jobFolder);
        _projectId = result.Id;
            await ProjectCreated.InvokeAsync(result.Id);
            Logger.LogInformation("VIDEO_RENDER_CREATE_PROJECT_OK projectId={ProjectId} sceneCount={SceneCount} status={Status}", result.Id, result.SceneCount, result.Status);
            await ReloadAsync();
            Snackbar.Add("Đã tạo project và chuyển sang tab Scene / Hình ảnh.", Severity.Success);
            _tabIndex = 1;
            await LogProjectEvent("PROJECT_CREATED", "info", "Đã tạo project và sinh scene plan mock.", new { result.Id, result.SceneCount, result.Status });
            await AddDebugAsync("ui_done", "Hoàn tất", "SUCCESS", $"Tạo project thành công: {result.Id}", $"SceneCount={result.SceneCount}, Status={result.Status}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "VIDEO_RENDER_CREATE_PROJECT_FAILED");
            Snackbar.Add(ex.Message, Severity.Error);
            await AddDebugAsync("ui_failed", "Thất bại", "FAILED", ex.Message, ex.ToString());
        }
        finally { _busy = false; }
    }

    private async Task CreateEmptyProjectAsync()
    {
        if (AuthState.CurrentUser is null) return;
        if (!EnsureAspectRatioSelected())
        {
            return;
        }
        _promptParseResult = PromptParser.Parse(_prompt);
        _busy = true;
        try
        {
            var storageRoot = VideoOptions.CurrentValue.StorageRoot;
            var publicBase = VideoOptions.CurrentValue.PublicBase;
            var jobFolder = DateTime.UtcNow.ToString("yyyyMMdd-HHmmss");
            var result = await VideoRepo.CreateProjectAsync(new VideoProjectCreateRequest
            {
                Prompt = PersistPromptVideoSettings(_prompt, _aspectRatio, _resolution),
                AspectRatio = _aspectRatio,
                CharacterId = _selectedCharacter?.Id,
                TotalSeconds = _totalSeconds,
                SceneSeconds = Math.Max(1, _sceneSeconds),
                ThinkScenes = false,
                Title = _promptParseResult.Model.VideoTitle ?? "Video project rỗng",
                CreateEmptyProject = true
            }, AuthState.CurrentUser.UserId, AuthState.CurrentUser.CustomerId, storageRoot, publicBase, jobFolder);
            _projectId = result.Id;
            await ProjectCreated.InvokeAsync(result.Id);
            await ReloadAsync();
            _tabIndex = 1;
            Snackbar.Add("Đã tạo project rỗng.", Severity.Success);
        }
        finally
        {
            _busy = false;
        }
    }

    private List<VideoProjectSceneCreateRequest> BuildSceneRequests()
    {
        if (_promptParseResult.HasScenes)
        {
            return _promptParseResult.Model.Scenes
                .OrderBy(x => x.Scene ?? int.MaxValue)
                .Select((scene, index) => new VideoProjectSceneCreateRequest
                {
                    SceneIndex = scene.Scene ?? index + 1,
                    Title = $"Scene {scene.Scene ?? index + 1}",
                    DurationSeconds = scene.DurationSeconds ?? _sceneSeconds,
                    ScenePrompt = BuildSceneMetadata(scene),
                    ImagePrompt = scene.ImagePrompt,
                    VideoPrompt = scene.MotionPrompt
                })
                .ToList();
        }

        var fallbackCount = Math.Max(1, (int)Math.Ceiling(Math.Max(1, _totalSeconds) / (double)Math.Max(1, _sceneSeconds)));
        return Enumerable.Range(1, fallbackCount)
            .Select(index => new VideoProjectSceneCreateRequest
            {
                SceneIndex = index,
                Title = $"Scene {index}",
                DurationSeconds = index == fallbackCount ? Math.Max(1, _totalSeconds - _sceneSeconds * (fallbackCount - 1)) : _sceneSeconds,
                ScenePrompt = $"scene_purpose: main_content | image_prompt: Scene {index} image prompt | motion_prompt: Scene {index} motion prompt | voice: Scene {index} voice | voice_instruction: Scene {index} voice instruction",
                ImagePrompt = $"Scene {index} image prompt",
                VideoPrompt = $"Scene {index} motion prompt"
            })
            .ToList();
    }

    private static string BuildSceneMetadata(TodoXVideoScenePromptModel scene)
        => new ScenePromptMetadata
        {
            ScenePurpose = scene.ScenePurpose,
            ImagePrompt = scene.ImagePrompt,
            MotionPrompt = scene.MotionPrompt,
            Voice = scene.Voice,
            VoiceInstruction = scene.VoiceInstruction
        }.Serialize();

    private string GetCharacterCardClass(long characterId)
        => $"pa-2 {(IsCharacterSelected(characterId) ? "todox-card-selected" : string.Empty)}".Trim();

    private static string ExtractScenePurpose(string? scenePrompt)
        => ScenePromptMetadata.Parse(scenePrompt).ScenePurpose ?? string.Empty;

    private string BuildInputDebugMessage()
        => $"PromptLength={_prompt.Length}, AspectRatio={ProjectAspectRatio}, Resolution={ProjectResolution}, CharacterId={(_selectedCharacter?.Id.ToString() ?? "null")}, TotalSeconds={_totalSeconds}, SceneSeconds={_sceneSeconds}, ThinkScenes={_thinkScenes}, IsTodoX={_promptParseResult.IsTodoXPrompt}, Scenes={_promptParseResult.Model.Scenes.Count}";

    private static string? ExtractValue(string? source, string key)
    {
        var metadata = ScenePromptMetadata.Parse(source);
        return key switch
        {
            "scene_purpose" or "purpose" => metadata.ScenePurpose,
            "image_prompt" => metadata.ImagePrompt,
            "motion_prompt" or "video_prompt" => metadata.MotionPrompt,
            "voice" => metadata.Voice,
            "voice_instruction" => metadata.VoiceInstruction,
            _ => metadata.Extra.TryGetValue(key, out var value) ? value : null
        };
    }

    private Task AddDebugAsync(string stepCode, string stepName, string status, string message, string? details = null)
    {
        _debugEntries.Add(new DebugEntry(DateTimeOffset.Now, ++_debugStep, stepCode, stepName, status, 0, message, details));
        if (_debugEntries.Count > 200)
        {
            _debugEntries.RemoveRange(0, _debugEntries.Count - 200);
        }

        return InvokeAsync(StateHasChanged);
    }

    private Task ClearDebugLogAsync()
    {
        _debugEntries.Clear();
        _debugStep = 0;
        return InvokeAsync(StateHasChanged);
    }

    private Task CopyDebugLogAsync()
    {
        var text = string.Join(Environment.NewLine, _debugEntries.OrderBy(x => x.StepNumber).Select(x => $"[{x.Timestamp:dd/MM/yyyy HH:mm:ss.fff}] {x.Status} {x.StepCode} {x.Message}"));
        return JS.InvokeVoidAsync("todoXRenderLog.copyText", text).AsTask();
    }

    private Task DownloadDebugLogAsync()
    {
        var text = string.Join(Environment.NewLine, _debugEntries.OrderBy(x => x.StepNumber).Select(x => $"[{x.Timestamp:dd/MM/yyyy HH:mm:ss.fff}] {x.Status} {x.StepCode} {x.Message}"));
        return JS.InvokeVoidAsync("todoxDownload.saveTextFile", $"render-job-{DateTimeOffset.Now:yyyyMMdd-HHmmss}.txt", text).AsTask();
    }

    private static string MaskGuid(Guid? value) => value.HasValue ? $"{value.Value.ToString()[..8]}****" : "null";

    private async Task NewProjectAsync()
    {
        _projectId = null;
        QueryProjectId = null;
        _project = null;
        _prompt = string.Empty;
        _promptParseResult = new();
        _aspectRatio = string.Empty;
        _resolution = string.Empty;
        _characterPrompt = string.Empty;
        _totalSeconds = 16;
        _sceneSeconds = 8;
        _thinkScenes = false;
        _projectDialogOpen = true;
        _tabIndex = 0;
        if (!Embedded)
        {
            Navigation.NavigateTo("/render-jobs", replace: true);
        }
        Snackbar.Add("Đã reset form tạo project mới.", Severity.Info);
        await InvokeAsync(StateHasChanged);
