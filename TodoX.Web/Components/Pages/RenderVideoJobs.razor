    private Task CheckPromptAsync()
    {
        _promptParseResult = PromptParser.Parse(_prompt);
        ApplyVideoSettingsFromPrompt();
        return InvokeAsync(StateHasChanged);
    }

    private Task OnAspectRatioChangedAsync(string value)
    {
        _aspectRatio = NormalizeAspectRatio(value) ?? string.Empty;
        return InvokeAsync(StateHasChanged);
    }

    private Task OnResolutionChangedAsync(string value)
    {
        _resolution = NormalizeResolution(value) ?? string.Empty;
        return InvokeAsync(StateHasChanged);
    }

    private void ApplyVideoSettingsFromPrompt()
    {
        var parsed = NormalizeAspectRatio(_promptParseResult.Model.AspectRatio);
        if (!string.IsNullOrWhiteSpace(parsed))
        {
            _aspectRatio = parsed;
        }

        var resolution = NormalizeResolution(_promptParseResult.Model.Resolution);
        if (!string.IsNullOrWhiteSpace(resolution))
        {
            _resolution = resolution;
        }
    }

    private bool EnsureAspectRatioSelected()
    {
        if (HasProjectAspectRatio)
        {
            return true;
        }

        if (!_promptParseResult.IsJsonValid)
        {
            _promptParseResult = PromptParser.Parse(_prompt);
            ApplyVideoSettingsFromPrompt();
            if (HasProjectAspectRatio)
            {
                return true;
            }
        }

        Snackbar.Add("Vui lòng chọn tỷ lệ video 16:9 hoặc 9:16 trước khi tạo/phân tách scene.", Severity.Warning);
        return false;
    }

    private bool EnsureResolutionSelected()
    {
        if (HasProjectResolution)
        {
            return true;
        }

        if (!_promptParseResult.IsJsonValid)
        {
            _promptParseResult = PromptParser.Parse(_prompt);
            ApplyVideoSettingsFromPrompt();
            if (HasProjectResolution)
            {
                return true;
            }
        }

        Snackbar.Add("Vui lòng chọn độ phân giải video trước khi render video.", Severity.Warning);
        return false;
    }

    private static bool IsSupportedAspectRatio(string? value)
        => string.Equals(value, AspectRatioLandscape, StringComparison.Ordinal)
           || string.Equals(value, AspectRatioPortrait, StringComparison.Ordinal);

    private static string? NormalizeAspectRatio(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return null;
        var text = value.Trim();
        return IsSupportedAspectRatio(text) ? text : null;
    }

    private bool IsSupportedResolution(string? value)
        => SupportedVideoResolutions.Any(x => string.Equals(x, NormalizeResolution(value), StringComparison.OrdinalIgnoreCase));

    private static string? NormalizeResolution(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return null;
        return value.Trim().ToLowerInvariant() switch
        {
            "720p" => Resolution720p,
            "1080p" => Resolution1080p,
            "4k" => Resolution4K,
            _ => null
        };
    }

    private static string PersistPromptVideoSettings(string? prompt, string aspectRatio, string resolution)
    {
        var ratio = NormalizeAspectRatio(aspectRatio) ?? AspectRatioPortrait;
        var normalizedResolution = NormalizeResolution(resolution);
        var source = prompt ?? string.Empty;
        if (TryExtractJsonRange(source, out var start, out var end))
        {
            try
            {
                var json = source[start..(end + 1)];
                if (JsonNode.Parse(json) is JsonObject obj)
                {
                    obj["aspect_ratio"] = ratio;
                    if (!string.IsNullOrWhiteSpace(normalizedResolution))
                    {
                        obj["resolution"] = normalizedResolution;
                    }
                    return source[..start] + obj.ToJsonString() + source[(end + 1)..];
                }
            }
            catch (JsonException)
            {
                // Fall through and append a small metadata object.
            }
        }

        var metadata = new JsonObject
        {
            ["aspect_ratio"] = ratio,
            ["resolution"] = normalizedResolution
        }.ToJsonString();
        return string.IsNullOrWhiteSpace(source) ? metadata : $"{source.TrimEnd()}{Environment.NewLine}{metadata}";
    }

    private static bool TryExtractJsonRange(string input, out int start, out int end)
    {
        start = input.IndexOf('{');
        end = input.LastIndexOf('}');
        return start >= 0 && end > start;
    }

    private async Task ReloadJobsAsync()
    {
        if (_projectId is null) return;
        var logCode = BuildLogCode();
        if (string.IsNullOrWhiteSpace(logCode)) return;

        try
        {
            _jobs = (await RenderJobs.ListByLogCodeAsync(logCode)).ToList();
            // Recover batch-active state after a refresh/navigation: the server job keeps running even
            // if this circuit was recreated, so re-derive the shimmer state from the live job list.
            _batchActive = _jobs.Any(j =>
                string.Equals(j.JobType, TodoX.Web.Services.Render.SceneImageBatchRenderHandler.JobTypeName, StringComparison.OrdinalIgnoreCase)
                && j.Status is RenderJobStatuses.Queued or RenderJobStatuses.Preparing or RenderJobStatuses.Rendering or RenderJobStatuses.PostProcessing);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "VIDEO_RENDER_LOAD_JOBS_FAILED logCode={LogCode}", logCode);
            await AddDebugAsync("jobs_failed", "Tải job thất bại", "FAILED", ex.Message, ex.ToString());
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task StartPolling()
    {
        if (_projectId is null)
        {
            StopPolling();
            return;
        }
        _pollCts?.Cancel();
        _pollCts = new CancellationTokenSource();
        _pollTimer?.Dispose();
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(VideoOptions.CurrentValue.PollIntervalSeconds));
        _ = PollLoopAsync(_pollCts.Token);
    }

    private void StopPolling()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollCts = null;
        _pollTimer?.Dispose();
        _pollTimer = null;
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        if (_projectId is null) return;
        while (!ct.IsCancellationRequested && _pollTimer is not null)
        {
            try
            {
                if (!await _pollTimer.WaitForNextTickAsync(ct)) break;
                if (_project is null) continue;

                // Keep polling while a configured image-provider batch is active, scenes are actively rendering/retrying,
                // scenes are still pending an image, or the video pipeline is mid-flight. Stop once everything
                // has settled to avoid churn.
                var hasPendingSceneImages = HasPendingSceneImages();
                var scenesPending = _batchActive || HasActiveSceneRenders();
                var videoActive = _project.Status is VideoProjectStatuses.Rendering or VideoProjectStatuses.Merging;
                if (scenesPending || videoActive)
                {
                    await InvokeAsync(ReloadAsync);
                    // Batch is done when no scene is still waiting for its first image.
                    if (_batchActive && !hasPendingSceneImages)
                    {
                        _batchActive = false;
                    }
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException) when (ct.IsCancellationRequested)
            {
                break;
            }
        }
    }

    private async Task SaveSceneAsync(VideoProjectSceneDto scene)
    {
        if (_projectId is null || AuthState.CurrentUser is null) return;
        var draft = GetSceneDraft(scene);
        var metadata = BuildMetadata(draft);
        scene.ImagePrompt = metadata.ImagePrompt;
        scene.VideoPrompt = metadata.MotionPrompt;
        scene.ScenePrompt = metadata.Serialize();

        await VideoRepo.SaveSceneDraftAsync(new VideoProjectSaveSceneDraftRequest
        {
            SceneId = scene.Id,
            Status = scene.Status,
            Title = scene.Title,
            SceneIndex = scene.SceneIndex,
            ScenePrompt = scene.ScenePrompt,
            ImagePrompt = scene.ImagePrompt,
            VideoPrompt = scene.VideoPrompt,
            ImageUrl = ResolveDraftImageUrl(scene, draft),
            ImagePath = ResolveDraftImagePath(scene, draft),
            VideoUrl = ResolveDraftVideoUrl(scene, draft),
            VideoPath = ResolveDraftVideoPath(scene, draft),
            ErrorMessage = scene.ErrorMessage,
            SelectedImageVersionId = draft.SelectedImageVersionId,
            SelectedVideoVersionId = draft.SelectedVideoVersionId,
            AspectRatio = draft.AspectRatio
        }, AuthState.CurrentUser.UserId);

        draft.IsDirty = false;
        Snackbar.Add("Đã lưu scene.", Severity.Success);
        await LogProjectEvent("SCENE_SAVED", "info", $"Đã lưu scene {scene.SceneIndex}.", new { scene.Id, scene.SceneIndex, scene.Status, draft.SelectedImageVersionId, draft.SelectedVideoVersionId, AspectRatio = draft.AspectRatio });
        await ReloadAsync();
        await ProjectSaved.InvokeAsync();
    }

    private async Task EditScenePromptsAsync(VideoProjectSceneDto scene)
    {
        var parameters = new DialogParameters
        {
            [nameof(Components.Dialogs.ScenePromptEditorDialog.Metadata)] = ScenePromptMetadata.FromScene(scene),
            [nameof(Components.Dialogs.ScenePromptEditorDialog.IsRendering)] = IsSceneRendering(scene) || RenderSceneImageUiState.IsActive(ResolveSceneImageState(scene))
        };
        var options = new DialogOptions { CloseButton = true, FullWidth = true, MaxWidth = MaxWidth.Medium };
        var dialog = await DialogService.ShowAsync<Components.Dialogs.ScenePromptEditorDialog>($"Chỉnh prompt scene {scene.SceneIndex}", parameters, options);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not ScenePromptMetadata metadata)
        {
            return;
        }

        var draft = GetSceneDraft(scene);
        draft.Purpose = metadata.ScenePurpose;
        draft.ImagePrompt = metadata.ImagePrompt;
        draft.MotionPrompt = metadata.MotionPrompt;
        draft.Voice = metadata.Voice;
        draft.VoiceInstruction = metadata.VoiceInstruction;
        draft.IsDirty = true;
        await SaveSceneAsync(scene);
    }

    private static void NormalizeScenePrompts(VideoProjectSceneDto scene)
    {
        var metadata = ScenePromptMetadata.FromScene(scene);
        scene.ImagePrompt = metadata.ImagePrompt;
        scene.VideoPrompt = metadata.MotionPrompt;
        scene.ScenePrompt = metadata.Serialize();
    }

    private async Task SaveJobAsync()
    {
        if (_project is null || AuthState.CurrentUser is null) return;
        if (!EnsureAspectRatioSelected())
        {
            return;
        }

        _busy = true;
        try
        {
            foreach (var scene in _project.Scenes)
            {
                NormalizeScenePrompts(scene);
            }

            _prompt = PersistPromptVideoSettings(_prompt, _aspectRatio, _resolution);
            var snapshot = BuildJobSnapshot();
            await VideoRepo.UpdateProjectDraftAsync(_project.Id, new VideoProjectUpdateRequest
            {
                Title = _project.Title,
                OriginalPrompt = _prompt,
                CharacterId = _selectedCharacter?.Id ?? _selectedCharacterId,
                TotalSeconds = _totalSeconds,
                SceneSeconds = Math.Max(1, _sceneSeconds),
                ThinkScenes = _thinkScenes,
                Scenes = _project.Scenes.OrderBy(x => x.SceneIndex).ToList()
            }, AuthState.CurrentUser);
            await LogProjectEvent("JOB_SAVED", "info", "Lưu video project render-job.", snapshot);
            Snackbar.Add("Đã lưu job.", Severity.Success);
            await ReloadAsync();
            await ProjectSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "VIDEO_RENDER_SAVE_JOB_FAILED projectId={ProjectId}", _project.Id);
            Snackbar.Add(ex.Message, Severity.Error);
            await AddDebugAsync("job_save_failed", "Lưu job thất bại", "FAILED", ex.Message, ex.ToString());
        }
        finally
        {
            _busy = false;
        }
    }

    private object BuildJobSnapshot()
    {
        var scenes = _project?.Scenes
            .OrderBy(x => x.SceneIndex)
            .Select(scene => new
            {
                scene.Id,
                scene.SceneIndex,
                scene.Title,
                scene.DurationSeconds,
                scene.ScenePrompt,
                scene.ImagePrompt,
                scene.VideoPrompt,
                Voice = ExtractValue(scene.ScenePrompt, "voice"),
                VoiceInstruction = ExtractValue(scene.ScenePrompt, "voice_instruction"),
                scene.StaticImageUrl,
                scene.StaticImagePath,
                scene.SceneVideoUrl,
                scene.SceneVideoPath,
                scene.Status,
                scene.ErrorMessage,
                scene.UpdatedAt
            })
            .ToList();

        return new
        {
            ProjectId = _project!.Id,
            _project.Title,
            _project.OriginalPrompt,
            AspectRatio = _aspectRatio,
            Resolution = _resolution,
            _project.CharacterId,
            CharacterName = _selectedCharacter?.CharacterName ?? ResolveCurrentCharacter()?.CharacterName,
            CharacterPrompt = _selectedCharacter?.NormalizedPrompt ?? ResolveCurrentCharacter()?.NormalizedPrompt,
            _project.TotalSeconds,
            _project.SceneSeconds,
            _project.ThinkScenes,
            _project.Status,
            _project.UpdatedAt,
            _project.StorageRoot,
            _project.PublicBase,
            _project.JobFolder,
            Scenes = scenes
        };
    }

    // ------------------------------------------------------------------
    // Bulk scene image render — configured image provider router, background job.
    // ------------------------------------------------------------------
    private async Task EnqueueBulkSceneImageRenderAsync(bool onlyMissingOrFailed)
    {
        if (_project is null || AuthState.CurrentUser is null) return;
        var character = ResolveCurrentCharacter();
        var input = new TodoX.Web.Services.Render.SceneImageBatchInput
        {
            ProjectId = _project.Id,
            AspectRatio = _aspectRatio,
            CharacterId = character?.Id ?? _project.CharacterId,
            UserId = AuthState.CurrentUser.UserId,
            CustomerId = AuthState.CurrentUser.CustomerId,
            CreatedBy = AuthState.CurrentUser.Email ?? AuthState.CurrentUser.UserId.ToString(),
            TrustedPayerContext = TodoX.Web.Services.AiProviders.AiBillingPayerResolver.CreateTrustedBackgroundContext(AuthState.CurrentUser),
            OnlyMissingOrFailed = onlyMissingOrFailed
        };

        var (job, alreadyActive) = await RenderJobs.EnqueueForProjectIfNoneActiveAsync(new RenderJobCreateModel
        {
            JobType = TodoX.Web.Services.Render.SceneImageBatchRenderHandler.JobTypeName,
            UserId = AuthState.CurrentUser.UserId,
            CustomerId = AuthState.CurrentUser.CustomerId,
            Input = input,
            Prompt = new { projectId = _project.Id },
            LogCode = BuildLogCode(),
            ProviderCode = TodoX.Web.Services.Render.SceneImageBatchRenderHandler.RoutingProviderCode,
            ModelCode = TodoX.Web.Services.Render.SceneImageBatchRenderHandler.RoutingModelCode,
            MaxAttempts = 1,
            PointCostEstimate = 0,
            PointStatus = RenderPointStatuses.NotRequired
        }, _project.Id);

        _batchActive = true;
        if (alreadyActive)
        {
            Logger.LogInformation("VIDEO_RENDER_SCENE_IMAGE_BATCH_ALREADY_ACTIVE projectId={ProjectId} jobId={JobId}", _project.Id, job.Id);
            Snackbar.Add("Project này đang có batch tạo ảnh tĩnh.", Severity.Info);
            await StartPolling();
            return;
        }

        Logger.LogInformation("VIDEO_RENDER_SCENE_IMAGE_BATCH_ENQUEUED projectId={ProjectId} jobId={JobId} onlyMissing={OnlyMissing} characterId={CharacterId}",
            _project.Id, job.Id, onlyMissingOrFailed, input.CharacterId);
        await LogProjectEvent("SCENE_IMAGE_BATCH_ENQUEUED", "info", "Đã enqueue batch render ảnh tĩnh qua AI provider đã cấu hình.",
            new { job.Id, onlyMissingOrFailed, input.CharacterId });
        await StartPolling();
    }

    private async Task RenderMissingSceneImagesAsync()
