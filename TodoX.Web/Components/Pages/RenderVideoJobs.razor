    private readonly HashSet<long> _sceneRerendering = new();
    // Per-scene re-render error messages (kept so a failed rerender does not wipe the old image).
    private readonly Dictionary<long, string> _sceneRerenderErrors = new();
    // Transient per-scene render state derived from project events (survives page refresh).
    private readonly Dictionary<long, RenderSceneImageVisualState> _sceneEventState = new();
    private readonly Dictionary<long, IReadOnlyList<TodoX.Web.Services.VideoRender.SceneImageVersionDto>> _imageVersions = new();
    private readonly Dictionary<long, IReadOnlyList<TodoX.Web.Services.VideoRender.SceneVideoVersionDto>> _videoVersions = new();
    private readonly Dictionary<long, SceneEditorState> _sceneDrafts = new();
    private IReadOnlyList<TodoX.Web.Services.VideoRender.FinalVideoVersionDto> _finalVersions = Array.Empty<TodoX.Web.Services.VideoRender.FinalVideoVersionDto>();
    private readonly Dictionary<Guid, IReadOnlyList<TodoX.Web.Services.VideoRender.FinalVideoVersionItemDto>> _finalVersionItems = new();
    private ProviderOptionDto? _defaultImageToVideoProvider;
    private long? _imageHistorySceneId;
    private long? _videoHistorySceneId;
