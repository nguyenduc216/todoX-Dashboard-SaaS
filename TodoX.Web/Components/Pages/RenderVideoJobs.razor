    private async Task OpenProjectAsync(long projectId)
    {
        _projectId = projectId;
        QueryProjectId = projectId;
        _projectDialogOpen = true;
        if (!Embedded)
        {
            Navigation.NavigateTo($"/render-jobs?projectId={projectId}", replace: false);
        }
        await ReloadAsync();
        await StartPolling();
        _tabIndex = 0;
    }

    private async Task CloseProjectDialogAsync()
    {
        _projectDialogOpen = false;
        StopPolling();
        if (Embedded)
        {
            await Closed.InvokeAsync();
        }
        else
        {
            Navigation.NavigateTo("/render-jobs", replace: true);
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadAsync()
    {
        if (_projectId is null) return;
        if (AuthState.CurrentUser is null) return;

        // Guard against overlapping ReloadAsync calls from concurrent polling/UI refresh. Non-blocking: if
        // already reloading, skip this call instead of queueing (the next poll will catch the new state).
        if (!await _reloadLock.WaitAsync(0))
        {
            return;
        }
        try
        {
            try
            {
                _project = await VideoRepo.GetProjectAsync(_projectId.Value, AuthState.CurrentUser);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "VIDEO_RENDER_RELOAD_PROJECT_FAILED projectId={ProjectId}", _projectId);
                throw;
            }
            if (_project is not null)
            {
                _thinkScenes = _project.ThinkScenes;
                _prompt = _project.OriginalPrompt;
                _promptParseResult = PromptParser.Parse(_prompt);
                ApplyVideoSettingsFromPrompt();
                _totalSeconds = _project.TotalSeconds;
                _sceneSeconds = _project.SceneSeconds;
                _selectedCharacterId = _project.CharacterId;
                if (_project.CharacterId is not null)
                {
                    await OnCharacterChangedAsync(_project.CharacterId);
                }
                else
                {
                    await ClearSelectedCharacterAsync();
                }
                ReconcileSceneDrafts();
                RebuildSceneEventState();
                _defaultImageToVideoProvider = await AiProviders.GetDefaultProviderAsync(AiProviderCatalog.ImageToVideo);
                await ReloadJobsAsync();
            }
        }
        finally
        {
            _reloadLock.Release();
        }
    }

    private async Task LoadCharactersAsync()
    {
        if (AuthState.CurrentUser is null) return;
        try
        {
            _characters.Clear();
            var items = await Characters.GetActiveCharactersAsync(AuthState.CurrentUser);
            _characters.AddRange(items);
            if (_selectedCharacterId is not null)
            {
                await OnCharacterChangedAsync(_selectedCharacterId);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "VIDEO_RENDER_LOAD_CHARACTERS_FAILED");
            await AddDebugAsync("character_failed", "Tải nhân vật thất bại", "FAILED", ex.Message, ex.ToString());
        }
    }

    private Task SelectCharacterAsync()
    {
        return InvokeAsync(StateHasChanged);
    }

    private async Task OnCharacterChangedAsync(long? characterId)
    {
        _selectedCharacterId = characterId;
        _selectedCharacter = characterId is null ? null : _characters.FirstOrDefault(x => x.Id == characterId.Value);
        if (_selectedCharacter is null && characterId is long id && AuthState.CurrentUser is not null)
        {
            try
            {
                var detail = await Characters.GetCharacterAsync(AuthState.CurrentUser, id);
                if (detail is not null)
                {
                    _selectedCharacter = new ActiveCharacterDto
                    {
                        Id = detail.Id,
                        CharacterName = detail.CharacterName,
                        Description = detail.Description,
                        StylePreset = detail.StylePreset,
                        Gender = detail.Gender,
                        MasterImageUrl = detail.MasterImageUrl,
                        MasterImageObjectKey = detail.MasterImageObjectKey,
                        NormalizedPrompt = detail.NormalizedPrompt
                    };
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "VIDEO_RENDER_RESOLVE_CHARACTER_FAILED characterId={CharacterId}", id);
            }
        }
        _characterPrompt = _selectedCharacter?.NormalizedPrompt ?? string.Empty;
        await InvokeAsync(StateHasChanged);
    }

    private bool IsCharacterSelected(long characterId) => _selectedCharacter?.Id == characterId;

    private Task ClearSelectedCharacterAsync()
    {
        _selectedCharacterId = null;
        _selectedCharacter = null;
        _characterPrompt = string.Empty;
        return InvokeAsync(StateHasChanged);
    }

    private string ResolveCharacterName(long? characterId)
        => characterId is null ? "Không sử dụng nhân vật" : _characters.FirstOrDefault(x => x.Id == characterId.Value)?.CharacterName ?? characterId.Value.ToString();

    private Task OpenCharacterPreview(ActiveCharacterDto character)
    {
        var parameters = new DialogParameters
        {
            [nameof(Components.Dialogs.ReferenceImageLightboxDialog.Title)] = character.CharacterName,
            [nameof(Components.Dialogs.ReferenceImageLightboxDialog.ImageUrl)] = character.MasterImageUrl,
            [nameof(Components.Dialogs.ReferenceImageLightboxDialog.FileName)] = character.CharacterName
        };
        var options = new DialogOptions { CloseButton = true, FullWidth = true, MaxWidth = MaxWidth.Large };
        _ = DialogService.ShowAsync<Components.Dialogs.ReferenceImageLightboxDialog>(character.CharacterName, parameters, options);
        return Task.CompletedTask;
    }



    private Task OpenScenePreview(VideoProjectSceneDto scene)
    {
        if (string.IsNullOrWhiteSpace(scene.StaticImageUrl)) return Task.CompletedTask;
        var parameters = new DialogParameters
        {
