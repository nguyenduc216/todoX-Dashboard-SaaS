    private async Task RenderSceneImageAsync(VideoProjectSceneDto scene)
    {
        if (_project is null || AuthState.CurrentUser is null) return;

        _busy = true;
        var character = ResolveCurrentCharacter();
        try
        {
            var prompt = BuildSceneRenderPrompt(scene, character);
            var referenceImageUrls = !string.IsNullOrWhiteSpace(character?.MasterImageUrl)
                ? new[] { character!.MasterImageUrl! }
                : Array.Empty<string>();

            await AddDebugAsync("scene_image_render_start", $"Render ảnh scene {scene.SceneIndex}", "INFO", $"Bắt đầu render ảnh cho scene {scene.SceneIndex}.");
            await LogProjectEvent("SCENE_IMAGE_RENDER_START", "info", $"Bắt đầu render ảnh scene {scene.SceneIndex}.", new { projectId = _project.Id, sceneId = scene.Id, sceneIndex = scene.SceneIndex, characterId = character?.Id, referenceCount = referenceImageUrls.Length });

            var render = await ImageRenderRouter.RenderImageAsync(new AiImageRenderRequest
            {
                CustomerId = null,
                UserId = AuthState.CurrentUser.UserId,
                FeatureCode = "render_job_scene_image",
                CapabilityCode = "avatar_generation",
                FromUser = false,
                Prompt = prompt,
                ReferenceImageUrls = referenceImageUrls,
                AspectRatio = "9:16",
                OutputFormat = "png",
                Quality = "high",
                Resolution = "2K",
                FileCategory = "video_scene_image",
                Metadata = new
                {
                    projectId = _project.Id,
                    sceneId = scene.Id,
                    sceneIndex = scene.SceneIndex,
                    characterId = character?.Id,
                    providerCode = "ImageAICreativeRender"
                },
                CreatedBy = AuthState.CurrentUser.Email ?? AuthState.CurrentUser.UserId.ToString()
            });

            if (!render.Success)
            {
                await VideoRepo.UpdateSceneAsync(scene.Id, VideoSceneStatuses.Failed, errorMessage: render.ErrorMessage, title: scene.Title, scenePrompt: scene.ScenePrompt, imagePrompt: scene.ImagePrompt, videoPrompt: scene.VideoPrompt);
                await LogProjectEvent("SCENE_IMAGE_RENDER_FAILED", "error", $"Render ảnh scene {scene.SceneIndex} thất b���i.", new { projectId = _project.Id, sceneId = scene.Id, sceneIndex = scene.SceneIndex, error = render.ErrorMessage, characterId = character?.Id, render.ProviderCode, render.ModelName });
                await AddDebugAsync("scene_image_render_failed", $"Render ảnh scene {scene.SceneIndex} lỗi", "FAILED", render.ErrorMessage ?? "Render không thành công");
                return;
            }

            var saved = await PersistRenderedSceneImageAsync(scene, render);
            await VideoRepo.UpdateSceneAsync(scene.Id, VideoSceneStatuses.ImageReady, imageUrl: saved.ImageUrl, imagePath: saved.ImagePath, errorMessage: null, title: scene.Title, scenePrompt: scene.ScenePrompt, imagePrompt: scene.ImagePrompt, videoPrompt: scene.VideoPrompt);
            if (_project.Scenes.FirstOrDefault(x => x.Id == scene.Id) is { } current)
            {
                current.StaticImageUrl = saved.ImageUrl;
                current.StaticImagePath = saved.ImagePath;
                current.Status = VideoSceneStatuses.ImageReady;
                current.ErrorMessage = null;
                current.UpdatedAt = DateTime.UtcNow;
            }

            await LogProjectEvent("SCENE_IMAGE_READY", "info", $"Scene {scene.SceneIndex} image ready.", new { projectId = _project.Id, sceneId = scene.Id, sceneIndex = scene.SceneIndex, characterId = character?.Id, imageUrl = saved.ImageUrl, providerCode = render.ProviderCode, modelName = render.ModelName });
            await AddDebugAsync("scene_image_rendered", $"Render ảnh scene {scene.SceneIndex} thành công", "SUCCESS", $"ImageUrl={saved.ImageUrl}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "VIDEO_RENDER_SCENE_IMAGE_FAILED projectId={ProjectId} sceneId={SceneId}", _project.Id, scene.Id);
            await VideoRepo.UpdateSceneAsync(scene.Id, VideoSceneStatuses.Failed, errorMessage: ex.Message, title: scene.Title, scenePrompt: scene.ScenePrompt, imagePrompt: scene.ImagePrompt, videoPrompt: scene.VideoPrompt);
            await LogProjectEvent("SCENE_IMAGE_RENDER_FAILED", "error", $"Render ảnh scene {scene.SceneIndex} thất bại.", new { projectId = _project.Id, sceneId = scene.Id, sceneIndex = scene.SceneIndex, error = ex.Message, characterId = character?.Id });
            await AddDebugAsync("scene_image_render_failed", $"Render ảnh scene {scene.SceneIndex} lỗi", "FAILED", ex.Message, ex.ToString());
        }
        finally
        {
            _busy = false;
            await ReloadAsync();
        }
    }

