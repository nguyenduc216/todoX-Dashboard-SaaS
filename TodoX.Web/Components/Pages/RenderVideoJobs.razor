    private static string ShortText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "(trống)";
        var text = value.Trim();
        return text.Length <= 220 ? text : text[..220] + "...";
    }

    private static string FormatMoney(decimal? value)
        => value.HasValue ? value.Value.ToString("0.######") : "N/A";

    private string ProjectCardClass(VideoProjectListItemDto item)
        => $"pa-3 render-project-card {(_projectId == item.Id ? "render-project-card-active" : string.Empty)}";

    private static Color ProjectStatusColor(string status) => status switch
    {
        VideoProjectStatuses.Completed => Color.Success,
        VideoProjectStatuses.Rendering or VideoProjectStatuses.Merging or VideoProjectStatuses.SceneReady or VideoProjectStatuses.ReadyToMerge => Color.Warning,
        VideoProjectStatuses.Failed => Color.Error,
        _ => Color.Default
    };

    // A scene is "pending an image" when it has no successful static image yet and is not in a terminal
    // failed state — i.e. the background batch is expected to still produce it.
    private bool HasPendingSceneImages()
        => _project is not null && _project.Scenes.Any(s =>
               string.IsNullOrWhiteSpace(s.StaticImageUrl)
               && !string.Equals(s.Status, VideoSceneStatuses.Failed, StringComparison.OrdinalIgnoreCase));

    // True when any scene is actively being processed (queued, rendering, or retrying) per events or UI state.
    private bool HasActiveSceneRenders()
        => _sceneEventState.Values.Any(RenderSceneImageUiState.IsActive)
           || _sceneRerendering.Count > 0;

    private RenderSceneImageVisualState ResolveSceneImageState(VideoProjectSceneDto scene)
    {
        // A locally-running OpenRouter re-render always wins for its own scene.
        if (_sceneRerendering.Contains(scene.Id))
        {
            return RenderSceneImageVisualState.Rendering;
        }

        // A scene that already has a valid image is Ready regardless of stale events.
        if (!string.IsNullOrWhiteSpace(scene.StaticImageUrl) && scene.Status != VideoSceneStatuses.Failed)
        {
            return RenderSceneImageVisualState.Ready;
        }

        // Otherwise derive the transient state from the latest batch event for this scene. This is what
        // makes the per-scene state survive a page refresh (state is reconstructed from project events).
        if (_sceneEventState.TryGetValue(scene.Id, out var evState) && evState != RenderSceneImageVisualState.None)
        {
            // A terminal DB status still overrides a stale non-terminal event.
            if (string.Equals(scene.Status, VideoSceneStatuses.Failed, StringComparison.OrdinalIgnoreCase)
                && !RenderSceneImageUiState.IsActive(evState))
            {
                return RenderSceneImageVisualState.Failed;
            }
            return evState;
        }

        if (string.Equals(scene.Status, VideoSceneStatuses.Failed, StringComparison.OrdinalIgnoreCase))
        {
            return RenderSceneImageVisualState.Failed;
        }

        // Fallback while a batch is active but no per-scene event has arrived yet.
        if (_batchActive && string.IsNullOrWhiteSpace(scene.StaticImageUrl))
        {
            return RenderSceneImageVisualState.Queued;
        }

        return RenderSceneImageVisualState.None;
    }

    // Rebuilds the per-scene transient render state from project events (latest event per scene wins).
    // Called on every reload so the UI reflects queued/rendering/retrying/ready/failed accurately and
    // restores correctly after a refresh.
    private void RebuildSceneEventState()
    {
        _sceneEventState.Clear();
        if (_project is null) return;

        // Events are returned newest-first; walk oldest→newest so the last write wins per scene.
        foreach (var ev in _project.Events.OrderBy(x => x.CreatedAt).ThenBy(x => x.Id))
        {
            var sceneId = ExtractSceneId(ev.DataJson);
            if (sceneId is not long id) continue;

            var state = ev.EventType switch
            {
                "SCENE_IMAGE_QUEUED" => RenderSceneImageVisualState.Queued,
                "SCENE_IMAGE_RENDER_START" => RenderSceneImageVisualState.Rendering,
                "SCENE_IMAGE_RETRY_START" => RenderSceneImageVisualState.Rendering,
                "SCENE_IMAGE_QUOTA_WAIT" => RenderSceneImageVisualState.Retrying,
                "SCENE_IMAGE_READY" => RenderSceneImageVisualState.Ready,
                "SCENE_IMAGE_RENDER_FAILED" => RenderSceneImageVisualState.Failed,
                _ => (RenderSceneImageVisualState?)null
            };
            if (state is RenderSceneImageVisualState resolved)
            {
                _sceneEventState[id] = resolved;
            }
        }
    }

    private static long? ExtractSceneId(string? dataJson)
    {
        if (string.IsNullOrWhiteSpace(dataJson)) return null;
        try
        {
            using var doc = JsonDocument.Parse(dataJson);
            if (doc.RootElement.ValueKind == JsonValueKind.Object
                && doc.RootElement.TryGetProperty("sceneId", out var el))
            {
                if (el.ValueKind == JsonValueKind.Number && el.TryGetInt64(out var n)) return n;
                if (el.ValueKind == JsonValueKind.String && long.TryParse(el.GetString(), out var s)) return s;
            }
        }
        catch (JsonException)
        {
            // Ignore malformed event payloads.
        }
        return null;
    }

