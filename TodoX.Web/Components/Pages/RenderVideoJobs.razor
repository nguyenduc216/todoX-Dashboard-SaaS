@page "/render-job"
@using System.Text.Json
@using System.Text.Json.Nodes
@using TodoX.Web.Services.AiProviders
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject TodoX.Web.Services.VideoRender.VideoRenderRepository VideoRepo
@inject TodoX.Web.Services.Render.IRenderJobService RenderJobs
@inject TodoX.Web.Services.Render.ISceneImageRenderService SceneImages
@inject TodoX.Web.Services.AiCharacters.IAiCharacterService Characters
@inject TodoX.Web.Services.VideoRender.ITodoXVideoPromptParser PromptParser
@inject TodoX.Web.Services.AiProviders.IAiImageRenderRouter ImageRenderRouter
@inject TodoX.Web.Services.AiProviders.IAiProviderService AiProviders
@inject TodoX.Web.Services.Media.IMediaFileService MediaFiles
@inject TodoX.Web.Services.VideoRender.ISceneMediaVersioningService SceneVersions
@inject IOptionsMonitor<TodoX.Web.Services.VideoRender.VideoRenderOptions> VideoOptions
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<RenderVideoJobs> Logger
@inject IJSRuntime JS

<PageTitle>Render Video Job</PageTitle>

@if (!Embedded)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Warning" />
}
else
{
<MudStack Spacing="0">
    @if (!AuthState.IsInitialized)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Warning" />
    }
    else if (AuthState.CurrentUser is null)
    {
        <MudAlert Severity="Severity.Warning">Vui lòng đăng nhập.</MudAlert>
    }
    else
    {
        @if (_projectDialogOpen)
        {
            <div class="render-project-dialog" role="dialog" aria-modal="true">
                <div class="render-project-dialog-surface">
                    <header class="render-project-dialog-header">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h6">@(_project?.Title ?? "Render Video Job")</MudText>
                            <MudText Typo="Typo.caption">@ProjectHeaderMeta</MudText>
                        </MudStack>
                        <MudStack Row="true" Spacing="1" Class="flex-wrap gap-1">
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="CloseProjectDialogAsync" />
                        </MudStack>
                    </MudStack>
                    </header>
                    <main class="render-project-dialog-body">
                    <MudTabs Class="render-project-tabs" rounded="true" ApplyEffectsToContainer="true" panelClass="render-tab-panel" @bind-ActivePanelIndex="_tabIndex">
            <MudTabPanel Text="Thông tin">
                <div class="render-tab-scroll render-info-scroll">
                <MudPaper Class="todox-card pa-4" rounded="true">
                    <MudGrid>
                        <MudItem xs="12" md="4">
                            <MudPaper Class="pa-4 d-flex flex-column h-100" Outlined="true" rounded="true">
                                <MudStack Spacing="2" Class="h-100">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
                                        <MudText Typo="Typo.h6">Nhân vật</MudText>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="ClearSelectedCharacterAsync" Disabled="@(_busy || _selectedCharacter is null)">Không sử dụng Character</MudButton>
                                    </MudStack>
                                    <MudAlert Severity="Severity.Info" Dense="true">Chọn một Character hoạt động hoặc để trống để tạo project không dùng Character.</MudAlert>
                                    <MudSelect T="long?" Label="Chọn nhân vật" Value="@(_selectedCharacterId)" ValueChanged="OnCharacterChangedAsync" Variant="Variant.Outlined" Dense="true" ToStringFunc="ResolveCharacterName">
                                        <MudSelectItem T="long?" Value="@((long?)null)">Không sử dụng nhân vật</MudSelectItem>
                                        @foreach (var character in _characters)
                                        {
                                            <MudSelectItem T="long?" Value="@character.Id">@character.CharacterName</MudSelectItem>
                                        }
                                    </MudSelect>
                                    <MudDivider />
                                    @{
                                        var previewCharacter = ResolveCurrentCharacter();
                                    }
                                    @if (previewCharacter is null)
                                    {
                                        <MudPaper Class="pa-4 text-center" Outlined="true" rounded="true">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Chưa chọn nhân vật. Project sẽ được tạo không dùng nhân vật.</MudText>
                                        </MudPaper>
                                    }
                                    else
                                    {
                                        <MudPaper Class="pa-3 selected-character-preview" Outlined="true" rounded="true">
                                            <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Start">
                                                <div class="character-thumb-wrap">
                                                    @if (!string.IsNullOrWhiteSpace(previewCharacter.MasterImageUrl))
                                                    {
                                                        <img src="@previewCharacter.MasterImageUrl" style="width:100%;height:100%;object-fit:cover;border-radius:10px;cursor:pointer" @onclick="@(() => OpenCharacterPreview(previewCharacter))" />
                                                    }
                                                    else
                                                    {
                                                        <MudPaper Class="pa-2 text-center" rounded="true" Outlined="true">No img</MudPaper>
                                                    }
                                                </div>
                                                <MudStack Spacing="1">
                                                    <MudText Typo="Typo.subtitle1">@previewCharacter.CharacterName</MudText>
                                                    @if (!string.IsNullOrWhiteSpace(previewCharacter.Description))
                                                    {
                                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@previewCharacter.Description</MudText>
                                                    }
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Nhấn ảnh để xem lớn.</MudText>
                                                </MudStack>
                                            </MudStack>
                                        </MudPaper>
                                    }
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" md="8">
                            <MudPaper Class="pa-4 h-100" Outlined="true" rounded="true">
                                <MudStack Spacing="2" Class="h-100">
                                    <MudTextField T="string" Label="Prompt video" @bind-Value="_prompt" Variant="Variant.Outlined" Lines="10" Immediate="true" />
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="CheckPromptAsync">Kiểm tra cấu trúc</MudButton>
                                    <MudSelect T="string" Label="Tỷ lệ video của project" Value="@_aspectRatio" ValueChanged="OnAspectRatioChangedAsync" Variant="Variant.Outlined" Dense="true" Required="true">
                                        <MudSelectItem T="string" Value="@string.Empty">Chọn tỷ lệ trước khi tạo scene</MudSelectItem>
                                        <MudSelectItem T="string" Value="@AspectRatioLandscape">16:9 — video ngang</MudSelectItem>
                                        <MudSelectItem T="string" Value="@AspectRatioPortrait">9:16 — video dọc</MudSelectItem>
                                    </MudSelect>
                                    <MudSelect T="string" Label="Độ phân giải video" Value="@_resolution" ValueChanged="OnResolutionChangedAsync" Variant="Variant.Outlined" Dense="true" Required="true">
                                        <MudSelectItem T="string" Value="@string.Empty">Chọn độ phân giải trước khi render video</MudSelectItem>
                                        @foreach (var resolution in SupportedVideoResolutions)
                                        {
                                            <MudSelectItem T="string" Value="@resolution">@resolution</MudSelectItem>
                                        }
                                    </MudSelect>
                                    <MudAlert Severity="@( _promptParseResult.IsJsonValid ? (_promptParseResult.IsTodoXPrompt ? Severity.Success : Severity.Info) : Severity.Warning )" Dense="true">
                                        @(_promptParseResult.IsJsonValid ? (_promptParseResult.IsTodoXPrompt ? "Prompt TodoX hợp lệ." : "Prompt thường.") : "JSON không hợp lệ hoặc chưa parse được.")
                                    </MudAlert>
                                    @if (!string.IsNullOrWhiteSpace(_promptParseResult.ErrorMessage))
                                    {
                                        <MudAlert Severity="Severity.Warning" Dense="true">@_promptParseResult.ErrorMessage</MudAlert>
                                    }
                                    @if (_promptParseResult.Model is not null)
                                    {
                                        <MudGrid>
                                            <MudItem xs="12" md="6"><MudText><b>Tiêu đề video:</b> @_promptParseResult.Summary.VideoTitle</MudText></MudItem>
                                            <MudItem xs="12" md="6"><MudText><b>Mục tiêu video:</b> @_promptParseResult.Summary.VideoObjective</MudText></MudItem>
                                            <MudItem xs="12" md="6"><MudText><b>Phong cách:</b> @_promptParseResult.Summary.Style</MudText></MudItem>
                                            <MudItem xs="12" md="6"><MudText><b>CTA:</b> @_promptParseResult.Summary.Cta</MudText></MudItem>
                                            <MudItem xs="12" md="6"><MudText><b>DeclaredDuration:</b> @_promptParseResult.Summary.DeclaredDurationSeconds</MudText></MudItem>
                                            <MudItem xs="12" md="6"><MudText><b>SceneCount:</b> @_promptParseResult.Summary.SceneCount</MudText></MudItem>
                                            <MudItem xs="12" md="6"><MudText><b>Tỷ lệ video:</b> @(ProjectAspectRatio)</MudText></MudItem>
                                            <MudItem xs="12" md="6"><MudText><b>Độ phân giải:</b> @(ProjectResolution)</MudText></MudItem>
                                        </MudGrid>
                                        @if (_promptParseResult.Summary.HasDurationMismatch)
                                        {
                                            <MudAlert Severity="Severity.Warning" Dense="true">@_promptParseResult.Summary.DurationMismatchMessage</MudAlert>
                                        }
                                    }
                                    <MudGrid>
                                        <MudItem xs="12" md="4"><MudNumericField T="int" Label="Tổng số giây" @bind-Value="_totalSeconds" Min="1" Variant="Variant.Outlined" /></MudItem>
                                        <MudItem xs="12" md="4"><MudNumericField T="int" Label="Giây mỗi scene" @bind-Value="_sceneSeconds" Min="1" Variant="Variant.Outlined" /></MudItem>
                                        <MudItem xs="12" md="4"><MudCheckBox @bind-Value="_thinkScenes" Label="Suy nghĩ kịch bản" /></MudItem>
                                    </MudGrid>
                                    <MudStack Row="true" Spacing="2" Class="flex-wrap gap-2">
                                        <MudButton Color="Color.Warning" Variant="Variant.Filled" OnClick="CreateProjectAsync" Disabled="@_busy">Tạo / phân tách scene</MudButton>
                                        <MudButton Color="Color.Primary" Variant="Variant.Outlined" OnClick="CreateEmptyProjectAsync" Disabled="@_busy">Tạo project rỗng</MudButton>
                                        <MudButton Color="Color.Primary" Variant="Variant.Outlined" OnClick="ReloadAsync" Disabled="@(_projectId is null || _busy)">Refresh</MudButton>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12">
                            <MudPaper Class="todox-card pa-4 mt-3" rounded="true">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
                                    <MudText Typo="Typo.h6">Nhật ký phân tách scene</MudText>
                                    <MudStack Row="true" Spacing="1" Class="flex-wrap gap-2">
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="ClearDebugLogAsync">Xóa log</MudButton>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="CopyDebugLogAsync">Sao chép log</MudButton>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="DownloadDebugLogAsync">Tải log .txt</MudButton>
                                    </MudStack>
                                </MudStack>
                                <MudDivider Class="my-2" />
                                <div id="render-job-debug-log" style="max-height:260px;overflow:auto;display:flex;flex-direction:column-reverse;gap:8px;">
                                    @if (_debugEntries.Count == 0)
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Chưa có log.</MudText>
                                    }
                                    else
                                    {
                                        @foreach (var entry in _debugEntries.OrderByDescending(x => x.StepNumber).ThenByDescending(x => x.Timestamp))
                                        {
                                            <MudPaper Class="pa-3" Outlined="true">
                                                <MudStack Spacing="1">
                                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="flex-wrap gap-2">
                                                        <MudText Typo="Typo.subtitle2">Bước @entry.StepNumber - @entry.StepName</MudText>
                                                        <MudChip T="string" Color="@LogColor(entry.Status)">@entry.Status</MudChip>
                                                    </MudStack>
                                                    <MudText Typo="Typo.caption">@entry.Timestamp.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss.fff") • @entry.StepCode • @entry.DurationMs ms</MudText>
                                                    <MudText Typo="Typo.body2">@entry.Message</MudText>
                                                    @if (!string.IsNullOrWhiteSpace(entry.Details))
                                                    {
                                                        <pre style="white-space:pre-wrap;margin:0">@entry.Details</pre>
                                                    }
                                                </MudStack>
                                            </MudPaper>
                                        }
                                    }
                                </div>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
                </div>
            </MudTabPanel>

            <MudTabPanel Text="Scene / Hình ảnh">
                <div class="scene-image-tab">
                    @if (_project is null)
                    {
                        <MudAlert Severity="Severity.Info">Hãy tạo project ở tab Thông tin trước.</MudAlert>
                    }
                    else
                    {
                        <div class="scene-image-toolbar" role="toolbar" aria-label="Thao tác Scene / Hình ảnh">
                            @if (_batchActive)
                            {
                                <MudChip T="string" Color="Color.Warning" Icon="@Icons.Material.Filled.HourglassBottom">Đang tạo ảnh tĩnh qua AI provider đã cấu hình...</MudChip>
                            }
                            <MudTooltip Text="Tạo ảnh tĩnh cho các scene còn thiếu hoặc lỗi">
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.AddPhotoAlternate" OnClick="RenderMissingSceneImagesAsync" Disabled="@_batchActive">Tạo ảnh còn thiếu</MudButton>
                            </MudTooltip>
                            <MudTooltip Text="Thêm scene thủ công">
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AddSceneAsync" Disabled="@_busy">Thêm scene</MudButton>
                            </MudTooltip>
                            <MudTooltip Text="Chuyển sang tab Video">
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward" OnClick="@(() => _tabIndex = 2)">Tiếp tục tạo video</MudButton>
                            </MudTooltip>
                            <MudTooltip Text="Tải lại scene">
                                <MudIconButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" Icon="@Icons.Material.Filled.Refresh" OnClick="ReloadAsync" Disabled="@_busy" aria-label="Refresh scene" />
                            </MudTooltip>
                        </div>

                        <div class="scene-list-scroll" tabindex="0">
                        <MudStack Spacing="3">
                        @foreach (var scene in _project.Scenes.OrderBy(x => x.SceneIndex))
                        {
                            var draft = GetSceneDraft(scene);
                            var sceneState = ResolveSceneImageState(scene);
                            <MudPaper Class="scene-card scene-card-compact pa-3" Outlined="true">
                                <MudStack Spacing="2">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="scene-card-header flex-wrap gap-1">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.subtitle1" Class="scene-card-title">Scene @scene.SceneIndex.ToString("00") - @scene.Title</MudText>
                                            <MudText Typo="Typo.caption">@scene.DurationSeconds giây</MudText>
                                        </MudStack>
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="scene-card-meta flex-wrap gap-1">
                                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@ProjectAspectRatio</MudChip>
                                            @if (draft.IsDirty)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Chưa lưu</MudChip>
                                            }
                                            <MudChip T="string" Color="@SceneColor(scene.Status)">@SceneLabel(scene.Status)</MudChip>
                                            <MudMenu Dense="true" Icon="@Icons.Material.Filled.MoreVert">
                                                <MudMenuItem Icon="@Icons.Material.Filled.Save" Disabled="@_busy" OnClick="@(() => SaveSceneAsync(scene))">Lưu scene</MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.AddPhotoAlternate" Disabled="@IsSceneRendering(scene)" OnClick="@(() => RerenderSceneImageAsync(scene))">@(string.IsNullOrWhiteSpace(ResolveDraftImageUrl(scene, draft)) ? "Tạo ảnh" : "Render lại ảnh")</MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => EditScenePromptsAsync(scene))">Chỉnh sửa prompt ảnh</MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.History" OnClick="@(() => ToggleImageHistoryAsync(scene))">Lịch sử ảnh</MudMenuItem>
                                                <MudDivider />
                                                <MudMenuItem Icon="@Icons.Material.Filled.KeyboardArrowUp" Disabled="@(_busy || scene.SceneIndex <= 1)" OnClick="@(() => MoveSceneUpAsync(scene))">Lên</MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.KeyboardArrowDown" Disabled="@(_busy || _project is null || scene.SceneIndex >= _project.Scenes.Count)" OnClick="@(() => MoveSceneDownAsync(scene))">Xuống</MudMenuItem>
                                                <MudDivider />
                                                <MudMenuItem Icon="@Icons.Material.Filled.Delete" Disabled="@_busy" OnClick="@(() => DeleteSceneAsync(scene))">Xóa</MudMenuItem>
                                            </MudMenu>
                                        </MudStack>
                                    </MudStack>

                                    <div class="scene-workflow">
                                        <div class="scene-workflow-cell scene-image-column">
                                            <MudText Typo="Typo.subtitle2">Khung ảnh</MudText>
                                            @RenderSceneImageFrame(scene, sceneState, draft)
                                        </div>
                                        <div class="scene-workflow-cell scene-details-column">
                                            <div class="scene-prompt-panel">
                                                <MudTextField T="string" Label="Prompt ảnh" Value="@draft.ImagePrompt" ValueChanged="@((string? value) => UpdateDraft(scene.Id, d => d.ImagePrompt = value))" Variant="Variant.Outlined" Lines="5" Immediate="true" />
                                                @if (_sceneRerenderErrors.TryGetValue(scene.Id, out var sceneErr) && !string.IsNullOrWhiteSpace(sceneErr))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Error">@sceneErr</MudText>
                                                }
                                            </div>
                                            <div class="scene-voice-row">
                                                <MudTextField T="string" Label="Purpose" Value="@draft.Purpose" ValueChanged="@((string? value) => UpdateDraft(scene.Id, d => d.Purpose = value))" Variant="Variant.Outlined" Lines="1" Immediate="true" />
                                                <MudTextField T="string" Label="Voice" Value="@draft.Voice" ValueChanged="@((string? value) => UpdateDraft(scene.Id, d => d.Voice = value))" Variant="Variant.Outlined" Lines="1" Immediate="true" />
                                                <MudTextField T="string" Label="Voice instruction" Value="@draft.VoiceInstruction" ValueChanged="@((string? value) => UpdateDraft(scene.Id, d => d.VoiceInstruction = value))" Variant="Variant.Outlined" Lines="1" Immediate="true" />
                                            </div>
                                        </div>
                                    </div>

                                    @if (_imageHistorySceneId == scene.Id)
                                    {
                                        @RenderImageHistoryPanel(scene)
                                    }
                                </MudStack>
                            </MudPaper>
                        }
                        </MudStack>
                        </div>
                    }
                </div>
            </MudTabPanel>

            <MudTabPanel Text="Video">
                <div class="scene-video-tab">
                    @if (_project is null)
                    {
                        <div class="render-tab-scroll">
                            <MudAlert Severity="Severity.Info">Hãy tạo project ở tab Thông tin trước.</MudAlert>
                        </div>
                    }
                    else
                    {
                    <MudStack Row="true" Spacing="2" Class="flex-wrap gap-2 mb-3">
                        <MudChip T="string" Color="Color.Info">Tổng scene: @_project.Scenes.Count</MudChip>
                        <MudChip T="string" Color="Color.Success">Đủ ảnh: @_project.Scenes.Count(x => !string.IsNullOrWhiteSpace(x.StaticImageUrl))</MudChip>
                        <MudChip T="string" Color="Color.Warning">Đang render: @_project.Scenes.Count(x => x.Status is VideoSceneStatuses.VideoQueued or VideoSceneStatuses.VideoRendering)</MudChip>
                        <MudChip T="string" Color="Color.Success">Hoàn tất: @_project.Scenes.Count(x => !string.IsNullOrWhiteSpace(x.SceneVideoUrl))</MudChip>
                        <MudChip T="string" Color="Color.Error">Lỗi: @_project.Scenes.Count(x => x.Status == VideoSceneStatuses.Failed)</MudChip>
                        <MudTooltip Text="@BulkSceneVideoDisabledReason()"><MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="EnqueueRenderAllScenesAsync" Disabled="@(!CanEnqueueSceneVideos())">Render video còn thiếu</MudButton></MudTooltip>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ReloadAsync" Disabled="@_busy">Refresh</MudButton>
                    </MudStack>

                    <div class="render-tab-scroll scene-video-scroll">
                    <div class="scene-video-grid">
                        @foreach (var scene in _project.Scenes.OrderBy(x => x.SceneIndex))
                        {
                            var draft = GetSceneDraft(scene);
                            <MudPaper Class="scene-card scene-card-compact scene-video-card pa-3" Outlined="true">
                                <MudStack Spacing="2">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="scene-card-header flex-wrap gap-1">
                                        <MudText Typo="Typo.subtitle1" Class="scene-card-title">Scene @scene.SceneIndex.ToString("00") - @scene.Title</MudText>
                                        <MudChip T="string" Color="@SceneColor(scene.Status)">@SceneLabel(scene.Status)</MudChip>
                                    </MudStack>
                                    @RenderSceneVideoFrame(scene, draft)
                                    <MudStack Row="true" Spacing="1" Class="scene-card-meta flex-wrap gap-1">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@ProjectAspectRatio</MudChip>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@ProjectResolution</MudChip>
                                        <MudChip T="string" Size="Size.Small">@scene.DurationSeconds giây</MudChip>
                                    </MudStack>
                                    <MudTextField T="string" Label="Prompt video" Value="@draft.MotionPrompt" ValueChanged="@((string? value) => UpdateDraft(scene.Id, d => d.MotionPrompt = value))" Variant="Variant.Outlined" Lines="4" Immediate="true" />
                                    <MudStack Row="true" Spacing="1" Class="flex-wrap gap-1">
                                        <MudTooltip Text="@SceneVideoDisabledReason(scene, draft)">
                                            <MudButton Size="Size.Small" Variant="Variant.Outlined" Disabled="@(!CanCreateSceneVideo(scene, draft))" OnClick="@(() => RenderSceneVideoAsync(scene))">Tạo video</MudButton>
                                        </MudTooltip>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" OnClick="@(() => ToggleVideoHistoryAsync(scene))">Lịch sử video</MudButton>
                                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => SaveSceneAsync(scene))" Disabled="@_busy">Lưu scene</MudButton>
                                    </MudStack>
                                    @if (_videoHistorySceneId == scene.Id)
                                    {
                                        @RenderVideoHistoryPanel(scene)
                                    }
                                </MudStack>
                            </MudPaper>
                        }
                    </div>
                    </div>
                    }
                </div>
            </MudTabPanel>

            <MudTabPanel Text="Kết quả">
                <div class="render-tab-scroll render-result-scroll">
                    @if (_project is null)
                    {
                        <MudAlert Severity="Severity.Info">Chưa có project.</MudAlert>
                    }
                    else
                    {
                    <MudPaper Class="todox-card pa-4" rounded="true">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6">@(_project.Title ?? "Video project")</MudText>
                            <MudText>Trạng thái: @_project.Status</MudText>
                            <MudText>Final video: @_project.FinalVideoUrl</MudText>
                            <MudStack Row="true" Spacing="2" Class="flex-wrap gap-2">
                                <MudTooltip Text="Ghép các scene video đang được chọn thành final video"><MudButton Color="Color.Warning" Variant="Variant.Filled" OnClick="EnqueueMergeAsync" Disabled="@(!CanMerge)">Tạo video kết quả</MudButton></MudTooltip>
                                <MudButton Color="Color.Primary" Variant="Variant.Outlined" OnClick="ReloadAsync">Refresh</MudButton>
                                <MudButton Color="Color.Info" Variant="Variant.Outlined" OnClick="ToggleFinalHistoryAsync">Lịch sử video hoàn chỉnh</MudButton>
                            </MudStack>
                            @if (!string.IsNullOrWhiteSpace(_project.FinalVideoUrl))
                            {
                                <video src="@_project.FinalVideoUrl" controls style="width:100%;border-radius:12px"></video>
                            }
                            @if (_showFinalHistory)
                            {
                                @RenderFinalHistoryPanel()
                            }
                        </MudStack>
                    </MudPaper>

                    <MudPaper Class="todox-card pa-4 mt-4" rounded="true">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
                            <MudText Typo="Typo.h6">Log thao tác</MudText>
                            <MudStack Row="true" Spacing="1" Class="flex-wrap gap-1">
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="ReloadAsync">Refresh log</MudButton>
                            </MudStack>
                        </MudStack>
                        <MudDivider Class="my-2" />
                        <div class="video-render-log-panel">
                            @foreach (var log in _project.Events.Take(50))
                            {
                                <MudPaper Class="pa-3 mb-2" rounded="true" Outlined="true">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="flex-wrap gap-1">
                                            <MudChip T="string" Size="Size.Small" Color="@LogColor(log.Level)">@log.Level</MudChip>
                                            <MudText Typo="Typo.subtitle2">@log.EventType</MudText>
                                            <MudText Typo="Typo.caption">@log.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</MudText>
                                        </MudStack>
                                        <MudText>@log.Message</MudText>
                                        @if (!string.IsNullOrWhiteSpace(log.DataJson))
                                        {
                                            <pre style="white-space:pre-wrap;margin:0">@log.DataJson</pre>
                                        }
                                    </MudStack>
                                </MudPaper>
                            }
                        </div>
                    </MudPaper>

                    <MudPaper Class="todox-card pa-4 mt-4" rounded="true">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
                            <MudText Typo="Typo.h6">Lịch sử tác vụ xử lý</MudText>
                            <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="ReloadJobsAsync">Refresh jobs</MudButton>
                        </MudStack>
                        <MudDivider Class="my-2" />
                        @if (_jobs.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info">Chưa có job nào cho project này.</MudAlert>
                        }
                        else
                        {
                            <MudTable Items="_jobs" Dense="true" Hover="true">
                                <HeaderContent>
                                    <MudTh>Job</MudTh>
                                    <MudTh>Type</MudTh>
                                    <MudTh>Status</MudTh>
                                    <MudTh>Provider / Model</MudTh>
                                    <MudTh>Thời gian</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Job">@context.Id</MudTd>
                                    <MudTd DataLabel="Type">@context.JobType</MudTd>
                                    <MudTd DataLabel="Status"><MudChip T="string" Color="@JobColor(context.Status)">@context.Status</MudChip></MudTd>
                                    <MudTd DataLabel="Provider / Model">@context.ProviderCode / @context.ModelCode</MudTd>
                                    <MudTd DataLabel="Thời gian">@context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudPaper>
                    }
                </div>
            </MudTabPanel>
                    </MudTabs>
                    </main>
                    <div class="render-project-dialog-footer">
                        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveJobAsync" Disabled="@(_projectId is null || _busy)">Lưu project</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Close" OnClick="CloseProjectDialogAsync">Đóng</MudButton>
                    </div>
                </div>
            </div>
        }
    }
</MudStack>
}

@code {
    [SupplyParameterFromQuery(Name = "projectId")]
    public long? QueryProjectId { get; set; }

