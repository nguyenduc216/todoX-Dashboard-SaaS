    private async Task<(string ImageUrl, string? ImagePath)> PersistRenderedSceneImageAsync(VideoProjectSceneDto scene, AiImageRenderResult result)
    {
        if (result.ImageBytes is null || result.ImageBytes.Length == 0)
        {
            throw new InvalidOperationException("AI render không trả về bytes ảnh.");
        }

        var projectFolder = Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", "uploads", "video-render", _project!.Id.ToString(), $"scene_{scene.SceneIndex:00}");
        Directory.CreateDirectory(projectFolder);
        var fileName = $"scene_{scene.SceneIndex:00}_{DateTime.UtcNow:yyyyMMddHHmmss}.png";
        var imagePath = Path.Combine(projectFolder, fileName);
        await File.WriteAllBytesAsync(imagePath, result.ImageBytes);
        var relative = Path.GetRelativePath(Path.Combine(Directory.GetCurrentDirectory(), "wwwroot"), imagePath).Replace(Path.DirectorySeparatorChar, '/');
        return ($"/{relative}", imagePath);
    }

    private static string BuildSceneRenderPrompt(VideoProjectSceneDto scene, ActiveCharacterDto? character)
    {
        var basePrompt = string.IsNullOrWhiteSpace(scene.ImagePrompt) ? scene.ScenePrompt : scene.ImagePrompt;
        if (character is null || string.IsNullOrWhiteSpace(character.NormalizedPrompt))
        {
            return basePrompt;
        }

        return $"Render a static image for this scene. Scene description: {basePrompt}. Keep the character identity consistent with this character description: {character.NormalizedPrompt}.";
    }

    private async Task MoveSceneUpAsync(VideoProjectSceneDto scene)
    {
        if (_project is null || scene.SceneIndex <= 1) return;
        var previous = _project.Scenes.FirstOrDefault(x => x.SceneIndex == scene.SceneIndex - 1);
        if (previous is null) return;
        (scene.SceneIndex, previous.SceneIndex) = (previous.SceneIndex, scene.SceneIndex);
        await VideoRepo.ReplaceScenesAsync(_project.Id, _project.Scenes.OrderBy(x => x.SceneIndex).ToList(), default);
        await ReloadAsync();
    }

    private async Task MoveSceneDownAsync(VideoProjectSceneDto scene)
    {
        if (_project is null || scene.SceneIndex >= _project.Scenes.Count) return;
        var next = _project.Scenes.FirstOrDefault(x => x.SceneIndex == scene.SceneIndex + 1);
        if (next is null) return;
        (scene.SceneIndex, next.SceneIndex) = (next.SceneIndex, scene.SceneIndex);
        await VideoRepo.ReplaceScenesAsync(_project.Id, _project.Scenes.OrderBy(x => x.SceneIndex).ToList(), default);
        await ReloadAsync();
    }

    private async Task DeleteSceneAsync(VideoProjectSceneDto scene)
    {
        if (_project is null) return;
        var remaining = _project.Scenes.Where(x => x.Id != scene.Id).OrderBy(x => x.SceneIndex).ToList();
        for (var index = 0; index < remaining.Count; index++)
        {
            remaining[index].SceneIndex = index + 1;
        }
        await VideoRepo.ReplaceScenesAsync(_project.Id, remaining, default);
        await ReloadAsync();
    }

    private async Task RenderSceneVideoAsync(VideoProjectSceneDto scene)
    {
        if (_project is null) return;
        var sceneDir = Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", "uploads", "video-render", _project.Id.ToString(), $"scene_{scene.SceneIndex:00}");
        Directory.CreateDirectory(sceneDir);
        var mockPath = Path.Combine(sceneDir, "scene.mp4");
        var mockSource = Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", "uploads", "video-render", "mock-scene.mp4");
        if (!File.Exists(mockSource))
        {
            Snackbar.Add("Thiếu file mock scene video. Hãy cấu hình VideoRender:MockSceneVideoPath.", Severity.Error);
            return;
        }
        File.Copy(mockSource, mockPath, true);
        var relative = Path.GetRelativePath(Path.Combine(Directory.GetCurrentDirectory(), "wwwroot"), mockPath).Replace(Path.DirectorySeparatorChar, '/');
        var url = "/" + relative;
        await VideoRepo.UpdateSceneAsync(scene.Id, VideoSceneStatuses.VideoReady, videoUrl: url, videoPath: mockPath, errorMessage: null, title: scene.Title, scenePrompt: scene.ScenePrompt, imagePrompt: scene.ImagePrompt, videoPrompt: scene.VideoPrompt);
        await VideoRepo.AddProjectEventAsync(_project.Id, "SCENE_VIDEO_READY", "info", $"Scene {scene.SceneIndex} video ready.", new { scene.Id, url });
        await LogProjectEvent("SCENE_VIDEO_RENDERED", "info", $"Render video mock cho scene {scene.SceneIndex}.", new { scene.Id, url, mockPath });
        await ReloadAsync();
    }

