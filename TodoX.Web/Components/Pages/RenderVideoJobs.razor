    }

    // ------------------------------------------------------------------
    // Per-scene re-render — configured routed image provider only.
    // ------------------------------------------------------------------
    private async Task RerenderSceneImageAsync(VideoProjectSceneDto scene)
    {
        if (_project is null || AuthState.CurrentUser is null) return;
        if (!EnsureAspectRatioSelected())
        {
            return;
        }
        var draft = GetSceneDraft(scene);
        if (string.IsNullOrWhiteSpace(draft.ImagePrompt))
        {
            Snackbar.Add("Cần nhập prompt ảnh trước khi render.", Severity.Warning);
            return;
        }
        if (!_sceneRerendering.Add(scene.Id)) return; // already running for this scene

        _sceneRerenderErrors.Remove(scene.Id);
        var character = ResolveCurrentCharacter();
        var previousImageUrl = scene.StaticImageUrl;
        var previousImagePath = scene.StaticImagePath;
        var previousStatus = scene.Status;
        await InvokeAsync(StateHasChanged);

        try
        {
            var promptScene = new VideoProjectSceneDto
            {
                Id = scene.Id,
                ProjectId = scene.ProjectId,
                SceneIndex = scene.SceneIndex,
                Title = scene.Title,
                DurationSeconds = scene.DurationSeconds,
                ScenePrompt = BuildMetadata(draft).Serialize(),
                ImagePrompt = draft.ImagePrompt,
                VideoPrompt = draft.MotionPrompt
            };
            var prompt = TodoX.Web.Services.Render.SceneImagePromptBuilder.Build(promptScene, character?.NormalizedPrompt);
            await LogProjectEvent("SCENE_IMAGE_RERENDER_START", "info", $"Render lại ảnh scene {scene.SceneIndex} qua OpenRouter.",
                new { projectId = _project.Id, sceneId = scene.Id, sceneIndex = scene.SceneIndex, characterId = character?.Id });

            var outcome = await SceneImages.RerenderSceneImageWithOpenRouterAsync(new TodoX.Web.Services.Render.SceneImageRenderContext
            {
                ProjectId = _project.Id,
                SceneId = scene.Id,
                SceneIndex = scene.SceneIndex,
                Prompt = prompt,
                AspectRatio = _aspectRatio,
                CharacterId = character?.Id,
                UserId = AuthState.CurrentUser.UserId,
                CustomerId = AuthState.CurrentUser.CustomerId,
                CreatedBy = AuthState.CurrentUser.Email ?? AuthState.CurrentUser.UserId.ToString(),
                CharacterReferenceUrl = character?.MasterImageUrl
            });

            if (!outcome.Success || string.IsNullOrWhiteSpace(outcome.ImageUrl))
            {
                // Giữ lại ảnh cũ nếu có; chỉ hiển thị lỗi riêng cho scene.
                _sceneRerenderErrors[scene.Id] = outcome.Error ?? "Render lại ảnh scene thất bại.";
                await LogProjectEvent("SCENE_IMAGE_RERENDER_FAILED", "error", $"Render lại ảnh scene {scene.SceneIndex} thất bại.",
                    new { projectId = _project.Id, sceneId = scene.Id, sceneIndex = scene.SceneIndex, error = outcome.Error, providerCode = outcome.ProviderCode, providerCapabilityId = outcome.ProviderCapabilityId, modelName = outcome.ModelName });
                Snackbar.Add(_sceneRerenderErrors[scene.Id], Severity.Error);
                return;
            }

            await VideoRepo.UpdateSceneAsync(scene.Id, VideoSceneStatuses.ImageReady,
                imageUrl: outcome.ImageUrl, imagePath: outcome.ObjectKey, errorMessage: null,
                title: scene.Title, scenePrompt: scene.ScenePrompt, imagePrompt: scene.ImagePrompt, videoPrompt: scene.VideoPrompt);
            if (_project.Scenes.FirstOrDefault(x => x.Id == scene.Id) is { } current)
            {
                current.StaticImageUrl = outcome.ImageUrl;
                current.StaticImagePath = outcome.ObjectKey;
                current.Status = VideoSceneStatuses.ImageReady;
                current.ErrorMessage = null;
                current.UpdatedAt = DateTime.UtcNow;
            }

            await LogProjectEvent("SCENE_IMAGE_RERENDER_DONE", "info", $"Scene {scene.SceneIndex} đã render lại ảnh.",
                new { projectId = _project.Id, sceneId = scene.Id, sceneIndex = scene.SceneIndex, characterId = character?.Id, providerCode = outcome.ProviderCode, providerCapabilityId = outcome.ProviderCapabilityId, modelName = outcome.ModelName, imageUrl = outcome.ImageUrl });
            Snackbar.Add($"Đã render lại ảnh scene {scene.SceneIndex}.", Severity.Success);
        }
        catch (Exception ex)
        {
            // Không đổi ảnh cũ khi lỗi; chỉ ghi nhận lỗi riêng của scene.
            _sceneRerenderErrors[scene.Id] = ex.Message;
            scene.StaticImageUrl = previousImageUrl;
            scene.StaticImagePath = previousImagePath;
            scene.Status = previousStatus;
            Logger.LogError(ex, "VIDEO_RENDER_SCENE_RERENDER_FAILED projectId={ProjectId} sceneId={SceneId}", _project.Id, scene.Id);
            await LogProjectEvent("SCENE_IMAGE_RERENDER_FAILED", "error", $"Render lại ảnh scene {scene.SceneIndex} lỗi.",
                new { projectId = _project.Id, sceneId = scene.Id, sceneIndex = scene.SceneIndex, error = ex.Message });
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _sceneRerendering.Remove(scene.Id);
            await InvokeAsync(StateHasChanged);
        }
    }

