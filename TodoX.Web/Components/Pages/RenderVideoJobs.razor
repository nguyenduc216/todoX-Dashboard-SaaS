    // Polling guard: prevents overlapping ReloadAsync calls.
    private readonly SemaphoreSlim _reloadLock = new(1, 1);
    // True while a background scene image batch job for this project is queued/rendering.
    private bool _batchActive;

    private sealed class SceneEditorState
    {
        public long SceneId { get; init; }
        public string? Purpose { get; set; }
        public string? ImagePrompt { get; set; }
