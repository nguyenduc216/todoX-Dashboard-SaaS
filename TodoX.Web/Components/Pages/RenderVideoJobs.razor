    private SceneEditorState GetSceneDraft(VideoProjectSceneDto scene)
    {
        if (_sceneDrafts.TryGetValue(scene.Id, out var draft))
        {
            return draft;
        }

        draft = CreateSceneDraft(scene);
        _sceneDrafts[scene.Id] = draft;
        return draft;
    }

    private SceneEditorState CreateSceneDraft(VideoProjectSceneDto scene)
    {
        var metadata = ScenePromptMetadata.FromScene(scene);
        return new SceneEditorState
        {
            SceneId = scene.Id,
            Purpose = metadata.ScenePurpose,
            ImagePrompt = metadata.ImagePrompt,
            MotionPrompt = metadata.MotionPrompt,
            Voice = metadata.Voice,
            VoiceInstruction = metadata.VoiceInstruction,
            AspectRatio = HasProjectAspectRatio ? _aspectRatio : AspectRatioPortrait
        };
    }

    private void ReconcileSceneDrafts()
    {
        if (_project is null) return;
        var sceneIds = _project.Scenes.Select(x => x.Id).ToHashSet();
        foreach (var staleId in _sceneDrafts.Keys.Where(id => !sceneIds.Contains(id)).ToList())
        {
            _sceneDrafts.Remove(staleId);
        }

        foreach (var scene in _project.Scenes)
        {
            if (!_sceneDrafts.TryGetValue(scene.Id, out var draft) || !draft.IsDirty)
            {
                _sceneDrafts[scene.Id] = CreateSceneDraft(scene);
            }
        }
    }

    private void UpdateDraft(long sceneId, Action<SceneEditorState> update)
    {
        if (_project?.Scenes.FirstOrDefault(x => x.Id == sceneId) is not { } scene) return;
        var draft = GetSceneDraft(scene);
        update(draft);
        draft.IsDirty = true;
    }

    private static ScenePromptMetadata BuildMetadata(SceneEditorState draft)
        => new()
        {
            ScenePurpose = TrimOrNull(draft.Purpose),
            ImagePrompt = TrimOrNull(draft.ImagePrompt),
            MotionPrompt = TrimOrNull(draft.MotionPrompt),
            Voice = TrimOrNull(draft.Voice),
            VoiceInstruction = TrimOrNull(draft.VoiceInstruction)
        };

    private static string? TrimOrNull(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

