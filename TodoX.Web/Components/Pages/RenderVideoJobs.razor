@page "/render-job"
@using System.Text.Json
@using TodoX.Web.Services.AiProviders
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject TodoX.Web.Services.VideoRender.VideoRenderRepository VideoRepo
@inject TodoX.Web.Services.Render.IRenderJobService RenderJobs
@inject TodoX.Web.Services.AiCharacters.IAiCharacterService Characters
@inject TodoX.Web.Services.VideoRender.ITodoXVideoPromptParser PromptParser
@inject TodoX.Web.Services.AiProviders.IAiImageRenderRouter ImageRenderRouter
@inject TodoX.Web.Services.Media.IMediaFileService MediaFiles
@inject IOptionsMonitor<TodoX.Web.Services.VideoRender.VideoRenderOptions> VideoOptions
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<RenderVideoJobs> Logger
@inject IJSRuntime JS

<PageTitle>Render Video Job</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-3">
        <div>
            <MudText Typo="Typo.h4" Class="todox-page-title">Render Video Job</MudText>
            <MudText Typo="Typo.body1" Class="todox-page-subtitle">Phase 1: chọn nhân vật chuẩn, tạo project rỗng hoặc tách scene, rồi render từng scene.</MudText>
        </div>
        <MudStack Row="true" Spacing="2" Class="flex-wrap gap-2">
            <MudButton Color="Color.Warning" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="NewProjectAsync">Tạo mới</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="ReloadAsync" Disabled="@(_projectId is null)">Refresh</MudButton>
        </MudStack>
    </MudStack>

    @if (!AuthState.IsInitialized)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Warning" />
    }
    else if (AuthState.CurrentUser is null)
    {
        <MudAlert Severity="Severity.Warning">Vui lòng đăng nhập.</MudAlert>
    }
    else
    {
        <MudTabs rounded="true" ApplyEffectsToContainer="true" panelClass="pt-4" @bind-ActivePanelIndex="_tabIndex">
            <MudTabPanel Text="Thông tin">
                <MudPaper Class="todox-card pa-4" rounded="true">
                    <MudGrid>
                        <MudItem xs="12" md="4">
                            <MudPaper Class="pa-4 d-flex flex-column h-100" Outlined="true" rounded="true">
                                <MudStack Spacing="2" Class="h-100">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
                                        <MudText Typo="Typo.h6">Nhân vật</MudText>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="ClearSelectedCharacterAsync" Disabled="@(_busy || _selectedCharacter is null)">Không sử dụng Character</MudButton>
                                    </MudStack>
                                    <MudAlert Severity="Severity.Info" Dense="true">Chọn một Character hoạt động hoặc để trống để tạo project không dùng Character.</MudAlert>
                                    <MudSelect T="long?" Label="Chọn nhân vật" Value="@(_selectedCharacterId)" ValueChanged="OnCharacterChangedAsync" Variant="Variant.Outlined" Dense="true" ToStringFunc="ResolveCharacterName">
                                        <MudSelectItem T="long?" Value="@((long?)null)">Không sử dụng nhân vật</MudSelectItem>
                                        @foreach (var character in _characters)
                                        {
                                            <MudSelectItem T="long?" Value="@character.Id">@character.CharacterName</MudSelectItem>
                                        }
                                    </MudSelect>
                                    <MudDivider />
                                    <div style="max-height:420px;overflow:auto;display:flex;flex-direction:column;gap:12px;">
                                        @foreach (var character in _characters)
                                        {
                                            <MudPaper Class="@GetCharacterCardClass(character.Id)" Outlined="true" rounded="true" @onclick="@(() => OnCharacterChangedAsync(character.Id))" style="cursor:pointer">
                                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
                                                    <div class="character-thumb-wrap">
                                                        @if (!string.IsNullOrWhiteSpace(character.MasterImageUrl))
                                                        {
                                                            <img src="@character.MasterImageUrl" style="width:100%;height:100%;object-fit:cover;border-radius:10px;" @onclick="@(() => OpenCharacterPreview(character))" />
                                                        }
                                                        else
                                                        {
                                                            <MudPaper Class="pa-2 text-center" rounded="true" Outlined="true">No img</MudPaper>
                                                        }
                                                    </div>
                                                    <MudStack Spacing="1">
                                                        <MudText Typo="Typo.subtitle2">@character.CharacterName</MudText>
                                                        @if (!string.IsNullOrWhiteSpace(character.Description))
                                                        {
                                                            <MudText Typo="Typo.caption">@character.Description</MudText>
                                                        }
                                                    </MudStack>
                                                </MudStack>
                                            </MudPaper>
                                        }
                                    </div>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" md="8">
                            <MudPaper Class="pa-4 h-100" Outlined="true" rounded="true">
                                <MudStack Spacing="2" Class="h-100">
                                    <MudTextField T="string" Label="Prompt video" @bind-Value="_prompt" Variant="Variant.Outlined" Lines="10" Immediate="true" />
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="CheckPromptAsync">Kiểm tra cấu trúc</MudButton>
                                    <MudAlert Severity="@( _promptParseResult.IsJsonValid ? (_promptParseResult.IsTodoXPrompt ? Severity.Success : Severity.Info) : Severity.Warning )" Dense="true">
                                        @(_promptParseResult.IsJsonValid ? (_promptParseResult.IsTodoXPrompt ? "Prompt TodoX hợp lệ." : "Prompt thường.") : "JSON không hợp lệ hoặc chưa parse được.")
                                    </MudAlert>
                                    @if (!string.IsNullOrWhiteSpace(_promptParseResult.ErrorMessage))
                                    {
                                        <MudAlert Severity="Severity.Warning" Dense="true">@_promptParseResult.ErrorMessage</MudAlert>
                                    }
                                    @if (_promptParseResult.Model is not null)
                                    {
                                        <MudGrid>
                                            <MudItem xs="12" md="6"><MudText><b>Tiêu đề video:</b> @_promptParseResult.Summary.VideoTitle</MudText></MudItem>
                                            <MudItem xs="12" md="6"><MudText><b>Mục tiêu video:</b> @_promptParseResult.Summary.VideoObjective</MudText></MudItem>
                                            <MudItem xs="12" md="6"><MudText><b>Phong cách:</b> @_promptParseResult.Summary.Style</MudText></MudItem>
                                            <MudItem xs="12" md="6"><MudText><b>CTA:</b> @_promptParseResult.Summary.Cta</MudText></MudItem>
                                            <MudItem xs="12" md="6"><MudText><b>DeclaredDuration:</b> @_promptParseResult.Summary.DeclaredDurationSeconds</MudText></MudItem>
                                            <MudItem xs="12" md="6"><MudText><b>SceneCount:</b> @_promptParseResult.Summary.SceneCount</MudText></MudItem>
                                        </MudGrid>
                                        @if (_promptParseResult.Summary.HasDurationMismatch)
                                        {
                                            <MudAlert Severity="Severity.Warning" Dense="true">@_promptParseResult.Summary.DurationMismatchMessage</MudAlert>
                                        }
                                    }
                                    <MudGrid>
                                        <MudItem xs="12" md="4"><MudNumericField T="int" Label="Tổng số giây" @bind-Value="_totalSeconds" Min="1" Variant="Variant.Outlined" /></MudItem>
                                        <MudItem xs="12" md="4"><MudNumericField T="int" Label="Giây mỗi scene" @bind-Value="_sceneSeconds" Min="1" Variant="Variant.Outlined" /></MudItem>
                                        <MudItem xs="12" md="4"><MudCheckBox @bind-Value="_thinkScenes" Label="Suy nghĩ kịch bản" /></MudItem>
                                    </MudGrid>
                                    <MudStack Row="true" Spacing="2" Class="flex-wrap gap-2">
                                        <MudButton Color="Color.Warning" Variant="Variant.Filled" OnClick="CreateProjectAsync" Disabled="@_busy">Tạo / phân tách scene</MudButton>
                                        <MudButton Color="Color.Primary" Variant="Variant.Outlined" OnClick="CreateEmptyProjectAsync" Disabled="@_busy">Tạo project rỗng</MudButton>
                                        <MudButton Color="Color.Primary" Variant="Variant.Outlined" OnClick="ReloadAsync" Disabled="@(_projectId is null || _busy)">Refresh</MudButton>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12">
                            <MudPaper Class="todox-card pa-4 mt-3" rounded="true">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
                                    <MudText Typo="Typo.h6">Nhật ký phân tách scene</MudText>
                                    <MudStack Row="true" Spacing="1" Class="flex-wrap gap-2">
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="ClearDebugLogAsync">Xóa log</MudButton>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="CopyDebugLogAsync">Sao chép log</MudButton>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="DownloadDebugLogAsync">Tải log .txt</MudButton>
                                    </MudStack>
                                </MudStack>
                                <MudDivider Class="my-2" />
                                <div id="render-job-debug-log" style="max-height:260px;overflow:auto;display:flex;flex-direction:column-reverse;gap:8px;">
                                    @if (_debugEntries.Count == 0)
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Chưa có log.</MudText>
                                    }
                                    else
                                    {
                                        @foreach (var entry in _debugEntries.OrderByDescending(x => x.StepNumber).ThenByDescending(x => x.Timestamp))
                                        {
                                            <MudPaper Class="pa-3" Outlined="true">
                                                <MudStack Spacing="1">
                                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="flex-wrap gap-2">
                                                        <MudText Typo="Typo.subtitle2">Bước @entry.StepNumber - @entry.StepName</MudText>
                                                        <MudChip T="string" Color="@LogColor(entry.Status)">@entry.Status</MudChip>
                                                    </MudStack>
                                                    <MudText Typo="Typo.caption">@entry.Timestamp.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss.fff") • @entry.StepCode • @entry.DurationMs ms</MudText>
                                                    <MudText Typo="Typo.body2">@entry.Message</MudText>
                                                    @if (!string.IsNullOrWhiteSpace(entry.Details))
                                                    {
                                                        <pre style="white-space:pre-wrap;margin:0">@entry.Details</pre>
                                                    }
                                                </MudStack>
                                            </MudPaper>
                                        }
                                    }
                                </div>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudTabPanel>

            <MudTabPanel Text="Scene">
                @if (_project is null)
                {
                    <MudAlert Severity="Severity.Info">Hãy tạo project ở tab Thông tin trước.</MudAlert>
                }
                else
                {
                    <MudStack Row="true" Spacing="2" Class="flex-wrap gap-2 mb-3">
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="RenderAllSceneImagesAsync" Disabled="@_busy">Tạo ảnh tĩnh tất cả scene</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="EnqueueRenderAllScenesAsync" Disabled="@_busy">Render all</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ReloadAsync" Disabled="@_busy">Refresh</MudButton>
                    </MudStack>

                    <MudProgressLinear Indeterminate="true" Color="Color.Warning" Class="mb-3" Style="@(_busy ? "visibility:visible" : "visibility:hidden")" />

                    <MudTable Items="_project.Scenes.OrderBy(x => x.SceneIndex).ToList()" Dense="true" Hover="true" Bordered="true" Breakpoint="Breakpoint.Sm">
                        <HeaderContent>
                            <MudTh>STT</MudTh>
                            <MudTh>Ảnh tĩnh</MudTh>
                            <MudTh>Nội dung scene</MudTh>
                            <MudTh>Thời lượng</MudTh>
                            <MudTh>Prompt</MudTh>
                            <MudTh>Trạng thái</MudTh>
                            <MudTh>Thao tác</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="STT">Scene @context.SceneIndex.ToString("00")</MudTd>
                            <MudTd DataLabel="Ảnh tĩnh">
                                <div class="scene-thumb-cell">
                                    @if (!string.IsNullOrWhiteSpace(context.StaticImageUrl))
                                    {
                                        <img src="@SceneImageUrl(context)" class="scene-thumb" @onclick="@(() => OpenScenePreview(context))" />
                                    }
                                    else
                                    {
                                        <div class="scene-thumb-placeholder">Chưa render</div>
                                    }
                                </div>
                            </MudTd>
                            <MudTd DataLabel="Nội dung scene">
                                <MudText Typo="Typo.subtitle2">@context.Title</MudText>
                                <MudText Typo="Typo.body2"><b>Purpose:</b> @ExtractScenePurpose(context.ScenePrompt)</MudText>
                                <MudText Typo="Typo.body2"><b>Voice:</b> @ExtractValue(context.ScenePrompt, "voice")</MudText>
                                <MudText Typo="Typo.body2"><b>VoiceInstruction:</b> @ExtractValue(context.ScenePrompt, "voice_instruction")</MudText>
                            </MudTd>
                            <MudTd DataLabel="Thời lượng">@context.DurationSeconds giây</MudTd>
                            <MudTd DataLabel="Prompt">
                                <MudMenu Dense="true" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                    <ActivatorContent Context="promptMenu">
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Visibility">Xem prompt</MudButton>
                                    </ActivatorContent>
                                    <ChildContent>
                                        <MudMenuItem OnClick="@(() => OpenScenePrompt(context, ScenePromptKind.Image))">Prompt ảnh</MudMenuItem>
                                        <MudMenuItem OnClick="@(() => OpenScenePrompt(context, ScenePromptKind.Motion))">Chuyển động</MudMenuItem>
                                        <MudMenuItem OnClick="@(() => OpenScenePrompt(context, ScenePromptKind.Voice))">Lời thoại</MudMenuItem>
                                    </ChildContent>
                                </MudMenu>
                            </MudTd>
                            <MudTd DataLabel="Trạng thái"><MudChip T="string" Color="@SceneColor(context.Status)">@SceneLabel(context.Status)</MudChip></MudTd>
                            <MudTd DataLabel="Thao tác">
                                <MudStack Spacing="1">
                                    <MudStack Row="true" Spacing="0" Class="flex-wrap gap-1 scene-action-icons">
                                        <MudTooltip Text="Xem prompt"><MudIconButton Icon="@Icons.Material.Filled.SavedSearch" Size="Size.Small" Color="Color.Primary" OnClick="@(() => OpenScenePrompt(context, ScenePromptKind.Image))" /></MudTooltip>
                                        <MudTooltip Text="Render ảnh"><MudIconButton Icon="@Icons.Material.Filled.Image" Size="Size.Small" Color="Color.Warning" OnClick="@(() => RenderSceneImageAsync(context))" Disabled="@_busy" /></MudTooltip>
                                        <MudTooltip Text="Lưu scene"><MudIconButton Icon="@Icons.Material.Filled.Save" Size="Size.Small" Color="Color.Success" OnClick="@(() => SaveSceneAsync(context))" Disabled="@_busy" /></MudTooltip>
                                        <MudTooltip Text="Lên"><MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" Color="Color.Default" OnClick="@(() => MoveSceneUpAsync(context))" Disabled="@(_busy || context.SceneIndex <= 1)" /></MudTooltip>
                                        <MudTooltip Text="Xuống"><MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" Color="Color.Default" OnClick="@(() => MoveSceneDownAsync(context))" Disabled="@(_busy || _project is null || context.SceneIndex >= _project.Scenes.Count)" /></MudTooltip>
                                        <MudTooltip Text="Xóa"><MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteSceneAsync(context))" Disabled="@_busy" /></MudTooltip>
                                    </MudStack>
                                    <MudStack Row="true" Spacing="1" Class="flex-wrap gap-1">
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" OnClick="@(() => RenderSceneImageAsync(context))" Disabled="@_busy">@(string.IsNullOrWhiteSpace(context.StaticImageUrl) ? "Tạo ảnh" : "Render lại ảnh")</MudButton>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => SaveSceneAsync(context))" Disabled="@_busy">Lưu</MudButton>
                                    </MudStack>
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudTabPanel>

            <MudTabPanel Text="Kết quả">
                @if (_project is null)
                {
                    <MudAlert Severity="Severity.Info">Chưa có project.</MudAlert>
                }
                else
                {
                    <MudPaper Class="todox-card pa-4" rounded="true">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6">@(_project.Title ?? "Video project")</MudText>
                            <MudText>Trạng thái: @_project.Status</MudText>
                            <MudText>Final video: @_project.FinalVideoUrl</MudText>
                            <MudStack Row="true" Spacing="2" Class="flex-wrap gap-2">
                                <MudButton Color="Color.Warning" Variant="Variant.Filled" OnClick="EnqueueMergeAsync" Disabled="@(_busy || !CanMerge)">Tạo video kết quả</MudButton>
                                <MudButton Color="Color.Primary" Variant="Variant.Outlined" OnClick="ReloadAsync">Refresh</MudButton>
                            </MudStack>
                            @if (!string.IsNullOrWhiteSpace(_project.FinalVideoUrl))
                            {
                                <video src="@_project.FinalVideoUrl" controls style="width:100%;border-radius:12px"></video>
                            }
                        </MudStack>
                    </MudPaper>

                    <MudPaper Class="todox-card pa-4 mt-4" rounded="true">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
                            <MudText Typo="Typo.h6">Log thao tác</MudText>
                            <MudStack Row="true" Spacing="1" Class="flex-wrap gap-1">
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="ReloadAsync">Refresh log</MudButton>
                            </MudStack>
                        </MudStack>
                        <MudDivider Class="my-2" />
                        <div class="video-render-log-panel" style="max-height:320px;overflow:auto;">
                            @foreach (var log in _project.Events.Take(50))
                            {
                                <MudPaper Class="pa-3 mb-2" rounded="true" Outlined="true">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="flex-wrap gap-1">
                                            <MudChip T="string" Size="Size.Small" Color="@LogColor(log.Level)">@log.Level</MudChip>
                                            <MudText Typo="Typo.subtitle2">@log.EventType</MudText>
                                            <MudText Typo="Typo.caption">@log.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</MudText>
                                        </MudStack>
                                        <MudText>@log.Message</MudText>
                                        @if (!string.IsNullOrWhiteSpace(log.DataJson))
                                        {
                                            <pre style="white-space:pre-wrap;margin:0">@log.DataJson</pre>
                                        }
                                    </MudStack>
                                </MudPaper>
                            }
                        </div>
                    </MudPaper>

                    <MudPaper Class="todox-card pa-4 mt-4" rounded="true">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
                            <MudText Typo="Typo.h6">Danh sách job render</MudText>
                            <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="ReloadJobsAsync">Refresh jobs</MudButton>
                        </MudStack>
                        <MudDivider Class="my-2" />
                        @if (_jobs.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info">Chưa có job nào cho project này.</MudAlert>
                        }
                        else
                        {
                            <MudTable Items="_jobs" Dense="true" Hover="true">
                                <HeaderContent>
                                    <MudTh>Job</MudTh>
                                    <MudTh>Type</MudTh>
                                    <MudTh>Status</MudTh>
                                    <MudTh>Provider / Model</MudTh>
                                    <MudTh>Thời gian</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Job">@context.Id</MudTd>
                                    <MudTd DataLabel="Type">@context.JobType</MudTd>
                                    <MudTd DataLabel="Status"><MudChip T="string" Color="@JobColor(context.Status)">@context.Status</MudChip></MudTd>
                                    <MudTd DataLabel="Provider / Model">@context.ProviderCode / @context.ModelCode</MudTd>
                                    <MudTd DataLabel="Thời gian">@context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudPaper>
                }
            </MudTabPanel>
        </MudTabs>
    }
</MudStack>

@code {
    private int _tabIndex;
    private bool _busy;
    private long? _projectId;
    private VideoProjectDto? _project;
    private List<RenderJobDto> _jobs = new();
    private readonly List<ActiveCharacterDto> _characters = new();
    private ActiveCharacterDto? _selectedCharacter;
    private long? _selectedCharacterId;
    private string _prompt = string.Empty;
    private string _characterPrompt = string.Empty;
    private TodoXVideoPromptParseResult _promptParseResult = new();
    private int _totalSeconds = 16;
    private int _sceneSeconds = 8;
    private bool _thinkScenes = false;
    private PeriodicTimer? _pollTimer;
    private CancellationTokenSource? _pollCts;
    private readonly List<DebugEntry> _debugEntries = new();
    private int _debugStep;

    private bool CanMerge => _project is not null && _project.Scenes.Count > 0 && _project.Scenes.All(x => x.Status == VideoSceneStatuses.VideoReady);

    private string BuildLogCode() => _projectId is null ? string.Empty : $"video-{_projectId.Value}";

    private sealed record DebugEntry(DateTimeOffset Timestamp, int StepNumber, string StepCode, string StepName, string Status, long DurationMs, string Message, string? Details = null);

    protected override async Task OnInitializedAsync()
    {
        if (AuthState.CurrentUser is not null)
        {
            await LoadCharactersAsync();
        }
        if (AuthState.CurrentUser is not null && _projectId is not null)
        {
            await ReloadAsync();
        }
        await StartPolling();
    }

    public void Dispose()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollTimer?.Dispose();
    }

    private async Task CreateProjectAsync()
    {
        if (AuthState.CurrentUser is null) return;
        _busy = true;
        try
        {
            if (!_promptParseResult.IsJsonValid)
            {
                _promptParseResult = PromptParser.Parse(_prompt);
            }
            await AddDebugAsync("ui_started", "Bắt đầu xử lý", "STARTED", "Người dùng bấm nút Tạo / phân tách scene.");
            await AddDebugAsync("ui_auth", "Kiểm tra đăng nhập", "INFO", $"User={MaskGuid(AuthState.CurrentUser.UserId)}, Customer={MaskGuid(AuthState.CurrentUser.CustomerId)}");
            var inputDebug = BuildInputDebugMessage();
            await AddDebugAsync("ui_input", "Kiểm tra prompt", "INFO", inputDebug);

            var storageRoot = VideoOptions.CurrentValue.StorageRoot;
            var publicBase = VideoOptions.CurrentValue.PublicBase;
            var jobFolder = DateTime.UtcNow.ToString("yyyyMMdd-HHmmss");
            await AddDebugAsync("repo_call", "Gọi repository", "INFO", $"storageRoot={storageRoot}, publicBase={publicBase}, jobFolder={jobFolder}");
            var result = await VideoRepo.CreateProjectAsync(new VideoProjectCreateRequest
            {
                Prompt = _prompt,
                CharacterId = _selectedCharacter?.Id,
                TotalSeconds = _totalSeconds,
                SceneSeconds = Math.Max(1, _sceneSeconds),
                ThinkScenes = _thinkScenes,
                Title = _promptParseResult.Model.VideoTitle ?? "Render video job",
                CreateEmptyProject = false,
                Scenes = BuildSceneRequests()
            }, AuthState.CurrentUser.UserId, AuthState.CurrentUser.CustomerId, storageRoot, publicBase, jobFolder);
            _projectId = result.Id;
            Logger.LogInformation("VIDEO_RENDER_CREATE_PROJECT_OK projectId={ProjectId} sceneCount={SceneCount} status={Status}", result.Id, result.SceneCount, result.Status);
            await ReloadAsync();
