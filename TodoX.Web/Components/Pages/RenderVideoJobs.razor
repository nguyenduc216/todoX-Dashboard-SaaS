    private List<VideoProjectSceneCreateRequest> BuildSceneRequests()
    {
        if (_promptParseResult.HasScenes)
        {
            return _promptParseResult.Model.Scenes
                .OrderBy(x => x.Scene ?? int.MaxValue)
                .Select((scene, index) => new VideoProjectSceneCreateRequest
                {
                    SceneIndex = scene.Scene ?? index + 1,
                    Title = $"Scene {scene.Scene ?? index + 1}",
                    DurationSeconds = scene.DurationSeconds ?? _sceneSeconds,
                    ScenePrompt = BuildSceneMetadata(scene),
                    ImagePrompt = scene.ImagePrompt,
                    VideoPrompt = scene.MotionPrompt
                })
                .ToList();
        }

        var fallbackCount = Math.Max(1, (int)Math.Ceiling(Math.Max(1, _totalSeconds) / (double)Math.Max(1, _sceneSeconds)));
        return Enumerable.Range(1, fallbackCount)
            .Select(index => new VideoProjectSceneCreateRequest
            {
                SceneIndex = index,
                Title = $"Scene {index}",
                DurationSeconds = index == fallbackCount ? Math.Max(1, _totalSeconds - _sceneSeconds * (fallbackCount - 1)) : _sceneSeconds,
                ScenePrompt = $"scene_purpose: main_content | image_prompt: Scene {index} image prompt | motion_prompt: Scene {index} motion prompt | voice: Scene {index} voice | voice_instruction: Scene {index} voice instruction",
                ImagePrompt = $"Scene {index} image prompt",
                VideoPrompt = $"Scene {index} motion prompt"
            })
            .ToList();
    }

    private static string BuildSceneMetadata(TodoXVideoScenePromptModel scene)
        => string.Join(" | ", new[]
        {
            scene.ScenePurpose is null ? null : $"scene_purpose: {scene.ScenePurpose}",
            scene.ImagePrompt is null ? null : $"image_prompt: {scene.ImagePrompt}",
            scene.MotionPrompt is null ? null : $"motion_prompt: {scene.MotionPrompt}",
            scene.Voice is null ? null : $"voice: {scene.Voice}",
            scene.VoiceInstruction is null ? null : $"voice_instruction: {scene.VoiceInstruction}"
        }.Where(x => !string.IsNullOrWhiteSpace(x)));

