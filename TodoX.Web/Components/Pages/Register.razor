@page "/register"
@layout AuthLayout
@inject AccountService Accounts
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Đăng ký tài khoản TodoX</PageTitle>

<div class="todox-auth-page">
    <div class="todox-auth-grid">
        <div class="todox-auth-hero">
            <img src="img/todox-logo.jpg" alt="TodoX" />
            <MudText Typo="Typo.h3" Class="mt-6 todox-page-title">Đăng ký khách hàng</MudText>
            <MudText Typo="Typo.body1" Class="todox-page-subtitle mt-2">Tạo hồ sơ khách hàng và tài khoản chủ sở hữu để sử dụng dịch vụ TodoX.</MudText>
        </div>

        <MudPaper Class="todox-auth-card pa-6" Rounded="true">
            <MudText Typo="Typo.h5" Class="todox-page-title">Thông tin đăng ký</MudText>
            <MudGrid Class="mt-2">
                <MudItem xs="12">
                    <MudTextField T="string" Label="Tên công ty / khách hàng" Variant="Variant.Outlined" @bind-Value="_model.CompanyName" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Người liên hệ" Variant="Variant.Outlined" @bind-Value="_model.ContactName" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Số điện thoại" Variant="Variant.Outlined" @bind-Value="_model.Phone" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Email" Variant="Variant.Outlined" @bind-Value="_model.Email" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Mã số thuế" Variant="Variant.Outlined" @bind-Value="_model.TaxCode" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="Giới tính" Variant="Variant.Outlined" @bind-Value="_model.Gender">
                        <MudSelectItem Value="@("male")">Nam</MudSelectItem>
                        <MudSelectItem Value="@("female")">Nữ</MudSelectItem>
                        <MudSelectItem Value="@("other")">Khác</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="Ngày sinh" Variant="Variant.Outlined" @bind-Date="_dob" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Mật khẩu" Variant="Variant.Outlined" @bind-Value="_model.Password" InputType="InputType.Password" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Xác nhận mật khẩu" Variant="Variant.Outlined" @bind-Value="_model.ConfirmPassword" InputType="InputType.Password" />
                </MudItem>
            </MudGrid>

            <MudButton FullWidth="true" Class="todox-primary-btn mt-5" OnClick="RegisterCustomer">Đăng ký</MudButton>
            <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-5 todox-page-subtitle">
                Đã có tài khoản? <MudLink Href="/login" Class="todox-gold">Đăng nhập</MudLink>
            </MudText>
        </MudPaper>
    </div>
</div>

@code {
    private readonly CustomerRegistration _model = new();
    private DateTime? _dob;

    private async Task RegisterCustomer()
    {
        _model.DateOfBirth = _dob;
        var result = await Accounts.RegisterCustomerAsync(_model);
        if (!result.Success)
        {
            Snackbar.Add(result.Message, Severity.Error);
            return;
        }

        Snackbar.Add(result.Message, Severity.Success);
        Navigation.NavigateTo("/login");
    }
}
