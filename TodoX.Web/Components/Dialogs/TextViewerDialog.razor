<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
            <MudText Typo="Typo.h6">@Title</MudText>
            <MudStack Row="true" Spacing="1">
                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" OnClick="RenderAgain">Render / cập nhật</MudButton>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="Close" />
            </MudStack>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string" Value="@Text" ReadOnly="true" Lines="18" Variant="Variant.Outlined" FullWidth="true" />
    </DialogContent>
</MudDialog>

@code {
    [Parameter] public string Title { get; set; } = "Nội dung";
    [Parameter] public string Text { get; set; } = string.Empty;
    [Parameter] public EventCallback OnRenderAgain { get; set; }
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    private void Close() => MudDialog.Close();
    private Task RenderAgain() => OnRenderAgain.HasDelegate ? OnRenderAgain.InvokeAsync() : Task.CompletedTask;
}
